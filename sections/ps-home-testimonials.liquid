{% assign total_reviews = 0 %}
{% for i in (1..6) %}
  {% assign text_key = 'review_' | append: i | append: '_text' %}
  {% if section.settings[text_key] != blank %}
    {% assign total_reviews = total_reviews | plus: 1 %}
  {% endif %}
{% endfor %}

{% if total_reviews > 0 %}
<section class="ps-htestimonials" id="ps-htestimonials">
  <div class="ps-htestimonials-inner">

    <div class="ps-htestimonials-header ps-reveal">
      <div class="ps-section-tag">⭐ Customer Love</div>
      <h2 class="ps-section-h2 ps-reveal ps-rd1">What Our <em>Customers Say!</em></h2>
      <p class="ps-htestimonials-sub ps-reveal ps-rd2">Real words from real people who've brought a little Iowa into their homes.</p>
    </div>

    <div class="ps-htestimonials-track-wrap">
      <button class="ps-htestimonials-arrow ps-htestimonials-prev" aria-label="Previous review">&#8592;</button>
      <div class="ps-htestimonials-viewport">
      <div class="ps-htestimonials-track" id="psTestimonialsTrack">
        {% for i in (1..6) %}
          {% assign text_key  = 'review_' | append: i | append: '_text' %}
          {% assign name_key  = 'review_' | append: i | append: '_name' %}
          {% assign stars_key = 'review_' | append: i | append: '_stars' %}
          {% assign prod_key  = 'review_' | append: i | append: '_product' %}
          {% if section.settings[text_key] != blank %}
            <div class="ps-htestimonials-card">
              <div class="ps-htestimonials-quote">✿</div>
              <p class="ps-htestimonials-text">{{ section.settings[text_key] }}</p>
              <div class="ps-htestimonials-stars">
                {% assign star_count = section.settings[stars_key] | default: 5 %}
                {% for s in (1..5) %}
                  {% if s <= star_count %}<span class="ps-hstar ps-hstar-filled">★</span>{% else %}<span class="ps-hstar">★</span>{% endif %}
                {% endfor %}
              </div>
              <div class="ps-htestimonials-reviewer">
                <span class="ps-htestimonials-name">— {{ section.settings[name_key] | default: 'Happy Customer' }}</span>
                {% if section.settings[prod_key] != blank %}
                  <span class="ps-htestimonials-product">{{ section.settings[prod_key] }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      </div>
      <button class="ps-htestimonials-arrow ps-htestimonials-next" aria-label="Next review">&#8594;</button>
    </div>

    <div class="ps-htestimonials-dots" id="psTestimonialsDots"></div>

  </div>
</section>

<style>
.ps-htestimonials {
  background: var(--lav-xlight);
  padding: 5rem 2rem 4.5rem;
  position: relative;
  overflow: hidden;
}
.ps-htestimonials::before {
  content: '✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿ ✿';
  position: absolute;
  top: 1.2rem;
  left: 0;
  width: 100%;
  text-align: center;
  font-size: .9rem;
  color: var(--border);
  letter-spacing: .5rem;
  white-space: nowrap;
  overflow: hidden;
}
.ps-htestimonials-inner {
  max-width: 900px;
  margin: 0 auto;
}
.ps-htestimonials-header {
  text-align: center;
  margin-bottom: 3rem;
}
.ps-htestimonials-sub {
  font-family: 'Caveat', cursive;
  font-size: 1.2rem;
  color: var(--lav-ink);
  max-width: 480px;
  margin: .5rem auto 0;
  line-height: 1.5;
}
.ps-htestimonials-track-wrap {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.ps-htestimonials-viewport {
  overflow: hidden;
  flex: 1;
  min-width: 0;
}
.ps-htestimonials-track {
  display: flex;
  transition: transform .4s ease;
}
.ps-htestimonials-card {
  flex: 0 0 100%;
  width: 100%;
  background: white;
  border-radius: 20px;
  border: 2px solid var(--border);
  padding: 2.5rem 2.5rem 2rem;
  box-shadow: 0 4px 24px rgba(124,77,158,.1);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .75rem;
  transition: transform .4s ease;
}
.ps-htestimonials-quote {
  font-size: 2rem;
  color: var(--lav-mid);
  line-height: 1;
  margin-bottom: .25rem;
}
.ps-htestimonials-text {
  font-family: 'Nunito', sans-serif;
  font-size: 1.15rem;
  font-style: italic;
  color: var(--lav-ink);
  line-height: 1.7;
  max-width: 620px;
  margin: 0 auto;
}
.ps-htestimonials-stars {
  display: flex;
  gap: .1rem;
  justify-content: center;
}
.ps-hstar {
  font-size: 1.4rem;
  color: var(--border);
}
.ps-hstar-filled {
  color: #F5A623;
}
.ps-htestimonials-reviewer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .2rem;
  margin-top: .25rem;
}
.ps-htestimonials-name {
  font-family: 'Nunito', sans-serif;
  font-weight: 800;
  font-size: 1rem;
  color: var(--lav);
}
.ps-htestimonials-product {
  font-family: 'Caveat', cursive;
  font-size: .95rem;
  color: var(--lav-mid);
}
.ps-htestimonials-arrow {
  background: var(--lav);
  color: white;
  border: none;
  border-radius: 50%;
  width: 44px;
  height: 44px;
  font-size: 1.2rem;
  cursor: pointer;
  flex-shrink: 0;
  transition: background .2s, transform .15s;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 3px 10px rgba(124,77,158,.25);
}
.ps-htestimonials-arrow:hover {
  background: var(--lav-dark);
  transform: scale(1.08);
}
.ps-htestimonials-dots {
  display: flex;
  justify-content: center;
  gap: .5rem;
  margin-top: 1.5rem;
}
.ps-htestimonials-dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--border);
  cursor: pointer;
  transition: background .2s, transform .2s;
  border: none;
  padding: 0;
}
.ps-htestimonials-dot.active {
  background: var(--lav);
  transform: scale(1.3);
}
@media (max-width: 600px) {
  .ps-htestimonials-card { padding: 2rem 1.25rem 1.75rem; }
  .ps-htestimonials-text { font-size: 1rem; }
  .ps-htestimonials-arrow { width: 36px; height: 36px; font-size: 1rem; }
}
</style>

<script>
(function() {
  var track = document.getElementById('psTestimonialsTrack');
  var dotsWrap = document.getElementById('psTestimonialsDots');
  if (!track) return;
  var cards = track.querySelectorAll('.ps-htestimonials-card');
  var total = cards.length;
  var current = 0;
  var dots = [];

  // Build dots
  for (var i = 0; i < total; i++) {
    var d = document.createElement('button');
    d.className = 'ps-htestimonials-dot' + (i === 0 ? ' active' : '');
    d.setAttribute('aria-label', 'Review ' + (i + 1));
    d.dataset.idx = i;
    d.addEventListener('click', function() { goTo(parseInt(this.dataset.idx)); });
    dotsWrap.appendChild(d);
    dots.push(d);
  }

  function goTo(idx) {
    current = (idx + total) % total;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
  }

  document.querySelector('.ps-htestimonials-prev').addEventListener('click', function() { goTo(current - 1); });
  document.querySelector('.ps-htestimonials-next').addEventListener('click', function() { goTo(current + 1); });

  // Auto-rotate
  setInterval(function() { goTo(current + 1); }, 6000);
})();
</script>
{% endif %}

