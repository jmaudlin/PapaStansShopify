{%- comment -%}
  /collections — Split Kinetic collections directory.
  Diagonal header band + angled kinetic cards, matching collection/blog/search.
{%- endcomment -%}

{%- paginate collections by section.settings.per_page -%}

<div class="ps-sk-head">
  <div class="ps-sk-head-inner">
    <div class="ps-section-tag">{{ section.settings.eyebrow | default: '🧺 Browse' }}</div>
    <h1>{{ section.settings.heading | default: 'Shop by Collection' }}</h1>
    {%- if section.settings.subtext != blank -%}
      <p class="ps-sk-head-sub">{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>
</div>

<div class="ps-page-wrap">

  <div class="ps-lc-grid">
    {%- for col in collections -%}
      {%- if section.settings.hide_utility -%}
        {%- if col.handle == 'frontpage' or col.handle contains 'featured' -%}{%- continue -%}{%- endif -%}
      {%- endif -%}
      {%- if section.settings.hide_empty and col.products_count == 0 -%}{%- continue -%}{%- endif -%}

      {%- assign lc_img = col.image | default: col.products.first.featured_image -%}
      <a href="{{ col.url }}" class="ps-lc-card">
        <div class="ps-lc-img">
          {%- if lc_img -%}
            <img src="{{ lc_img | image_url: width: 600, height: 450, crop: 'center' }}"
                 srcset="{{ lc_img | image_url: width: 400, height: 300, crop: 'center' }} 400w,
                         {{ lc_img | image_url: width: 600, height: 450, crop: 'center' }} 600w"
                 sizes="(max-width: 700px) 90vw, (max-width: 1000px) 44vw, 370px"
                 alt="{{ col.title | escape }}"
                 width="600" height="450" loading="lazy">
          {%- else -%}
            <div class="ps-lc-img-fallback">🧼</div>
          {%- endif -%}
          <span class="ps-lc-count">{{ col.products_count }} {% if col.products_count == 1 %}product{% else %}products{% endif %}</span>
        </div>
        <div class="ps-lc-body">
          <h2 class="ps-lc-title">{{ col.title }}</h2>
          {%- if col.description != blank -%}
            <p class="ps-lc-desc">{{ col.description | strip_html | truncate: 90 }}</p>
          {%- endif -%}
          <span class="ps-lc-go">Shop {{ col.title }} →</span>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when '@app' -%}
        <div {{ block.shopify_attributes }}>{% render block %}</div>
    {%- endcase -%}
  {%- endfor -%}

  {%- if paginate.pages > 1 -%}
    <div class="ps-pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="ps-btn-secondary">← Previous</a>
      {%- endif -%}
      <span class="ps-page-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="ps-btn-primary">Next →</a>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

{%- endpaginate -%}

<script>
const psNavOnScroll = () => document.getElementById('psNav').classList.toggle('scrolled', (document.body.scrollTop || window.scrollY) > 10);
document.body.addEventListener('scroll', psNavOnScroll, { passive: true });
window.addEventListener('scroll', psNavOnScroll, { passive: true });
</script>

{% schema %}
{
  "name": "Collections List",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "🧺 Browse" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Collection" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Every collection, handcrafted in small batches in Oskaloosa, Iowa." },
    { "type": "range", "id": "per_page", "label": "Collections per page", "min": 6, "max": 24, "step": 3, "default": 12 },
    { "type": "checkbox", "id": "hide_empty", "label": "Hide empty collections", "default": true },
    { "type": "checkbox", "id": "hide_utility", "label": "Hide utility collections (frontpage, featured)", "default": true }
  ],
  "blocks": [ { "type": "@app" } ],
  "templates": [ "list-collections" ]
}
{% endschema %}
