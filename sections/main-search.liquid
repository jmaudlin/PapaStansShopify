{% render 'ps-account-nav' %}

<div class="ps-page-wrap">

  <!-- Search header -->
  <div class="ps-blog-header">
    <div class="ps-section-tag" style="margin-bottom:.7rem">🔍 Search</div>
    <h1 class="ps-section-h2">Search <em>Papa Stan's</em></h1>
  </div>

  <!-- Search form -->
  <form action="{{ routes.search_url }}" method="get" class="ps-search-form" role="search">
    <input type="hidden" name="options[prefix]" value="last">
    <div class="ps-search-input-wrap">
      <input
        type="search"
        name="q"
        class="ps-form-input ps-search-input"
        placeholder="Search products, blog posts…"
        value="{{ search.terms | escape }}"
        aria-label="Search"
        autocomplete="off">
      <button type="submit" class="ps-btn-primary ps-search-btn">🔍 Search</button>
    </div>

    <!-- Search type tabs -->
    <div class="ps-search-type-tabs">
      <label class="ps-search-type-tab {% unless request.path contains '/blogs/' %}ps-search-type-active{% endunless %}">
        <input type="radio" name="type" value="product,page" {% unless search.results.first.object_type == 'article' %}checked{% endunless %}> 🛒 Products &amp; Pages
      </label>
      <label class="ps-search-type-tab {% if request.path contains '/blogs/' %}ps-search-type-active{% endif %}">
        <input type="radio" name="type" value="article"> 📝 Blog Posts
      </label>
    </div>
  </form>

  <!-- Results -->
  {%- if search.performed -%}

    {%- if search.results_count > 0 -%}
      <div class="ps-search-summary">
        Found <strong>{{ search.results_count }}</strong> result{{ search.results_count | pluralize: '', 's' }} for <strong>"{{ search.terms | escape }}"</strong>
      </div>

      {%- paginate search.results by 12 -%}

        <div class="ps-search-results">
          {%- for result in search.results -%}

            {%- if result.object_type == 'article' -%}
              <!-- Blog result -->
              <div class="ps-search-result-card ps-reveal">
                {%- if result.image -%}
                  <a href="{{ result.url }}" class="ps-search-result-img-link">
                    <img src="{{ result.image | image_url: width: 200, height: 150, crop: 'center' }}"
                      alt="{{ result.title | escape }}" width="200" height="150" loading="lazy">
                  </a>
                {%- endif -%}
                <div class="ps-search-result-body">
                  <span class="ps-blog-tag" style="margin-bottom:.4rem;display:inline-block">📝 Blog</span>
                  <h3 class="ps-search-result-title"><a href="{{ result.url }}">{{ result.title | escape }}</a></h3>
                  <p class="ps-search-result-excerpt">{{ result.content | strip_html | truncate: 120 }}</p>
                  <span class="ps-blog-date">{{ result.published_at | date: "%b %d, %Y" }}</span>
                </div>
              </div>

            {%- elsif result.object_type == 'product' -%}
              <!-- Product result -->
              {%- assign first_variant = result.variants.first -%}
              <div class="ps-pc ps-reveal" style="flex-direction:row;align-items:center;padding:.8rem">
                <div class="ps-search-product-img">
                  {%- if result.featured_image -%}
                    <a href="{{ result.url }}">
                      <img src="{{ result.featured_image | image_url: width: 120, height: 120, crop: 'center' }}"
                        alt="{{ result.title | escape }}" width="120" height="120" loading="lazy">
                    </a>
                  {%- else -%}
                    <div class="ps-pc-img-fallback" style="width:90px;height:90px;font-size:2rem">🧼</div>
                  {%- endif -%}
                </div>
                <div style="flex:1;padding:.5rem 1rem">
                  <p class="ps-pc-cat" style="margin-bottom:.2rem">🛒 Product</p>
                  <h3 class="ps-pc-name" style="margin-bottom:.3rem"><a href="{{ result.url }}">{{ result.title }}</a></h3>
                  <span class="ps-pc-price">{{ result.price | money }}</span>
                </div>
                {%- if result.available -%}
                  <a href="{{ result.url }}" class="ps-atc" style="white-space:nowrap">View →</a>
                {%- endif -%}
              </div>

            {%- else -%}
              <!-- Page result -->
              <div class="ps-search-result-card ps-reveal">
                <div class="ps-search-result-body">
                  <span class="ps-blog-tag" style="margin-bottom:.4rem;display:inline-block">📄 Page</span>
                  <h3 class="ps-search-result-title"><a href="{{ result.url }}">{{ result.title | escape }}</a></h3>
                  <p class="ps-search-result-excerpt">{{ result.content | strip_html | truncate: 120 }}</p>
                </div>
              </div>
            {%- endif -%}

          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="ps-pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="ps-btn-secondary">← Previous</a>
            {%- endif -%}
            <span class="ps-page-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="ps-btn-primary">Next →</a>
            {%- endif -%}
          </div>
        {%- endif -%}

      {%- endpaginate -%}

    {%- else -%}
      <div class="ps-blog-empty">
        <div style="font-size:3rem;margin-bottom:1rem">🔍</div>
        <p>No results found for <strong>"{{ search.terms | escape }}"</strong>.</p>
        <p style="margin-top:.5rem;font-size:.9rem">Try different keywords, or browse our full product range below.</p>
        <a href="{{ shop.url }}/collections/all" class="ps-btn-primary" style="margin-top:1.2rem;display:inline-block">Browse All Products 🛒</a>
      </div>
    {%- endif -%}

  {%- else -%}
    <!-- No search yet -->
    <div class="ps-search-suggestions">
      <h3 class="ps-account-section-title">Popular Categories</h3>
      <div class="ps-cat-tabs" style="justify-content:flex-start">
        <a href="{{ shop.url }}/collections/all" class="ps-cat-tab">🧼 Soaps</a>
        <a href="{{ shop.url }}/collections/all" class="ps-cat-tab">🧴 Lotions</a>
        <a href="{{ shop.url }}/collections/all" class="ps-cat-tab">🕯️ Candles</a>
        <a href="{{ shop.url }}/collections/all" class="ps-cat-tab">🌸 Scrubs</a>
        <a href="{{ shop.url }}/blogs/news" class="ps-cat-tab">📝 Blog</a>
      </div>
    </div>
  {%- endif -%}

</div>

<script>
// Submit on type tab change
document.querySelectorAll('.ps-search-type-tab input').forEach(radio => {
  radio.addEventListener('change', () => radio.closest('form').submit());
});
window.addEventListener('scroll', () => document.getElementById('psNav').classList.toggle('scrolled', window.scrollY > 10), { passive: true });
const revObs = new IntersectionObserver(e => e.forEach(x => { if(x.isIntersecting){x.target.classList.add('visible');revObs.unobserve(x.target);}}),{threshold:.05});
document.querySelectorAll('.ps-reveal').forEach(el => revObs.observe(el));
</script>

{% schema %}
{
  "name": "Search",
  "settings": [],
  "presets": [{ "name": "Search" }]
}
{% endschema %}
