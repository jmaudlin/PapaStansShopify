{% render 'ps-account-nav' %}

<div class="ps-page-wrap">

  <!-- Account header -->
  <div class="ps-account-header">
    <div>
      <div class="ps-section-tag" style="margin-bottom:.5rem">👤 My Account</div>
      <h1 class="ps-section-h2">Hello, <em>{{ customer.first_name }}!</em></h1>
    </div>
    <a href="{{ routes.account_logout_url }}" class="ps-account-logout">Sign Out →</a>
  </div>

  <div class="ps-account-grid">

    <!-- Order History -->
    <div class="ps-account-main">
      <div class="ps-account-section-card">
        <h2 class="ps-account-section-title">📦 Order History</h2>

        {%- paginate customer.orders by 10 -%}
          {%- if customer.orders.size > 0 -%}
            <div class="ps-order-table-wrap">
              <table class="ps-order-table">
                <thead>
                  <tr>
                    <th>Order</th>
                    <th>Date</th>
                    <th>Payment</th>
                    <th>Fulfillment</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for order in customer.orders -%}
                    <tr>
                      <td data-label="Order">
                        <a href="{{ order.customer_url }}" class="ps-order-link">{{ order.name }}</a>
                      </td>
                      <td data-label="Date">{{ order.created_at | time_tag: format: 'date' }}</td>
                      <td data-label="Payment">
                        <span class="ps-order-badge ps-badge-{{ order.financial_status }}">
                          {{ order.financial_status_label }}
                        </span>
                      </td>
                      <td data-label="Fulfillment">
                        <span class="ps-order-badge ps-badge-{{ order.fulfillment_status }}">
                          {{ order.fulfillment_status_label }}
                        </span>
                      </td>
                      <td data-label="Total">{{ order.total_net_amount | money_with_currency }}</td>
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            </div>

            {%- if paginate.pages > 1 -%}
              <div class="ps-pagination" style="margin-top:1.5rem">
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="ps-btn-secondary" style="padding:.5rem 1.2rem">← Previous</a>
                {%- endif -%}
                <span class="ps-page-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="ps-btn-primary" style="padding:.5rem 1.2rem">Next →</a>
                {%- endif -%}
              </div>
            {%- endif -%}

          {%- else -%}
            <div class="ps-account-empty">
              <div style="font-size:3rem;margin-bottom:.8rem">🛒</div>
              <p>You haven't placed any orders yet.</p>
              <a href="{{ shop.url }}/collections/all" class="ps-btn-primary" style="margin-top:1rem;display:inline-block">Start Shopping 🌿</a>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>

    <!-- Sidebar: Account Details -->
    <div class="ps-account-sidebar">
      <div class="ps-account-section-card">
        <h2 class="ps-account-section-title">📋 Account Details</h2>
        <p class="ps-account-name">{{ customer.name }}</p>
        <p class="ps-account-email">{{ customer.email }}</p>

        {%- if customer.default_address -%}
          <div class="ps-account-address">
            {{ customer.default_address | format_address }}
          </div>
        {%- endif -%}

        <a href="{{ routes.account_addresses_url }}" class="ps-btn-secondary" style="display:block;text-align:center;margin-top:1rem">
          Manage Addresses
          {%- if customer.addresses_count > 0 -%}
            ({{ customer.addresses_count }})
          {%- endif -%}
        </a>
      </div>

      <div class="ps-account-section-card">
        <h2 class="ps-account-section-title">🌿 Quick Links</h2>
        <ul class="ps-account-links">
          <li><a href="{{ shop.url }}/collections/all">Shop All Products</a></li>
          <li><a href="{{ routes.account_addresses_url }}">My Addresses</a></li>
          <li><a href="{{ shop.url }}/pages/contact">Contact Us</a></li>
          <li><a href="{{ shop.url }}/pages/shipping">Shipping Info</a></li>
          <li><a href="{{ routes.account_logout_url }}">Sign Out</a></li>
        </ul>
      </div>
    </div>

  </div>
</div>

<script>
window.addEventListener('scroll', () => document.getElementById('psNav').classList.toggle('scrolled', window.scrollY > 10), { passive: true });
</script>

{% schema %}{"name":"Account","settings":[]}{% endschema %}
