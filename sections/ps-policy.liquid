{% render 'ps-search-bar' %}

<div class="ps-page-wrap">

  <!-- Policy header -->
  <div class="ps-policy-header">

    {%- assign policy_icon = '📄' -%}
    {%- assign policy_tag  = 'Policy' -%}
    {%- if policy.title contains 'Shipping' -%}
      {%- assign policy_icon = '🚚' -%}
      {%- assign policy_tag  = 'Shipping Info' -%}
    {%- elsif policy.title contains 'Refund' or policy.title contains 'Return' -%}
      {%- assign policy_icon = '↩️' -%}
      {%- assign policy_tag  = 'Returns & Refunds' -%}
    {%- elsif policy.title contains 'Privacy' -%}
      {%- assign policy_icon = '🔒' -%}
      {%- assign policy_tag  = 'Privacy Policy' -%}
    {%- elsif policy.title contains 'Terms' -%}
      {%- assign policy_icon = '📋' -%}
      {%- assign policy_tag  = 'Terms of Service' -%}
    {%- endif -%}

    <div class="ps-section-tag" style="margin-bottom:.8rem">{{ policy_icon }} {{ policy_tag }}</div>
    <h1 class="ps-section-h2">{{ policy.title }}</h1>
    <p class="ps-policy-updated">Last updated: {{ policy.updated_at | date: "%B %d, %Y" }}</p>
  </div>

  <div class="ps-policy-grid">

    <!-- Policy content -->
    <div class="ps-policy-content rte">
      {{ policy.body }}
    </div>

    <!-- Sidebar -->
    <div class="ps-policy-sidebar">

      <!-- Quick links to other policies -->
      <div class="ps-policy-sidebar-card">
        <h4 class="ps-policy-sidebar-title">📋 All Policies</h4>
        <ul class="ps-policy-links">
          <li>
            <a href="{{ shop.shipping_policy.url }}"
               {% if policy.title contains 'Shipping' %}class="ps-policy-link-active"{% endif %}>
              🚚 Shipping Info
            </a>
          </li>
          <li>
            <a href="{{ shop.refund_policy.url }}"
               {% if policy.title contains 'Refund' or policy.title contains 'Return' %}class="ps-policy-link-active"{% endif %}>
              ↩️ Returns &amp; Refunds
            </a>
          </li>
          <li>
            <a href="{{ shop.privacy_policy.url }}"
               {% if policy.title contains 'Privacy' %}class="ps-policy-link-active"{% endif %}>
              🔒 Privacy Policy
            </a>
          </li>
          <li>
            <a href="{{ shop.terms_of_service.url }}"
               {% if policy.title contains 'Terms' %}class="ps-policy-link-active"{% endif %}>
              📋 Terms of Service
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact card -->
      <div class="ps-policy-sidebar-card">
        <h4 class="ps-policy-sidebar-title">💬 Questions?</h4>
        <p class="ps-policy-sidebar-body">
          Have a question about our policies? We're happy to help!
        </p>
        <a href="{{ shop.url }}/pages/contact" class="ps-btn-primary" style="display:block;text-align:center;margin-top:1rem;">
          Contact Us
        </a>
        <div class="ps-policy-contact-row">
          <a href="tel:{{ shop.phone }}">📞 {{ shop.phone | default: '641.670.1573' }}</a>
        </div>
        <div class="ps-policy-contact-row">
          <a href="mailto:{{ shop.email }}">✉️ {{ shop.email }}</a>
        </div>
      </div>

      <!-- Back to shop -->
      <a href="{{ shop.url }}/collections/all" class="ps-btn-secondary" style="display:block;text-align:center;">
        ← Back to Shop
      </a>

    </div>
  </div>

</div>

