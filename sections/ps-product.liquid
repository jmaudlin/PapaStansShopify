{% render 'product-jsonld' %}

<div class="ps-pdp">
  <a class="ps-pdp-back" href="{{ shop.url }}/collections/all">← Back to Shop</a>

  <section class="ps-pdp-stage" id="psPdpStage">
    <div class="ps-pdp-imgcol">
      {%- if product.featured_image -%}
        <img id="psMainImg" fetchpriority="high"
          src="{{ product.featured_image | image_url: width: 900, height: 900, crop: 'center' }}"
          alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
          width="900" height="900">
      {%- else -%}
        <div class="ps-product-img-fallback">🧼</div>
      {%- endif -%}
      {%- if product.images.size > 1 -%}
        <div class="ps-pdp-thumbs" role="list">
          {%- for image in product.images -%}
            <img loading="lazy" class="ps-product-thumb {% if forloop.first %}active{% endif %}"
              src="{{ image | image_url: width: 120, height: 120, crop: 'center' }}"
              alt="{{ image.alt | escape | default: product.title | escape }}"
              width="120" height="120"
              loading="lazy"
              role="listitem"
              tabindex="0"
              data-full="{{ image | image_url: width: 900, height: 900, crop: 'center' }}"
              aria-label="View image {{ forloop.index }}">
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="ps-pdp-detailcol">
      {%- assign ps_type = product.type | strip -%}
      <span class="ps-pdp-catchip">
        {%- case ps_type -%}
          {%- when 'Body Bars' -%}🧼 Soap
          {%- when 'Body Lotion', 'Ultra-Rich Body Butter', 'Hair And Body Wash', 'Perfume Body Spray', 'Deodorant', 'Lip butter', 'Foaming Hand Soap', 'Metaphysical' -%}🧴 Body Care
          {%- when 'Candles - 8 oz', 'Seasonal Candles', 'Wax Melts', 'Potpourri' -%}🕯️ Candle
          {%- when 'Bath Bombs' -%}💣 Bath Bomb
          {%- when 'Brown Sugar Scrub' -%}🌸 Scrub
          {%- when 'Bath Accessories', 'Happily Ever After' -%}🛁 Accessories
          {%- else -%}🧼 Soap
        {%- endcase -%}
      </span>

      <h1 class="ps-pdp-title">{{ product.title }}</h1>

      <!-- Start of Judge.me code -->
      <div style='{{ jm_style }}' class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>
        {{ product.metafields.judgeme.badge }}
      </div>
      <!-- End of Judge.me code -->

      {%- form 'product', product, id: 'psProductForm' -%}
        <div class="ps-pdp-price" id="psProductPrice">
          {%- if product.compare_at_price > product.price -%}
            <span class="ps-price-compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="ps-price-current">{{ product.selected_or_first_available_variant.price | money }}</span>
        </div>

        {%- if section.settings.show_description and product.description != blank -%}
          <div class="ps-pdp-desc">{{ product.description }}</div>
        {%- endif -%}

        {%- if section.settings.show_perks -%}
        <div class="ps-pdp-perks">
          <span class="ps-pdp-perk">🌿 All Natural</span>
          <span class="ps-pdp-perk">⭐ Made in Iowa</span>
          <span class="ps-pdp-perk">🎁 Free Samples on Orders</span>
          <span class="ps-pdp-perk">🚚 Free Shipping $55+</span>
        </div>
        {%- endif -%}

        {%- if product.variants.size > 1 -%}
          <div class="ps-variant-wrap">
            <label class="ps-variant-label">Options:</label>
            <select name="id" class="ps-variant-select" id="psVariantSelect">
              {%- for variant in product.variants -%}
                <option value="{{ variant.id }}"
                  {%- unless variant.available %} disabled{%- endunless -%}
                  {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                  {{ variant.title }} — {{ variant.price | money }}
                  {%- unless variant.available %} (Sold Out){%- endunless -%}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}

        {%- assign sel = product.selected_or_first_available_variant -%}
        {%- if sel.inventory_management == 'shopify' -%}
          {%- assign qty = sel.inventory_quantity -%}
          {%- if qty > 10 -%}
            <div class="ps-stock ps-stock--ok" id="psStockBadge">✔ In Stock</div>
          {%- elsif qty > 0 -%}
            <div class="ps-stock ps-stock--low" id="psStockBadge">⚠ Only {{ qty }} left</div>
          {%- else -%}
            <div class="ps-stock ps-stock--out" id="psStockBadge">✘ Out of Stock</div>
          {%- endif -%}
        {%- endif -%}

        <script>
          window.psVariantInventory = {
            {%- for v in product.variants -%}
              "{{ v.id }}": { qty: {{ v.inventory_quantity | default: -1 }}, managed: {%- if v.inventory_management == 'shopify' -%}true{%- else -%}false{%- endif -%} }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          };
        </script>

        {%- if product.available -%}
          <div class="ps-pdp-qty-row">
            <div class="ps-qty-wrap">
              <button type="button" class="ps-qty-btn" onclick="psChangeQty(-1)">−</button>
              <input type="number" name="quantity" value="1" min="1" id="psQtyInput" class="ps-qty-input">
              <button type="button" class="ps-qty-btn" onclick="psChangeQty(1)">+</button>
            </div>
            <button type="submit" class="ps-pdp-btn" id="psAtcBtn">🛒 Add to Cart</button>
          </div>
        {%- else -%}
          <button class="ps-pdp-btn" disabled style="opacity:.5;cursor:not-allowed">Sold Out 😢</button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </section>

  {%- if section.settings.show_reviews -%}
  <section class="ps-pdp-reviews">
    <div class="ps-section-tag" style="margin-bottom:1rem">⭐ Customer Reviews</div>
    <!-- Start of Judge.me code -->{% assign has_legacy = false %}{% if product.metafields.judgeme.widget.size > 20 %}{% assign has_legacy = true %}{% endif %}<div style='clear:both'></div><div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-product-id='{{ product.id }}' data-widget='review' data-auto-install='false' data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' data-entry-point='review_widget.js' data-entry-key='review-widget/main.js'>{% if has_legacy %}<div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>{% endif %}</div>{% if product.metafields.judgeme.review_widget_data %}<script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>{% endif %}<!-- End of Judge.me code -->
  </section>
  {%- endif -%}

  {%- if section.settings.show_similar -%}
  <section class="ps-pdp-more" id="psSimilar" style="display:none">
    <h2>More on the Runway</h2>
    <div class="ps-pdp-mgrid" id="psSimilarGrid"></div>
  </section>
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when '@app' -%}
        <div class="ps-pdp-app-block" {{ block.shopify_attributes }}>
          {% render block %}
        </div>
    {%- endcase -%}
  {%- endfor -%}
</div>

<script>
// ── Gallery: event listeners + keyboard nav ──
(function() {
  const mainImg = document.getElementById('psMainImg');
  if (!mainImg) return;
  function switchThumb(thumb) {
    mainImg.src = thumb.dataset.full;
    document.querySelectorAll('.ps-product-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }
  document.querySelectorAll('.ps-product-thumb').forEach(thumb => {
    thumb.addEventListener('click', () => switchThumb(thumb));
    thumb.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); switchThumb(thumb); } });
  });
})();

// ── Qty stepper ──
function psChangeQty(delta) {
  const input = document.getElementById('psQtyInput');
  input.value = Math.max(1, parseInt(input.value) + delta);
}

// ── Stock badge ──
function psUpdateStock(variantId) {
  const badge = document.getElementById('psStockBadge');
  if (!badge || !window.psVariantInventory) return;
  const v = window.psVariantInventory[variantId];
  if (!v || !v.managed) { badge.style.display = 'none'; return; }
  badge.style.display = 'inline-block';
  if (v.qty > 10) {
    badge.className = 'ps-stock ps-stock--ok'; badge.textContent = '✔ In Stock';
  } else if (v.qty > 0) {
    badge.className = 'ps-stock ps-stock--low'; badge.textContent = '⚠ Only ' + v.qty + ' left';
  } else {
    badge.className = 'ps-stock ps-stock--out'; badge.textContent = '✘ Out of Stock';
  }
}

// ── Variant select: update URL + stock ──
document.getElementById('psVariantSelect')?.addEventListener('change', function() {
  const variantId = this.value;
  psUpdateStock(variantId);
  const url = new URL(window.location.href);
  url.searchParams.set('variant', variantId);
  window.history.replaceState({}, '', url.toString());
});

// ── Similar products ──
{% if section.settings.show_similar %}
(async function() {
  try {
    const res = await fetch('/recommendations/products.json?product_id={{ product.id }}&limit=4&intent=related');
    const { products } = await res.json();
    if (!products?.length) return;
    const grid = document.getElementById('psSimilarGrid');
    if (!grid) return;
    grid.innerHTML = products.map(p => {
      const img = p.featured_image ? `<img src="${p.featured_image}" alt="${p.title}" loading="lazy">` : `<div class="ps-product-img-fallback">🧼</div>`;
      const price = (p.price_min / 100).toLocaleString('en-US', { style:'currency', currency:'USD' });
      return `<a class="ps-pdp-mcard" href="/products/${p.handle}">
        <img src="${p.featured_image || ''}" alt="${p.title}" loading="lazy" onerror="this.style.display='none'">
        <div class="b"><div class="n">${p.title}</div><div class="p">${price}</div></div>
      </a>`;
    }).join('');
    document.getElementById('psSimilar').style.display = 'block';
  } catch(e) {}
})();
{% endif %}

// ── Add to cart ──
document.getElementById('psProductForm')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('psAtcBtn');
  const variantId = e.target.querySelector('[name="id"]')?.value || '{{ product.selected_or_first_available_variant.id }}';
  const qty = parseInt(document.getElementById('psQtyInput')?.value || 1);
  btn.textContent = 'Adding… ⏳'; btn.disabled = true;
  try {
    await fetch('/cart/add.js', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ id: variantId, quantity: qty }) });
    psShowToast('✅ Added to cart!');
    psOpenCart();
  } catch(e) { psShowToast('Something went wrong.'); }
  btn.textContent = '🛒 Add to Cart'; btn.disabled = false;
});

requestAnimationFrame(() => document.getElementById('psPdpStage')?.classList.add('in'));
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "header",
      "content": "Page sections"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "Show customer reviews",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_similar",
      "label": "Show similar products",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_perks",
      "label": "Show perks bar",
      "default": true
    }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "Product", "category": "Product" }],
  "templates": ["product"]
}
{% endschema %}
