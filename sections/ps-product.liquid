{% render 'ps-header', nav_solid: true %}

<div class="ps-page-wrap">
  <div class="ps-breadcrumb">
    <a href="{{ shop.url }}">Home</a> &rsaquo;
    <a href="{{ shop.url }}/collections/all">Shop</a> &rsaquo;
    {{ product.title }}
  </div>

  <div class="ps-product-detail">
    <!-- Images -->
    <div class="ps-product-gallery">
      <div class="ps-product-main-img">
        {%- if product.featured_image -%}
          <img id="psMainImg"
            src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            width="600" height="600">
        {%- else -%}
          <div class="ps-product-img-fallback">🧼</div>
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="ps-product-thumbs">
          {%- for image in product.images -%}
            <img class="ps-product-thumb {% if forloop.first %}active{% endif %}"
              src="{{ image | img_url: '120x120', crop: 'center' }}"
              alt="{{ image.alt | escape }}"
              onclick="document.getElementById('psMainImg').src='{{ image | img_url: '600x600', crop: 'center' }}'; document.querySelectorAll('.ps-product-thumb').forEach(t=>t.classList.remove('active')); this.classList.add('active');">
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="ps-product-info">
      <div class="ps-section-tag" style="margin-bottom:.5rem">
        {%- assign ps_type = product.type | strip -%}
        {%- case ps_type -%}
          {%- when 'Body Bars' -%}
            🧼 Soap
          {%- when 'Body Lotion', 'Ultra-Rich Body Butter', 'Hair And Body Wash', 'Perfume Body Spray', 'Deodorant', 'Lip butter', 'Foaming Hand Soap', 'Metaphysical' -%}
            🧴 Body Care
          {%- when 'Candles - 8 oz', 'Seasonal Candles', 'Wax Melts', 'Potpourri' -%}
            🕯️ Candle
          {%- when 'Bath Bombs' -%}
            💣 Bath Bomb
          {%- when 'Brown Sugar Scrub' -%}
            🌸 Scrub
          {%- when 'Bath Accessories', 'Happily Ever After' -%}
            🛁 Accessories
          {%- else -%}
            🧼 Soap
        {%- endcase -%}
      </div>
      <h1 class="ps-product-title">{{ product.title }}</h1>
      <!-- Start of Judge.me code -->
      <div style='{{ jm_style }}' class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>
        {{ product.metafields.judgeme.badge }}
      </div>
      <!-- End of Judge.me code -->

      {%- form 'product', product, id: 'psProductForm' -%}
        <!-- Variants -->
        {%- if product.variants.size > 1 -%}
          <div class="ps-variant-wrap">
            <label class="ps-variant-label">Options:</label>
            <select name="id" class="ps-variant-select" id="psVariantSelect">
              {%- for variant in product.variants -%}
                <option value="{{ variant.id }}"
                  {%- unless variant.available %} disabled{%- endunless -%}
                  {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                  {{ variant.title }} — {{ variant.price | money }}
                  {%- unless variant.available %} (Sold Out){%- endunless -%}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}

        <!-- Price -->
        <div class="ps-product-price" id="psProductPrice">
          {%- if product.compare_at_price > product.price -%}
            <span class="ps-price-compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="ps-price-current">{{ product.selected_or_first_available_variant.price | money }}</span>
        </div>

        <!-- Add to cart -->
        {%- if product.available -%}
          <div class="ps-qty-row">
            <div class="ps-qty-wrap">
              <button type="button" class="ps-qty-btn" onclick="psChangeQty(-1)">−</button>
              <input type="number" name="quantity" value="1" min="1" id="psQtyInput" class="ps-qty-input">
              <button type="button" class="ps-qty-btn" onclick="psChangeQty(1)">+</button>
            </div>
            <button type="submit" class="ps-btn-primary ps-atc-big" id="psAtcBtn">Add to Cart 🛒</button>
          </div>
        {%- else -%}
          <button class="ps-btn-primary ps-atc-big" disabled style="opacity:.5;cursor:not-allowed">Sold Out 😢</button>
        {%- endif -%}

        <div class="ps-product-perks">
          <span>🌿 All Natural</span>
          <span>⭐ Made in Iowa</span>
          <span>🎁 Free Samples on Orders</span>
          <span>🚚 Free Shipping $55+</span>
        </div>
      {%- endform -%}

      <!-- Description -->
      {%- if product.description != blank -%}
        <div class="ps-product-desc">{{ product.description }}</div>
      {%- endif -%}
    </div>
  </div>

  <!-- Judge.me Review Widget -->
  <div class="ps-reviews-wrap">
    <div class="ps-section-tag" style="margin-bottom:1rem">⭐ Customer Reviews</div>
    <!-- Start of Judge.me code -->{% assign has_legacy = false %}{% if product.metafields.judgeme.widget.size > 20 %}{% assign has_legacy = true %}{% endif %}<div style='clear:both'></div><div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-product-id='{{ product.id }}' data-widget='review' data-auto-install='false' data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' data-entry-point='review_widget.js' data-entry-key='review-widget/main.js'>{% if has_legacy %}<div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>{% endif %}</div>{% if product.metafields.judgeme.review_widget_data %}<script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>{% endif %}<!-- End of Judge.me code -->
  </div>

  <!-- Back to shop -->
  <div style="text-align:center;margin:3rem 0">
    <a href="{{ shop.url }}/collections/all" class="ps-btn-secondary">← Back to All Products</a>
  </div>
</div>

{% render 'ps-footer' %}

<script>
function psChangeQty(delta) {
  const input = document.getElementById('psQtyInput');
  input.value = Math.max(1, parseInt(input.value) + delta);
}
// Handle form submit via AJAX
document.getElementById('psProductForm')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.target;
  const btn = document.getElementById('psAtcBtn');
  const variantId = form.querySelector('[name="id"]')?.value || '{{ product.selected_or_first_available_variant.id }}';
  const qty = parseInt(document.getElementById('psQtyInput')?.value || 1);
  btn.textContent = 'Adding… ⏳';
  btn.disabled = true;
  try {
    await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty })
    });
    await 
    psShowToast('✅ Added to cart!');
    psOpenCart();
  } catch(e) { psShowToast('Something went wrong.'); }
  btn.textContent = 'Add to Cart 🛒';
  btn.disabled = false;
});
</script>

{% schema %}{ "name": "Product", "settings": [], "presets": [{ "name": "Product" }] }{% endschema %}
