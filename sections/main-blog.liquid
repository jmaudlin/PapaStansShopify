{% render 'ps-header', nav_solid: true %}

<div class="ps-page-wrap">

  <!-- Header -->
  <div class="ps-blog-header">
    <div class="ps-section-tag" style="margin-bottom:.7rem">📝 {{ blog.title }}</div>
    <h1 class="ps-section-h2">The Papa Stan's <em>Blog!</em></h1>
    <p class="ps-blog-header-sub">Tips, stories, and updates from our little corner of Oskaloosa, Iowa.</p>
  </div>

  <!-- Search bar -->
  <form action="{{ routes.search_url }}" method="get" class="ps-blog-search" role="search">
    <input type="hidden" name="type" value="article">
    <input type="search" name="q" class="ps-form-input ps-blog-search-input"
      placeholder="Search the blog…" value="{{ search.terms | escape }}"
      aria-label="Search articles">
    <button type="submit" class="ps-btn-primary ps-blog-search-btn">🔍 Search</button>
  </form>

  {%- paginate blog.articles by 9 -%}

    {%- if blog.articles.size > 0 -%}
      <div class="ps-blog-grid">
        {%- for article in blog.articles -%}
          <article class="ps-blog-card ps-reveal" style="transition-delay:{{ forloop.index0 | modulo: 3 | times: 80 }}ms">
            <a href="{{ article.url }}" class="ps-blog-card-img-link">
              {%- if article.image -%}
                <img
                  src="{{ article.image | image_url: width: 600, height: 400, crop: 'center' }}"
                  alt="{{ article.image.alt | escape | default: article.title | escape }}"
                  width="600" height="400" loading="lazy"
                  class="ps-blog-card-img">
              {%- else -%}
                <div class="ps-blog-card-img-fallback">🧼</div>
              {%- endif -%}
            </a>
            <div class="ps-blog-card-body">
              <div class="ps-blog-card-meta">
                {%- if article.tags.size > 0 -%}
                  <span class="ps-blog-tag">{{ article.tags.first }}</span>
                {%- endif -%}
                <span class="ps-blog-date">{{ article.published_at | date: "%b %d, %Y" }}</span>
              </div>
              <h2 class="ps-blog-card-title">
                <a href="{{ article.url }}">{{ article.title | escape }}</a>
              </h2>
              {%- if article.excerpt.size > 0 -%}
                <p class="ps-blog-card-excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
              {%- else -%}
                <p class="ps-blog-card-excerpt">{{ article.content | strip_html | truncate: 120 }}</p>
              {%- endif -%}
              <a href="{{ article.url }}" class="ps-blog-read-more">Read More →</a>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="ps-pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="ps-btn-secondary">← Previous</a>
          {%- endif -%}
          <span class="ps-page-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="ps-btn-primary">Next →</a>
          {%- endif -%}
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="ps-blog-empty">
        <div style="font-size:3rem;margin-bottom:1rem">📝</div>
        <p>No posts yet — check back soon for updates from the Papa Stan's family!</p>
        <a href="{{ shop.url }}/collections/all" class="ps-btn-primary" style="margin-top:1.2rem;display:inline-block">Shop Our Products 🌿</a>
      </div>
    {%- endif -%}

  {%- endpaginate -%}
</div>

{% render 'ps-footer' %}

{% schema %}
{
  "name": "Blog",
  "settings": [],
  "presets": [{ "name": "Blog" }]
}
{% endschema %}
