{% layout none %}<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:g="http://base.google.com/ns/1.0">
  <channel>
    <title>{{ shop.name | xml_escape }}</title>
    <link>{{ shop.url }}</link>
    <description>{{ shop.name | xml_escape }} — Handcrafted soaps, lotions &amp; candles from Oskaloosa, Iowa</description>
    {% paginate collections.all.products by 250 %}
    {% for product in collections.all.products %}
      {% unless product.available == false and product.variants.first.inventory_management == 'shopify' and product.variants.first.inventory_quantity <= 0 %}
      {% for variant in product.variants %}
        {% assign variant_available = variant.available %}
        <item>
          {%- comment -%} ── Core identifiers ── {%- endcomment -%}
          <g:id>{{ variant.id }}</g:id>
          <g:item_group_id>{{ product.id }}</g:item_group_id>
          <title>
            {%- if product.variants.size > 1 -%}
              {{ product.title | xml_escape }} - {{ variant.title | xml_escape }}
            {%- else -%}
              {{ product.title | xml_escape }}
            {%- endif -%}
          </title>

          {%- comment -%} ── Description: strip HTML, fallback to title ── {%- endcomment -%}
          <description>
            {%- if product.description != blank -%}
              {{ product.description | strip_html | truncatewords: 150 | xml_escape }}
            {%- else -%}
              {{ product.title | xml_escape }} — Handcrafted by Papa Stan's of Iowa, a veteran-owned small business in Oskaloosa, Iowa.
            {%- endif -%}
          </description>

          {%- comment -%} ── URL ── {%- endcomment -%}
          <link>{{ shop.url }}/products/{{ product.handle }}{% if product.variants.size > 1 %}?variant={{ variant.id }}{% endif %}</link>

          {%- comment -%} ── Images ── {%- endcomment -%}
          {%- if variant.image -%}
            <g:image_link>{{ variant.image.src | img_url: '1200x1200' | prepend: 'https:' }}</g:image_link>
          {%- elsif product.featured_image -%}
            <g:image_link>{{ product.featured_image.src | img_url: '1200x1200' | prepend: 'https:' }}</g:image_link>
          {%- endif -%}
          {%- assign extra_images = product.images -%}
          {%- for img in extra_images limit: 9 -%}
            {%- unless img == product.featured_image -%}
              <g:additional_image_link>{{ img.src | img_url: '1200x1200' | prepend: 'https:' }}</g:additional_image_link>
            {%- endunless -%}
          {%- endfor -%}

          {%- comment -%} ── Availability & condition ── {%- endcomment -%}
          <g:availability>{% if variant_available %}in_stock{% else %}out_of_stock{% endif %}</g:availability>
          <g:condition>new</g:condition>

          {%- comment -%} ── Pricing ── {%- endcomment -%}
          <g:price>{{ variant.price | money_without_currency | strip }} USD</g:price>
          {%- if variant.compare_at_price > variant.price -%}
            <g:sale_price>{{ variant.price | money_without_currency | strip }} USD</g:sale_price>
            <g:sale_price_effective_date>2000-01-01T00:00+00:00/2099-12-31T23:59+00:00</g:sale_price_effective_date>
          {%- endif -%}

          {%- comment -%} ── Brand & identifiers ── {%- endcomment -%}
          <g:brand>Papa Stan's of Iowa</g:brand>
          <g:mpn>{{ variant.sku | default: variant.id }}</g:mpn>
          <g:identifier_exists>no</g:identifier_exists>

          {%- comment -%} ── Product type & Google category ── {%- endcomment -%}
          {%- assign type_lower = product.type | downcase -%}
          {%- assign title_lower = product.title | downcase -%}
          {%- assign combined = type_lower | append: ' ' | append: title_lower -%}

          {%- if combined contains 'candle' -%}
            <g:product_type>Candles</g:product_type>
            <g:google_product_category>Home &amp; Garden &gt; Decor &gt; Candles &amp; Home Fragrance &gt; Candles</g:google_product_category>
          {%- elsif combined contains 'scrub' -%}
            <g:product_type>Scrubs</g:product_type>
            <g:google_product_category>Health &amp; Beauty &gt; Personal Care &gt; Cosmetics &gt; Bath &amp; Body &gt; Body Scrub</g:google_product_category>
          {%- elsif combined contains 'lotion' or combined contains 'butter' or combined contains 'cream' or combined contains 'moisturizer' or combined contains 'aloe' or combined contains 'almond coconut' -%}
            <g:product_type>Lotions &amp; Moisturizers</g:product_type>
            <g:google_product_category>Health &amp; Beauty &gt; Personal Care &gt; Cosmetics &gt; Skin Care &gt; Lotion &amp; Moisturizer</g:google_product_category>
          {%- else -%}
            <g:product_type>Handcrafted Soap</g:product_type>
            <g:google_product_category>Health &amp; Beauty &gt; Personal Care &gt; Cosmetics &gt; Bath &amp; Body &gt; Bar Soap</g:google_product_category>
          {%- endif -%}

          {%- comment -%} ── Variant attributes (scent/size/color) ── {%- endcomment -%}
          {%- for option in product.options_with_values -%}
            {%- assign opt_name = option.name | downcase -%}
            {%- assign opt_val  = variant.options[forloop.index0] -%}
            {%- if opt_name == 'scent' or opt_name == 'fragrance' -%}
              <g:scent>{{ opt_val | xml_escape }}</g:scent>
            {%- elsif opt_name == 'size' or opt_name == 'weight' -%}
              <g:size>{{ opt_val | xml_escape }}</g:size>
            {%- elsif opt_name == 'color' or opt_name == 'colour' -%}
              <g:color>{{ opt_val | xml_escape }}</g:color>
            {%- elsif opt_name == 'title' and opt_val != 'Default Title' -%}
              <g:size>{{ opt_val | xml_escape }}</g:size>
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} ── Shipping (Iowa → matches Shopify free shipping threshold) ── {%- endcomment -%}
          <g:shipping>
            <g:country>US</g:country>
            <g:service>Standard</g:service>
            {%- if variant.price >= 5500 -%}
              <g:price>0 USD</g:price>
            {%- else -%}
              <g:price>5.99 USD</g:price>
            {%- endif -%}
          </g:shipping>

          {%- comment -%} ── Custom labels for smart campaigns ── {%- endcomment -%}
          {%- if combined contains 'candle' -%}
            <g:custom_label_0>candle</g:custom_label_0>
          {%- elsif combined contains 'scrub' -%}
            <g:custom_label_0>scrub</g:custom_label_0>
          {%- elsif combined contains 'lotion' or combined contains 'butter' or combined contains 'cream' or combined contains 'aloe' or combined contains 'almond coconut' -%}
            <g:custom_label_0>lotion</g:custom_label_0>
          {%- else -%}
            <g:custom_label_0>soap</g:custom_label_0>
          {%- endif -%}
          <g:custom_label_1>veteran-owned</g:custom_label_1>
          <g:custom_label_2>handcrafted</g:custom_label_2>

        </item>
      {% endfor %}
      {% endunless %}
    {% endfor %}
    {% endpaginate %}
  </channel>
</rss>
