{% render 'ps-account-nav' %}

<div class="ps-page-wrap ps-account-wrap">
  <div class="ps-account-card">
    <div class="ps-section-tag" style="margin:0 auto .8rem;width:fit-content">🔐 My Account</div>
    <h1 class="ps-account-title">Welcome Back!</h1>
    <p class="ps-account-sub">Sign in to view your orders, manage addresses, and more.</p>

    <!-- Password Recovery Form -->
    <div id="RecoverPasswordForm" style="display:none">
      <h2 class="ps-account-section-h">Reset Your Password</h2>
      <p class="ps-account-sub">Enter your email and we'll send you a reset link.</p>
      {%- form 'recover_customer_password' -%}
        {%- if form.posted_successfully? -%}
          <div class="ps-form-success">✅ Check your email — a reset link is on its way!</div>
        {%- endif -%}
        {%- if form.errors -%}<div class="ps-form-error">{{ form.errors | default_errors }}</div>{%- endif -%}
        <div class="ps-form-group">
          <label class="ps-form-label" for="RecoverEmail">Email Address</label>
          <input type="email" id="RecoverEmail" name="email" class="ps-form-input" placeholder="you@example.com" autocomplete="email">
        </div>
        <button type="submit" class="ps-btn-primary" style="width:100%;text-align:center;">Send Reset Link 📧</button>
      {%- endform -%}
      <button type="button" class="ps-account-link-btn" style="width:100%;text-align:center;margin-top:.8rem" onclick="psToggleRecover(false)">← Back to Sign In</button>
    </div>

    <!-- Login Form -->
    <div id="CustomerLoginForm">
      {%- form 'customer_login', novalidate: 'novalidate' -%}
        {%- if form.errors -%}<div class="ps-form-error">{{ form.errors | default_errors }}</div>{%- endif -%}
        <div class="ps-form-group">
          <label class="ps-form-label" for="CustomerEmail">Email Address</label>
          <input type="email" id="CustomerEmail" name="customer[email]" class="ps-form-input"
            placeholder="you@example.com" autocomplete="email"
            {% if form.errors contains 'email' %}autofocus{% endif %}>
        </div>
        <div class="ps-form-group">
          <label class="ps-form-label" for="CustomerPassword">Password</label>
          <input type="password" id="CustomerPassword" name="customer[password]" class="ps-form-input"
            placeholder="••••••••" autocomplete="current-password"
            {% if form.errors contains 'password' %}autofocus{% endif %}>
        </div>
        <div style="text-align:right;margin-bottom:.8rem">
          <button type="button" class="ps-account-link-btn" onclick="psToggleRecover(true)">Forgot your password?</button>
        </div>
        <button type="submit" class="ps-btn-primary" style="width:100%;text-align:center;">Sign In 🔐</button>
      {%- endform -%}
      <div class="ps-account-divider"><span>New to Papa Stan's?</span></div>
      <a href="{{ routes.account_register_url }}" class="ps-btn-secondary" style="display:block;text-align:center;">Create an Account 🌿</a>
    </div>
  </div>
</div>

<script>
function psToggleRecover(show) {
  document.getElementById('RecoverPasswordForm').style.display = show ? 'block' : 'none';
  document.getElementById('CustomerLoginForm').style.display = show ? 'none' : 'block';
}
window.addEventListener('scroll', () => document.getElementById('psNav').classList.toggle('scrolled', window.scrollY > 10), { passive: true });
</script>

{% schema %}{"name":"Login","settings":[{"type":"checkbox","id":"enable_shop_login_button","label":"Enable Shop login","default":true}]}{% endschema %}
