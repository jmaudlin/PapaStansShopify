
{%- paginate collection.products by 24 -%}

{%- assign ch = collection.handle -%}

<div class="ps-sk-head">
  <div class="ps-sk-head-inner">
    <div class="ps-section-tag">🛒 Shop</div>
    <h1>{{ collection.title | default: 'All Products' }} <em>({{ collection.products_count }})</em></h1>
    {%- if collection.description != blank -%}
      <p class="ps-sk-head-sub">{{ collection.description }}</p>
    {%- endif -%}
  </div>
</div>

<div class="ps-page-wrap">

  {%- comment -%} ── Massage & Aromatherapy callout (Metaphysical collection only) ── {%- endcomment -%}
  {%- if ch == 'metaphysical' -%}
    <div class="ps-use-banner">
      <span class="ps-use-banner-icon">💆</span>
      <div>
        <strong>Massage &amp; Aromatherapy</strong>
        <p>Our chakra oils are handcrafted for massage, energy work, and daily aromatherapy rituals. Each bottle blends essential oils matched to a specific chakra.</p>
      </div>
    </div>
  {%- endif -%}

  <div class="ps-coll-toolbar">
    <div class="ps-cat-tabs" id="psCatTabs">
      <a href="/collections/all" class="ps-cat-tab {% if ch == 'all' %}active{% endif %}">🌟 All</a>
      {%- for col in collections -%}
        {%- unless col.handle == 'all' or col.handle == 'frontpage' or col.handle contains 'featured' or col.products_count == 0 -%}
          <a href="{{ col.url }}" class="ps-cat-tab {% if ch == col.handle %}active{% endif %}">{{ col.title }}</a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
    <script>
      /* Mobile: start the swipe row with the active collection in view */
      (function(){
        var bar=document.getElementById('psCatTabs');
        var act=bar&&bar.querySelector('.ps-cat-tab.active');
        if(bar&&act&&bar.scrollWidth>bar.clientWidth){
          bar.scrollLeft=Math.max(0,act.offsetLeft-(bar.clientWidth-act.offsetWidth)/2);
        }
      })();
    </script>
    <form method="get" class="ps-sort-form">
      <select name="sort_by" class="ps-sort-select" onchange="this.form.submit()">
        <option value="manual"             {% if collection.sort_by == 'manual'             %}selected{% endif %}>Featured</option>
        <option value="best-selling"       {% if collection.sort_by == 'best-selling'       %}selected{% endif %}>Best Selling</option>
        <option value="title-ascending"    {% if collection.sort_by == 'title-ascending'    %}selected{% endif %}>A–Z</option>
        <option value="price-ascending"    {% if collection.sort_by == 'price-ascending'    %}selected{% endif %}>Price: Low–High</option>
        <option value="price-descending"   {% if collection.sort_by == 'price-descending'   %}selected{% endif %}>Price: High–Low</option>
        <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
      </select>
    </form>
  </div>

  {%- comment -%} ── Scent-family filter bar (Candles & Scents collection only) ── {%- endcomment -%}
  {%- if ch == 'candles-and-scents' -%}
    <div class="ps-scent-bar" id="psScentBar" role="group" aria-label="Filter by scent family">
      <button class="ps-scent-btn active" data-scent="all">✨ All</button>
      <button class="ps-scent-btn" data-scent="floral">🌸 Floral</button>
      <button class="ps-scent-btn" data-scent="citrus">🍋 Citrus</button>
      <button class="ps-scent-btn" data-scent="fresh">🌿 Fresh &amp; Clean</button>
      <button class="ps-scent-btn" data-scent="warm">🍂 Warm &amp; Cozy</button>
      <button class="ps-scent-btn" data-scent="seasonal">❄️ Seasonal</button>
    </div>
  {%- endif -%}

  <div class="ps-cgrid" id="psProductGrid">
    {%- for product in collection.products -%}
      {%- assign ps_type = product.type | strip -%}

      {%- case ps_type -%}
        {%- when 'Body Bars' -%}
          {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}{%- assign ps_label = 'Body Bar' -%}
        {%- when 'Ultra-Rich Body Butter' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}{%- assign ps_label = 'Body Butter' -%}
        {%- when 'Body Lotion' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}{%- assign ps_label = 'Body Lotion' -%}
        {%- when 'Hair And Body Wash' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}{%- assign ps_label = 'Body Wash' -%}
        {%- when 'Perfume Body Spray' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}{%- assign ps_label = 'Body Spray' -%}
        {%- when 'Foaming Hand Soap' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}{%- assign ps_label = 'Hand Soap' -%}
        {%- when 'Lip butter' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}{%- assign ps_label = 'Lip Butter' -%}
        {%- when 'Deodorant' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}{%- assign ps_label = 'Deodorant' -%}
        {%- when 'Metaphysical' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '✨' -%}{%- assign ps_label = 'Chakra Oil' -%}
        {%- when 'Candles - 8 oz' -%}
          {%- assign ps_cat = 'candle' -%}{%- assign ps_emoji = '🕯️' -%}{%- assign ps_label = 'Candle 8oz' -%}
        {%- when 'Seasonal Candles' -%}
          {%- assign ps_cat = 'candle' -%}{%- assign ps_emoji = '🕯️' -%}{%- assign ps_label = 'Seasonal Candle' -%}
        {%- when 'Wax Melts' -%}
          {%- assign ps_cat = 'candle' -%}{%- assign ps_emoji = '🕯️' -%}{%- assign ps_label = 'Wax Melt' -%}
        {%- when 'Potpourri' -%}
          {%- assign ps_cat = 'candle' -%}{%- assign ps_emoji = '🌸' -%}{%- assign ps_label = 'Potpourri' -%}
        {%- when 'Bath Bombs' -%}
          {%- assign ps_cat = 'bomb' -%}{%- assign ps_emoji = '💣' -%}{%- assign ps_label = 'Bath Bomb' -%}
        {%- when 'Brown Sugar Scrub' -%}
          {%- assign ps_cat = 'scrub' -%}{%- assign ps_emoji = '🌸' -%}{%- assign ps_label = 'Sugar Scrub' -%}
        {%- when 'Bath Accessories' -%}
          {%- assign ps_cat = 'accessory' -%}{%- assign ps_emoji = '🛁' -%}{%- assign ps_label = 'Accessory' -%}
        {%- when 'Happily Ever After' -%}
          {%- assign ps_cat = 'accessory' -%}{%- assign ps_emoji = '🛁' -%}{%- assign ps_label = 'Gift' -%}
        {%- else -%}
          {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}{%- assign ps_label = ps_type | default: 'Product' -%}
      {%- endcase -%}

      {%- comment -%} Build scent-family data attribute from product tags {%- endcomment -%}
      {%- assign ps_scent = 'all' -%}
      {%- for tag in product.tags -%}
        {%- if tag == 'scent-floral' -%}{%- assign ps_scent = 'floral' -%}
        {%- elsif tag == 'scent-citrus' -%}{%- assign ps_scent = 'citrus' -%}
        {%- elsif tag == 'scent-fresh' -%}{%- assign ps_scent = 'fresh' -%}
        {%- elsif tag == 'scent-warm' -%}{%- assign ps_scent = 'warm' -%}
        {%- elsif tag == 'scent-seasonal' -%}{%- assign ps_scent = 'seasonal' -%}
        {%- endif -%}
      {%- endfor -%}

      {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}

      <div class="ps-pc" data-cat="{{ ps_cat }}" data-scent="{{ ps_scent }}">
        <div class="ps-pc-img">
          {%- if product.featured_image -%}
            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
                   alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
                   loading="lazy" width="400" height="400">
            </a>
          {%- else -%}
            <a href="{{ product.url }}"><div class="ps-pc-img-fallback">{{ ps_emoji }}</div></a>
          {%- endif -%}
          {%- unless product.available -%}
            <span class="ps-pc-badge ps-sold">Sold Out</span>
          {%- endunless -%}
          <span class="ps-type-badge">{{ ps_emoji }} {{ ps_label }}</span>
          <div class="ps-pc-overlay">
            {%- if product.available -%}
              <button class="ps-pc-quick" onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">Quick Add! 🛒</button>
            {%- else -%}
              <button class="ps-pc-quick" disabled>Out of Stock</button>
            {%- endif -%}
          </div>
        </div>
        <div class="ps-pc-body">
          <h3 class="ps-pc-name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
          <div class="ps-pc-foot">
            {%- if product.available -%}
              <span class="ps-pc-price">{{ first_variant.price | money }}</span>
              <button class="ps-atc" onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">Add to Cart</button>
            {%- else -%}
              <span class="ps-pc-price ps-sold-out">{{ product.price | money }}</span>
              <button class="ps-atc" disabled>Sold Out</button>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- else -%}
      <p style="grid-column:1/-1;text-align:center;font-family:'Caveat',cursive;font-size:1.3rem;color:var(--lav-ink);padding:3rem">No products here yet! 🌿</p>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="ps-pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="ps-btn-secondary">← Previous</a>
      {%- endif -%}
      <span class="ps-page-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="ps-btn-primary">Next →</a>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

{%- endpaginate -%}


<script>
// Preserve sort_by param when clicking category tabs
(function () {
  var sortBy = new URLSearchParams(window.location.search).get('sort_by');
  if (!sortBy) return;
  document.querySelectorAll('#psCatTabs .ps-cat-tab').forEach(function (a) {
    var url = new URL(a.href);
    url.searchParams.set('sort_by', sortBy);
    a.href = url.toString();
  });
})();

// Scent-family filter (Candles & Scents page only)
(function () {
  var bar = document.getElementById('psScentBar');
  if (!bar) return;

  bar.addEventListener('click', function (e) {
    var btn = e.target.closest('.ps-scent-btn');
    if (!btn) return;

    bar.querySelectorAll('.ps-scent-btn').forEach(function (b) { b.classList.remove('active'); });
    btn.classList.add('active');

    var scent = btn.dataset.scent;
    document.querySelectorAll('#psProductGrid .ps-pc').forEach(function (card) {
      if (scent === 'all' || card.dataset.scent === scent) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });

    // Update visible count in heading
    var visible = document.querySelectorAll('#psProductGrid .ps-pc:not([style*="none"])').length;
    var em = document.querySelector('.ps-section-h2 em');
    if (em) em.textContent = '(' + visible + ')';
  });
})();
</script>

<style>
/* ── Scent filter bar ──────────────────────────────────── */
.ps-scent-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  padding: 0.75rem 0 1.25rem;
}
.ps-scent-btn {
  background: var(--lav-light, #f3eeff);
  color: var(--lav-ink, #3b2d6e);
  clip-path: polygon(8% 0,100% 0,92% 100%,0 100%);
  border: none;
  box-shadow: inset 0 0 0 1.5px var(--lav-mid, #c9b8f0);
  padding: 0.4rem 1.1rem;
  font-size: 0.875rem;
  font-family: inherit;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
}
.ps-scent-btn:hover {
  background: var(--lav-mid, #c9b8f0);
}
.ps-scent-btn.active {
  background: var(--lav-ink, #3b2d6e);
  box-shadow: inset 0 0 0 1.5px var(--lav-ink, #3b2d6e);
  color: #fff;
}

/* ── Massage & Aromatherapy use-case banner ────────────── */
.ps-use-banner {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  background: var(--lav-light, #f3eeff);
  border-left: 4px solid var(--lav-mid, #c9b8f0);
  clip-path: polygon(0 0, 100% 0, 100% 85%, 98.5% 100%, 0 100%);
  padding: 1rem 1.25rem;
  margin-bottom: 1.5rem;
}
.ps-use-banner-icon {
  font-size: 2rem;
  line-height: 1;
}
.ps-use-banner strong {
  display: block;
  font-size: 1rem;
  color: var(--lav-ink, #3b2d6e);
  margin-bottom: 0.25rem;
}
.ps-use-banner p {
  margin: 0;
  font-size: 0.875rem;
  color: var(--lav-ink, #3b2d6e);
  opacity: 0.85;
}
</style>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "header",
      "content": "SEO"
    },
    {
      "type": "textarea",
      "id": "meta_description",
      "label": "Meta description override",
      "info": "Overrides the default collection description for search engines."
    }
  ],
  "presets": [
    {
      "name": "Collection"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "templates": [
    "collection"
  ]
}
{% endschema %}
