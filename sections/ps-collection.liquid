{% render 'ps-header', nav_solid: true %}

{%- paginate collection.products by 24 -%}

<div class="ps-page-wrap">

  <div class="ps-coll-header">
    <div class="ps-section-tag">🛒 Shop</div>
    <h1 class="ps-section-h2">{{ collection.title | default: 'All Products' }} <em>({{ collection.products_count }})</em></h1>
    {%- if collection.description != blank -%}
      <p class="ps-coll-desc">{{ collection.description }}</p>
    {%- endif -%}
  </div>

  <div class="ps-coll-toolbar">
    <div class="ps-cat-tabs" id="psCatTabs">
      <button class="ps-cat-tab active" data-cat="all">🌟 All</button>
      <button class="ps-cat-tab" data-cat="soap">🧼 Soaps</button>
      <button class="ps-cat-tab" data-cat="lotion">🧴 Lotions</button>
      <button class="ps-cat-tab" data-cat="candle">🕯️ Candles</button>
      <button class="ps-cat-tab" data-cat="scrub">🌸 Scrubs</button>
    </div>
    <form method="get" class="ps-sort-form">
      <select name="sort_by" class="ps-sort-select" onchange="this.form.submit()">
        <option value="manual"             {% if collection.sort_by == 'manual'             %}selected{% endif %}>Featured</option>
        <option value="best-selling"       {% if collection.sort_by == 'best-selling'       %}selected{% endif %}>Best Selling</option>
        <option value="title-ascending"    {% if collection.sort_by == 'title-ascending'    %}selected{% endif %}>A–Z</option>
        <option value="price-ascending"    {% if collection.sort_by == 'price-ascending'    %}selected{% endif %}>Price: Low–High</option>
        <option value="price-descending"   {% if collection.sort_by == 'price-descending'   %}selected{% endif %}>Price: High–Low</option>
        <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
      </select>
    </form>
  </div>

  <div class="ps-pgrid" id="psProductGrid">
    {%- for product in collection.products -%}
      {%- assign combined = product.type | downcase | append: ' ' | append: product.title | downcase -%}
      {%- for tag in product.tags -%}{%- assign combined = combined | append: ' ' | append: tag | downcase -%}{%- endfor -%}

      {%- if combined contains 'candle' -%}
        {%- assign ps_cat = 'candle' -%}{%- assign ps_emoji = '🕯️' -%}
      {%- elsif combined contains 'lotion' or combined contains 'butter' or combined contains 'cream' -%}
        {%- assign ps_cat = 'lotion' -%}{%- assign ps_emoji = '🧴' -%}
      {%- elsif combined contains 'scrub' -%}
        {%- assign ps_cat = 'scrub' -%}{%- assign ps_emoji = '🌸' -%}
      {%- else -%}
        {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}
      {%- endif -%}

      {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}

      <div class="ps-pc ps-reveal" data-cat="{{ ps_cat }}">
        <div class="ps-pc-img">
          {%- if product.featured_image -%}
            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
                   alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
                   loading="lazy" width="400" height="400">
            </a>
          {%- else -%}
            <a href="{{ product.url }}"><div class="ps-pc-img-fallback">{{ ps_emoji }}</div></a>
          {%- endif -%}
          {%- unless product.available -%}
            <span class="ps-pc-badge ps-sold">Sold Out</span>
          {%- endunless -%}
          <div class="ps-pc-overlay">
            {%- if product.available -%}
              <button class="ps-pc-quick" onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">Quick Add! 🛒</button>
            {%- else -%}
              <button class="ps-pc-quick" disabled>Out of Stock</button>
            {%- endif -%}
          </div>
        </div>
        <div class="ps-pc-body">
          <p class="ps-pc-cat">{{ ps_emoji }} {{ ps_cat | capitalize }}</p>
          <h3 class="ps-pc-name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
          <div class="ps-pc-foot">
            {%- if product.available -%}
              <span class="ps-pc-price">{{ first_variant.price | money }}</span>
              <button class="ps-atc" onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">Add to Cart</button>
            {%- else -%}
              <span class="ps-pc-price ps-sold-out">{{ product.price | money }}</span>
              <button class="ps-atc" disabled>Sold Out</button>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- else -%}
      <p style="grid-column:1/-1;text-align:center;font-family:'Caveat',cursive;font-size:1.3rem;color:var(--lav-ink);padding:3rem">No products here yet! 🌿</p>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="ps-pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="ps-btn-secondary">← Previous</a>
      {%- endif -%}
      <span class="ps-page-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="ps-btn-primary">Next →</a>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

{%- endpaginate -%}

{% render 'ps-footer' %}

<script>
}

document.getElementById('psCatTabs').addEventListener('click', e => {
  const tab = e.target.closest('.ps-cat-tab');
  if (!tab) return;
  document.querySelectorAll('.ps-cat-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active');
  const cat = tab.dataset.cat;
  document.querySelectorAll('.ps-pc').forEach(card => {
    card.style.display = (cat === 'all' || card.dataset.cat === cat) ? 'flex' : 'none';
  });
});

const revObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revObs.unobserve(e.target); }});
}, { threshold: 0.05 });
document.querySelectorAll('.ps-reveal').forEach(el => revObs.observe(el));
</script>

{% schema %}
{ "name": "Collection", "settings": [], "presets": [{ "name": "Collection" }] }
{% endschema %}
