{% render 'ps-account-nav' %}

<div class="ps-page-wrap ps-article-wrap">

  <!-- Breadcrumb -->
  <div class="ps-breadcrumb">
    <a href="{{ shop.url }}">Home</a> ›
    <a href="{{ blog.url }}">{{ blog.title }}</a> ›
    {{ article.title | truncate: 40 }}
  </div>

  <div class="ps-article-grid">

    <!-- Article content -->
    <article class="ps-article-main">

      {%- if article.image -%}
        <div class="ps-article-hero">
          <img
            src="{{ article.image | image_url: width: 1200, height: 500, crop: 'center' }}"
            alt="{{ article.image.alt | escape | default: article.title | escape }}"
            width="1200" height="500" loading="eager"
            class="ps-article-hero-img">
        </div>
      {%- endif -%}

      <div class="ps-article-header">
        {%- if article.tags.size > 0 -%}
          <div class="ps-article-tags">
            {%- for tag in article.tags -%}
              <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="ps-blog-tag">{{ tag }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <h1 class="ps-article-title">{{ article.title | escape }}</h1>
        <div class="ps-article-meta">
          <span>📅 {{ article.published_at | date: "%B %d, %Y" }}</span>
          {%- if article.author -%}
            <span>✍️ {{ article.author }}</span>
          {%- endif -%}
          {%- if article.comments_count > 0 -%}
            <span>💬 {{ article.comments_count }} comments</span>
          {%- endif -%}
        </div>
      </div>

      <div class="ps-article-content rte">
        {{ article.content }}
      </div>

      <!-- Prev / Next -->
      <nav class="ps-article-nav">
        {%- if blog.previous_article -%}
          <a href="{{ blog.previous_article.url }}" class="ps-article-nav-link ps-article-nav-prev">
            <span class="ps-article-nav-label">← Previous</span>
            <span class="ps-article-nav-title">{{ blog.previous_article.title | truncate: 50 }}</span>
          </a>
        {%- else -%}
          <span></span>
        {%- endif -%}
        {%- if blog.next_article -%}
          <a href="{{ blog.next_article.url }}" class="ps-article-nav-link ps-article-nav-next">
            <span class="ps-article-nav-label">Next →</span>
            <span class="ps-article-nav-title">{{ blog.next_article.title | truncate: 50 }}</span>
          </a>
        {%- endif -%}
      </nav>

    </article>

    <!-- Sidebar -->
    <aside class="ps-article-sidebar">

      <!-- Back to blog -->
      <a href="{{ blog.url }}" class="ps-btn-secondary" style="display:block;text-align:center;margin-bottom:1.2rem">← All Posts</a>

      <!-- Recent posts -->
      {%- if blog.articles.size > 1 -%}
        <div class="ps-policy-sidebar-card">
          <h4 class="ps-policy-sidebar-title">📝 Recent Posts</h4>
          <ul class="ps-account-links">
            {%- for a in blog.articles limit: 5 -%}
              {%- unless a.handle == article.handle -%}
                <li>
                  <a href="{{ a.url }}">
                    <span style="font-size:.75rem;color:var(--lav-ink);display:block">{{ a.published_at | date: "%b %d, %Y" }}</span>
                    {{ a.title | truncate: 45 }}
                  </a>
                </li>
              {%- endunless -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <!-- Share -->
      <div class="ps-policy-sidebar-card">
        <h4 class="ps-policy-sidebar-title">📣 Share This Post</h4>
        <div class="ps-article-share">
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ request.origin | append: article.url | url_encode }}"
            target="_blank" class="ps-contact-social-btn">
            <strong>f</strong> Facebook
          </a>
          <a href="https://twitter.com/intent/tweet?text={{ article.title | url_encode }}&url={{ request.origin | append: article.url | url_encode }}"
            target="_blank" class="ps-contact-social-btn">
            <strong>𝕏</strong> Twitter
          </a>
        </div>
      </div>

      <!-- Shop CTA -->
      <div class="ps-policy-sidebar-card" style="background:var(--lav);border-color:var(--lav-dark);text-align:center">
        <div style="font-size:2rem;margin-bottom:.5rem">🌿</div>
        <h4 style="font-family:'Luckiest Guy',cursive;color:#fff;letter-spacing:.04em;margin-bottom:.5rem">Shop Our Products</h4>
        <p style="font-size:.82rem;font-weight:600;color:rgba(255,255,255,.85);margin-bottom:1rem">190+ handcrafted soaps, lotions &amp; candles!</p>
        <a href="{{ shop.url }}/collections/all" class="ps-btn-secondary" style="display:block;text-align:center">Shop Now 🛒</a>
      </div>

    </aside>

  </div>
</div>

<script>
window.addEventListener('scroll', () => document.getElementById('psNav').classList.toggle('scrolled', window.scrollY > 10), { passive: true });
</script>

{% schema %}
{
  "name": "Article",
  "settings": [],
  "blocks": [
    { "type": "featured_image", "name": "Featured Image", "settings": [] },
    { "type": "title", "name": "Title", "settings": [] },
    { "type": "content", "name": "Content", "settings": [] },
    { "type": "share", "name": "Share", "settings": [] }
  ],
  "presets": [{ "name": "Article" }]
}
{% endschema %}
