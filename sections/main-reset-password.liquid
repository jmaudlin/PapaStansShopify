{% render 'ps-account-nav' %}

<div class="ps-page-wrap ps-account-wrap">
  <div class="ps-account-card">
    <div class="ps-section-tag" style="margin:0 auto .8rem;width:fit-content">🔑 Reset Password</div>
    <h1 class="ps-account-title">Choose a New Password</h1>
    <p class="ps-account-sub">Enter a new password for your Papa Stan's account.</p>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}<div class="ps-form-error">{{ form.errors | default_errors }}</div>{%- endif -%}

      <div class="ps-form-group">
        <label class="ps-form-label" for="ResetPassword">New Password <span class="ps-required">*</span></label>
        <input type="password" id="ResetPassword" name="customer[password]" class="ps-form-input"
          placeholder="Min. 6 characters" autocomplete="new-password" required
          {% if form.errors contains 'password' %}autofocus{% endif %}>
      </div>
      <div class="ps-form-group">
        <label class="ps-form-label" for="ResetPasswordConfirm">Confirm Password <span class="ps-required">*</span></label>
        <input type="password" id="ResetPasswordConfirm" name="customer[password_confirmation]" class="ps-form-input"
          placeholder="Re-enter your password" autocomplete="new-password" required>
      </div>
      <button type="submit" class="ps-btn-primary" style="width:100%;text-align:center;">Reset Password 🔐</button>
    {%- endform -%}
  </div>
</div>

<script>
window.addEventListener('scroll', () => document.getElementById('psNav').classList.toggle('scrolled', window.scrollY > 10), { passive: true });
</script>

{% schema %}{"name":"Reset Password","settings":[]}{% endschema %}
