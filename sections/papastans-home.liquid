{% render 'ps-header' %}

<!-- HERO -->
<section class="ps-hero">
  <div class="ps-hero-bg" id="psHeroBg"></div>
  <div class="ps-hero-pattern"></div>
  <div class="ps-bubble ps-bubble-1"></div>
  <div class="ps-bubble ps-bubble-2"></div>
  <div class="ps-bubble ps-bubble-3"></div>
  <div class="ps-bubble ps-bubble-4"></div>
  <div class="ps-bubble ps-bubble-5"></div>
  <div class="ps-bubble ps-bubble-6"></div>
  <div class="ps-bubble ps-bubble-7"></div>
  <div class="ps-hero-art" id="psHeroArt">🪣</div>
  <div class="ps-hero-content">
    <div class="ps-hero-eyebrow">🌿 Handcrafted · Small Batch · All Natural</div>
    <h1 class="ps-hero-h1"><span>Soaps, Lotions</span><br>&amp; Candles!</h1>
    <p class="ps-hero-sub">Made with love right here in<br>Oskaloosa, Iowa since 2019</p>
    <div class="ps-hero-btns">
      <a href="#ps-products" class="ps-btn-primary">Shop Now 🛒</a>
      <a href="{{ shop.url }}/pages/our-story" class="ps-btn-secondary">Our Story 🏡</a>
    </div>
  </div>

  <div class="ps-hero-phone">
    <span>📞</span>
    <a href="tel:6416701573">641.670.1573</a>
  </div>
</section>

<!-- MARQUEE -->
<div class="ps-marquee">
  <div class="ps-marquee-inner">
    {%- assign marquee_items = "🧼 Soaps,🧴 Lotions,🕯️ Candles,🧖 Face Scrubs,🌿 All Natural,🎖️ Veteran Owned,📍 Oskaloosa Iowa,⭐ 190+ Products,🎁 Free Samples" | split: "," -%}
    {%- for item in marquee_items -%}<span class="ps-m-item">{{ item }}<span class="ps-m-sep">✦</span></span>{%- endfor -%}
    {%- for item in marquee_items -%}<span class="ps-m-item">{{ item }}<span class="ps-m-sep">✦</span></span>{%- endfor -%}
  </div>
</div>


<!-- PRODUCTS — rendered server-side via Liquid -->
<section class="ps-products" id="ps-products">
  <div class="ps-products-top">
    <div>
      <div class="ps-section-tag ps-reveal">🛒 Shop Now</div>
      <h2 class="ps-section-h2 ps-reveal ps-rd1">Pick Your <em>Favorites!</em></h2>
    </div>
    <a href="{{ shop.url }}/collections/all" class="ps-view-all ps-reveal">See All {{ collections.all.products_count }} Products →</a>
    <a href="{{ shop.url }}/collections/all" class="ps-mobile-view-all ps-btn-primary">
      See All {{ collections.all.products_count }} Products 🛒
    </a>
  </div>

  <!-- Category filter tabs -->
  <div class="ps-cat-tabs ps-reveal" id="psCatTabs">
    <button class="ps-cat-tab active" data-cat="all">🌟 All</button>
    <button class="ps-cat-tab" data-cat="soap">🧼 Soaps</button>
    <button class="ps-cat-tab" data-cat="bodycare">🧴 Body Care</button>
    <button class="ps-cat-tab" data-cat="candle">🕯️ Candles</button>
    <button class="ps-cat-tab" data-cat="bomb">💣 Bath Bombs</button>
    <button class="ps-cat-tab" data-cat="scrub">🌸 Scrubs</button>
    <button class="ps-cat-tab" data-cat="accessory">🛁 Accessories</button>
  </div>

  <div class="ps-pgrid-wrap">
    <button class="ps-pgrid-arrow ps-pgrid-prev" id="psPrev" aria-label="Previous products">&#8592;</button>
    <div class="ps-pgrid" id="psProductGrid">
    {%- assign featured = collections['featured-products'] -%}
    {%- assign source = featured.products | default: collections.all.products -%}
    {%- for product in source limit: 24 -%}
      {%- assign ps_type = product.type | strip -%}

      {%- case ps_type -%}
        {%- when 'Body Bars' -%}
          {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}
        {%- when 'Body Lotion', 'Ultra-Rich Body Butter', 'Hair And Body Wash', 'Perfume Body Spray', 'Deodorant', 'Lip butter', 'Foaming Hand Soap', 'Metaphysical' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}
        {%- when 'Candles - 8 oz', 'Seasonal Candles', 'Wax Melts', 'Potpourri' -%}
          {%- assign ps_cat = 'candle' -%}{%- assign ps_emoji = '🕯️' -%}
        {%- when 'Bath Bombs' -%}
          {%- assign ps_cat = 'bomb' -%}{%- assign ps_emoji = '💣' -%}
        {%- when 'Brown Sugar Scrub' -%}
          {%- assign ps_cat = 'scrub' -%}{%- assign ps_emoji = '🌸' -%}
        {%- when 'Bath Accessories', 'Happily Ever After' -%}
          {%- assign ps_cat = 'accessory' -%}{%- assign ps_emoji = '🛁' -%}
        {%- else -%}
          {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}
      {%- endcase -%}

      {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
      {%- assign is_available = product.available -%}

      <div class="ps-pc" data-cat="{{ ps_cat }}">
        <div class="ps-pc-img">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
              alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
              loading="lazy"
              width="400" height="400"
            >
          {%- else -%}
            <div class="ps-pc-img-fallback">{{ ps_emoji }}</div>
          {%- endif -%}

          {%- unless is_available -%}
            <span class="ps-pc-badge ps-sold">Sold Out</span>
          {%- endunless -%}

          <div class="ps-pc-overlay">
            {%- if is_available -%}
              <button class="ps-pc-quick"
                data-variant-id="{{ first_variant.id }}"
                data-product-title="{{ product.title | escape }}"
                onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">
                Quick Add! 🛒
              </button>
            {%- else -%}
              <button class="ps-pc-quick" disabled>Out of Stock</button>
            {%- endif -%}
          </div>
        </div>

        <div class="ps-pc-body">
          <p class="ps-pc-cat">{{ ps_emoji }} {{ ps_type | default: 'Body Bar' }}</p>
          <h3 class="ps-pc-name">
            <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">{{ product.title }}</a>
          </h3>
          <div class="ps-pc-foot">
            {%- if is_available -%}
              <span class="ps-pc-price">{{ first_variant.price | money }}</span>
              <button class="ps-atc"
                data-variant-id="{{ first_variant.id }}"
                data-product-title="{{ product.title | escape }}"
                onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">
                Add to Cart
              </button>
            {%- else -%}
              <span class="ps-pc-price ps-sold-out">{{ product.price | money }}</span>
              <button class="ps-atc" disabled>Sold Out</button>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div><!-- /ps-pgrid -->
    <button class="ps-pgrid-arrow ps-pgrid-next" id="psNext" aria-label="Next products">&#8594;</button>
  </div><!-- /ps-pgrid-wrap -->

  <div class="ps-load-more-wrap">
    <a href="{{ shop.url }}/collections/all" class="ps-btn-primary">See All Products 👉</a>
  </div>
</section>

<script>
// ── Parallax ──
const psHeroBgEl   = document.getElementById('psHeroBg');
const psHeroArtEl  = document.getElementById('psHeroArt');

function psRatio(el) {
  const r = el.getBoundingClientRect();
  return (window.innerHeight - r.top) / (window.innerHeight + r.height);
}
function psSetNavTop() {
  const rainbow  = document.querySelector('.ps-rainbow-bar');
  const announce = document.querySelector('.ps-announce');
  const h = (rainbow  ? rainbow.offsetHeight  : 8)
          + (announce ? announce.offsetHeight : 36);
  document.documentElement.style.setProperty('--nav-top', h + 'px');
}
function psOnScroll() {
  const sy = window.scrollY;
  if (psHeroBgEl)   psHeroBgEl.style.transform  = `translateY(${sy * 0.45}px)`;
  if (psHeroArtEl)  psHeroArtEl.style.transform  = `translateY(${sy * 0.25}px) scaleX(-1)`;
  document.getElementById('psNav').classList.toggle('scrolled', sy > 50);
}
window.addEventListener('scroll', psOnScroll, { passive: true });
window.addEventListener('resize', psSetNavTop, { passive: true });
psSetNavTop();
psOnScroll();

// ── Reveal on scroll ──
const psRevObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); psRevObs.unobserve(e.target); }
  });
}, { threshold: 0.08 });
document.querySelectorAll('.ps-reveal').forEach(el => psRevObs.observe(el));

// ── Category filter tabs ──
document.getElementById('psCatTabs').addEventListener('click', e => {
  const tab = e.target.closest('.ps-cat-tab');
  if (!tab) return;
  document.querySelectorAll('.ps-cat-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active');
  const cat = tab.dataset.cat;
  document.querySelectorAll('.ps-pc').forEach(card => {
    card.style.display = (cat === 'all' || card.dataset.cat === cat) ? 'flex' : 'none';
  });
});

// ── Smooth anchor scrolling ──
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const el = document.querySelector(a.getAttribute('href'));
    if (el) { e.preventDefault(); el.scrollIntoView({ behavior: 'smooth' }); }
  });
});
// ── Product slider (large screens only) ──
(function() {
  var grid = document.getElementById('psProductGrid');
  var prev = document.getElementById('psPrev');
  var next = document.getElementById('psNext');
  if (!grid || !prev || !next) return;

  function scrollBy(dir) {
    var card = grid.querySelector('.ps-pc');
    if (!card) return;
    var step = (card.offsetWidth + parseInt(getComputedStyle(grid).gap || 24)) * 2;
    grid.scrollBy({ left: dir * step, behavior: 'smooth' });
  }

  function updateArrows() {
    var atStart = grid.scrollLeft <= 4;
    var atEnd = grid.scrollLeft >= grid.scrollWidth - grid.offsetWidth - 4;
    prev.style.opacity = atStart ? '0.3' : '1';
    prev.style.pointerEvents = atStart ? 'none' : 'auto';
    next.style.opacity = atEnd ? '0.3' : '1';
    next.style.pointerEvents = atEnd ? 'none' : 'auto';
  }

  prev.addEventListener('click', function() { scrollBy(-1); });
  next.addEventListener('click', function() { scrollBy(1); });
  grid.addEventListener('scroll', updateArrows, { passive: true });
  updateArrows();
})();



{% schema %}
{
  "name": "Papa Stan's Home",
  "settings": [],
  "presets": [{ "name": "Papa Stan's Home" }]
}
{% endschema %}
