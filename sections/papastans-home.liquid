<!-- MARQUEE -->
<script>
(function(){
const cv=document.getElementById('psMascotCanvas');
if(!cv)return;
const ctx=cv.getContext('2d');
let W,H,dpr;

function resize(){
  dpr=window.devicePixelRatio||1;
  W=cv.offsetWidth; H=cv.offsetHeight;
  cv.width=W*dpr; cv.height=H*dpr;
  ctx.scale(dpr,dpr);
}
resize();
window.addEventListener('resize',()=>{ resize(); if(phase>=4) skipTo(); });

const lerp=(a,b,t)=>a+(b-a)*Math.max(0,Math.min(1,t));
const easeOut=(t)=>1-(1-t)**3;
const rnd=(a,b)=>a+(b-a)*Math.random();
const PURPLE={r:188,g:105,b:235};

let phase=0,pT=0,bobT=0,faceFill=0,mascotY=0;
let hicS=0,hicT=0,hicMouth='smile',hicBlush=1,hicEye='normal';
let burps=[],all=[],last=0,rafId;
let scrollV=0,lastScrollY=0,scrollIdle=0,scrollTriggered=false,scrollSpinAngle=0,scrollSpinV=0;

const MCX=()=>W*.76;
const MCY=()=>H*.52;

const SLOTS=[
  {key:'body',dx:0,   dy:0,  r:50,depth:.5},
  {key:'armL',dx:-56, dy:-5, r:9, depth:.48},
  {key:'armR',dx:57,  dy:-5, r:9, depth:.52},
  {key:'legL',dx:-19, dy:57, r:9, depth:.49},
  {key:'legR',dx:20,  dy:57, r:9, depth:.51},
];

class B{
  constructor(x,y,r,slot,depth){
    this.x=x;this.y=y;this.r=r;
    this.vx=rnd(-.85,.85);this.vy=rnd(-.85,.85);
    this.slot=slot;this.depth=depth||rnd(.1,.9);
    this.fill=0;this.attached=false;this.attachT=0;
    this.wobble=0;
    this.op=slot?rnd(.6,.85):rnd(.2,.5);
    this.drift={ax:rnd(-.003,.003),ay:rnd(-.003,.003)};
  }
  get tx(){return this.slot?MCX()+this.slot.dx:null}
  get ty(){return this.slot?MCY()+this.slot.dy+mascotY:null}
}

function mkBubbles(){
  all=[];
  SLOTS.forEach(s=>{
    all.push(new B(rnd(W*.42,W*.96),rnd(H*.08,H*.92),s.r,s,s.depth));
  });
  [38,28,22,18,32,16,24,14,20,30,12,26,16,22,18,10,34].forEach(r=>{
    all.push(new B(rnd(r,W-r),rnd(r,H-r),r,null,rnd(.05,.95)));
  });
}

function collide(){
  for(let i=0;i<all.length;i++) for(let j=i+1;j<all.length;j++){
    const a=all[i],b=all[j];
    const dx=b.x-a.x,dy=b.y-a.y,d=Math.sqrt(dx*dx+dy*dy),mn=a.r+b.r+2;
    if(d<mn&&d>.01){
      const nx=dx/d,ny=dy/d,ov=(mn-d)*.5;
      if(!a.attached){a.x-=nx*ov;a.y-=ny*ov;}
      if(!b.attached){b.x+=nx*ov;b.y+=ny*ov;}
      const rv=(a.vx-b.vx)*nx+(a.vy-b.vy)*ny;
      if(rv>0){
        const imp=rv*.72;
        if(!a.attached){a.vx-=imp*nx;a.vy-=imp*ny;}
        if(!b.attached){b.vx+=imp*nx;b.vy+=imp*ny;}
        a.wobble+=(Math.random()-.5)*.28;b.wobble+=(Math.random()-.5)*.28;
      }
    }
  }
}

function wall(b){
  if(b.attached)return;
  if(b.x<b.r){b.x=b.r;b.vx=Math.abs(b.vx)*.6;}
  if(b.x>W-b.r){b.x=W-b.r;b.vx=-Math.abs(b.vx)*.6;}
  if(b.y<b.r){b.y=b.r;b.vy=Math.abs(b.vy)*.6;}
  if(b.y>H-b.r){b.y=H-b.r;b.vy=-Math.abs(b.vy)*.6;}
}

function freeDrift(b,spd){
  b.vx+=b.drift.ax*spd;b.vy+=b.drift.ay*spd;b.vx*=.997;b.vy*=.997;
  b.x+=b.vx*spd;b.y+=b.vy*spd;wall(b);
}

function update(dt){
  pT+=dt;
  if(phase===0){
    all.forEach(b=>freeDrift(b,1));
    collide();
    if(pT>2.4){phase=1;pT=0;}
  }
  else if(phase===1){
    const prog=Math.min(pT/5.5,1);
    all.forEach(b=>{
      if(b.slot){
        const dx=b.tx-b.x,dy=b.ty-b.y,d=Math.sqrt(dx*dx+dy*dy);
        const zone=b.r*3.8,pull=.003+prog*.02;
        if(d<zone){
          b.vx+=dx*(pull*(1+(zone-d)/zone*1.8));
          b.vy+=dy*(pull*(1+(zone-d)/zone*1.8));
          if(d<b.r*1.4&&!b.attached){
            b.vx*=.72;b.vy*=.72;b.attachT+=dt;
            if(b.attachT>.38){b.attached=true;}
          }
        } else {
          b.vx+=dx*.001+b.drift.ax;b.vy+=dy*.001+b.drift.ay;
        }
        if(!b.attached){b.vx*=.97;b.vy*=.97;b.x+=b.vx;b.y+=b.vy;wall(b);}
        else{b.x=lerp(b.x,b.tx,.16);b.y=lerp(b.y,b.ty,.16);}
      } else {freeDrift(b,1);}
      b.wobble*=.87;
    });
    collide();
    const allIn=all.filter(b=>b.slot).every(b=>b.attached);
    if(allIn&&pT>3.2){phase=2;pT=0;}
  }
  else if(phase===2){
    const t=Math.min(pT/1.8,1);
    all.forEach(b=>{
      if(b.slot){b.fill=easeOut(t);b.x=lerp(b.x,b.tx,.2);b.y=lerp(b.y,b.ty,.2);}
      else freeDrift(b,1);
    });
    if(t>=1){phase=3;pT=0;}
  }
  else if(phase===3){
    faceFill=Math.min(pT/.9,1);
    mascotY=-Math.sin(Math.min(pT/.95,1)*Math.PI)*10;
    all.forEach(b=>{if(b.slot){b.x=lerp(b.x,b.tx,.25);b.y=lerp(b.y,b.ty,.25);b.fill=1;}});
    if(pT>.9){phase=4;pT=0;scheduleHic();}
  }
  else if(phase===4){
    bobT+=dt*1.05;
    mascotY=Math.sin(bobT)*7;
    scrollIdle+=dt;
    if(scrollIdle>1.8)scrollTriggered=false;
    scrollSpinV*=.88; scrollSpinAngle+=scrollSpinV;
    all.forEach(b=>{
      if(b.slot){
        b.x=lerp(b.x,b.tx+Math.sin(bobT*(b.depth+.3))*(b.r*.1),.2);
        b.y=lerp(b.y,b.ty,.2);
        b.wobble=b.slot.key==='body'
          ? Math.sin(bobT)*.025+scrollSpinAngle
          : Math.sin(bobT*(b.slot.key==='armL'?.9:1.1))*.04+scrollSpinAngle;
        b.fill=1;
      } else {
        const spd=lerp(1.6,.5,b.depth);
        freeDrift(b,spd);
        b.wobble*=.9;
      }
    });
    if(hicS>0)tickHic(dt);
    burps.forEach(b=>{b.y-=1.7+b.s*.5;b.r+=.28;b.a-=.014;});
    burps=burps.filter(b=>b.a>0);
    faceFill=1;
  }
}

function drawBub(b){
  const f=b.fill;
  const alpha=b.op*(b.slot&&phase>=2?(1-f*.6):1);
  if(alpha<.02)return;
  ctx.save();ctx.globalAlpha=alpha;
  ctx.translate(b.x,b.y);if(b.wobble)ctx.rotate(b.wobble);
  ctx.beginPath();ctx.arc(0,0,b.r,0,Math.PI*2);
  if(f>0&&b.slot){
    const ri=lerp(255,PURPLE.r,f),gi=lerp(255,PURPLE.g,f),bi=lerp(255,PURPLE.b,f);
    ctx.fillStyle=`rgba(${Math.round(ri)},${Math.round(gi)},${Math.round(bi)},${lerp(.07,.88,f)})`;
  } else {
    ctx.fillStyle=`rgba(255,255,255,${lerp(.04,.12,b.depth)})`;
  }
  ctx.fill();
  ctx.strokeStyle=`rgba(255,255,255,${f>0?lerp(.18,.36,f):lerp(.1,.24,b.depth)})`;
  ctx.lineWidth=1.8;ctx.stroke();
  if(f>.2&&b.slot){
    ctx.beginPath();ctx.ellipse(-b.r*.28,-b.r*.28,b.r*.3,b.r*.19,-.35,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,255,255,${f*.42})`;ctx.fill();
  }
  if(f<.1&&b.r>12){
    ctx.beginPath();ctx.ellipse(-b.r*.3,-b.r*.3,b.r*.26,b.r*.15,-.3,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,255,255,${b.op*.32})`;ctx.fill();
  }
  ctx.restore();
}

function drawFace(cx,cy){
  if(faceFill<=0)return;
  ctx.save();ctx.globalAlpha=faceFill;
  const ey=cy-7;
  const ew=hicEye==='wide'?12:10,eh=hicEye==='wide'?14:11.5;
  [cx-16,cx+16].forEach(ex=>{
    ctx.beginPath();ctx.ellipse(ex,ey,ew,eh,0,0,Math.PI*2);ctx.fillStyle='white';ctx.fill();
    ctx.beginPath();ctx.arc(ex+1.5,ey+1,6,0,Math.PI*2);ctx.fillStyle='#1e0838';ctx.fill();
    ctx.beginPath();ctx.arc(ex+3,ey-.5,2.2,0,Math.PI*2);ctx.fillStyle='white';ctx.fill();
    ctx.beginPath();ctx.arc(ex-1,ey+3.5,1.2,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,.5)';ctx.fill();
  });
  const br=hicBlush>1?13:9.5;
  ctx.beginPath();ctx.ellipse(cx-22,cy+9,br,6.5,0,0,Math.PI*2);ctx.fillStyle='rgba(255,130,165,.5)';ctx.fill();
  ctx.beginPath();ctx.ellipse(cx+22,cy+9,br,6.5,0,0,Math.PI*2);ctx.fillStyle='rgba(255,130,165,.5)';ctx.fill();
  ctx.beginPath();
  if(hicMouth==='smile'){ctx.moveTo(cx-13,cy+14);ctx.quadraticCurveTo(cx,cy+25,cx+13,cy+14);}
  else if(hicMouth==='open'){ctx.moveTo(cx-13,cy+12);ctx.quadraticCurveTo(cx,cy+28,cx+13,cy+12);}
  else if(hicMouth==='wide'){ctx.moveTo(cx-15,cy+11);ctx.quadraticCurveTo(cx,cy+30,cx+15,cy+11);}
  else{ctx.moveTo(cx-11,cy+20);ctx.quadraticCurveTo(cx,cy+13,cx+11,cy+20);}
  ctx.strokeStyle='#1e0838';ctx.lineWidth=2.8;ctx.lineCap='round';ctx.stroke();
  ctx.beginPath();ctx.arc(cx-26,cy-14,3.5,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,.22)';ctx.fill();
  ctx.restore();
}

function tickHic(dt){
  hicT+=dt;
  if(hicS===1){mascotY=-15;if(hicT>.22){hicS=2;hicT=0;hicMouth='open';hicEye='wide';}}
  else if(hicS===2){
    mascotY=20+Math.sin(hicT*7)*5;
    if(hicT>.78){
      hicS=3;hicT=0;hicMouth='wide';
      const body=all.find(b=>b.slot?.key==='body');
      if(body){for(let i=0;i<4;i++)burps.push({x:body.x+rnd(-10,10),y:body.y-body.r-5,r:rnd(5,13),a:1,s:Math.random()});}
    }
  }
  else if(hicS===3){mascotY=lerp(20,0,hicT/.5);if(hicT>.5){hicS=4;hicT=0;hicMouth='embarrassed';hicBlush=2;}}
  else if(hicS===4){if(hicT>1.5){hicS=0;hicT=0;hicMouth='smile';hicBlush=1;hicEye='normal';scheduleHic();}}
}

function scheduleHic(){
  setTimeout(()=>{if(phase===4&&hicS===0){hicS=1;hicT=0;hicMouth='line';hicEye='wide';}},rnd(18000,30000));
}

function skipTo(){
  phase=4;pT=0;faceFill=1;bobT=0;mascotY=0;hicS=0;hicT=0;hicMouth='smile';hicBlush=1;hicEye='normal';burps=[];
  all.forEach(b=>{if(b.slot){b.fill=1;b.attached=true;b.x=b.tx;b.y=b.ty;b.vx=0;b.vy=0;}});
  scheduleHic();
}

const scrollEl=document.body;
let scrollSpinAngle=0, scrollSpinV=0;
scrollEl.addEventListener('scroll',()=>{
  const sy=scrollEl.scrollTop;
  scrollV=sy-lastScrollY; lastScrollY=sy; scrollIdle=0;
  if(phase===4&&hicS===0){
    scrollSpinV+=(scrollV>0?.18:-.18)*Math.min(Math.abs(scrollV)*.04,1.2);
    scrollTriggered=true;
  }
},{passive:true});

function render(){
  ctx.clearRect(0,0,W,H);
  const bg=all.filter(b=>!b.slot&&b.depth<.5).sort((a,b2)=>b2.depth-a.depth);
  const fg=all.filter(b=>!b.slot&&b.depth>=.5).sort((a,b2)=>a.depth-b2.depth);
  const slotBubs=all.filter(b=>b.slot).sort((a,b2)=>a.depth-b2.depth);
  bg.forEach(b=>drawBub(b));
  slotBubs.forEach(b=>drawBub(b));
  const body=all.find(b=>b.slot?.key==='body');
  if(body)drawFace(body.x,body.y);
  burps.forEach(b=>{
    ctx.save();ctx.globalAlpha=b.a;
    ctx.beginPath();ctx.arc(b.x,b.y,b.r,0,Math.PI*2);
    ctx.fillStyle='rgba(190,150,255,.1)';ctx.fill();
    ctx.strokeStyle='rgba(200,165,255,.65)';ctx.lineWidth=1.6;ctx.stroke();
    ctx.beginPath();ctx.ellipse(b.x-b.r*.28,b.y-b.r*.28,b.r*.3,b.r*.18,0,0,Math.PI*2);
    ctx.fillStyle='rgba(255,255,255,.38)';ctx.fill();
    ctx.restore();
  });
  fg.forEach(b=>drawBub(b));
}

function tick(now){
  const dt=Math.min((now-last)/1000,.05);last=now;
  update(dt);render();
  rafId=requestAnimationFrame(tick);
}

mkBubbles();
last=performance.now();
requestAnimationFrame(tick);
})();
</script>

<!-- MARQUEE -->
<div class="ps-marquee">
  <div class="ps-marquee-inner">
    {%- assign marquee_items = "🧼 Soaps,🧴 Lotions,🕯️ Candles,🧖 Face Scrubs,🌿 All Natural,🎖️ Veteran Owned,📍 Oskaloosa Iowa,⭐ 190+ Products,🎁 Free Samples" | split: "," -%}
    {%- for item in marquee_items -%}<span class="ps-m-item">{{ item }}<span class="ps-m-sep">✦</span></span>{%- endfor -%}
    {%- for item in marquee_items -%}<span class="ps-m-item">{{ item }}<span class="ps-m-sep">✦</span></span>{%- endfor -%}
  </div>
</div>


<!-- PRODUCTS — rendered server-side via Liquid -->
<section class="ps-products" id="ps-products">
  <div class="ps-products-top">
    <div>
      <div class="ps-section-tag ps-reveal">🛒 Shop Now</div>
      <h2 class="ps-section-h2 ps-reveal ps-rd1">Pick Your <em>Favorites!</em></h2>
    </div>
    <a href="{{ shop.url }}/collections/all" class="ps-view-all ps-reveal">See All {{ collections.all.products_count }} Products →</a>
    <a href="{{ shop.url }}/collections/all" class="ps-mobile-view-all ps-btn-primary">
      See All {{ collections.all.products_count }} Products 🛒
    </a>
  </div>

  <!-- Category filter tabs -->
  <div class="ps-cat-tabs ps-reveal" id="psCatTabs">
    <button class="ps-cat-tab active" data-cat="all">🌟 All</button>
    <button class="ps-cat-tab" data-cat="soap">🧼 Soaps</button>
    <button class="ps-cat-tab" data-cat="bodycare">🧴 Body Care</button>
    <button class="ps-cat-tab" data-cat="candle">🕯️ Candles</button>
    <button class="ps-cat-tab" data-cat="bomb">💣 Bath Bombs</button>
    <button class="ps-cat-tab" data-cat="scrub">🌸 Scrubs</button>
    <button class="ps-cat-tab" data-cat="accessory">🛁 Accessories</button>
  </div>

  <div class="ps-pgrid-wrap">
    <button class="ps-pgrid-arrow ps-pgrid-prev" id="psPrev" aria-label="Previous products">&#8592;</button>
    <div class="ps-pgrid" id="psProductGrid">
    {%- assign featured = collections['featured-products'] -%}
    {%- assign source = featured.products | default: collections.all.products -%}
    {%- for product in source limit: 24 -%}
      {%- assign ps_type = product.type | strip -%}

      {%- case ps_type -%}
        {%- when 'Body Bars' -%}
          {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}
        {%- when 'Body Lotion', 'Ultra-Rich Body Butter', 'Hair And Body Wash', 'Perfume Body Spray', 'Deodorant', 'Lip butter', 'Foaming Hand Soap', 'Metaphysical' -%}
          {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}
        {%- when 'Candles - 8 oz', 'Seasonal Candles', 'Wax Melts', 'Potpourri' -%}
          {%- assign ps_cat = 'candle' -%}{%- assign ps_emoji = '🕯️' -%}
        {%- when 'Bath Bombs' -%}
          {%- assign ps_cat = 'bomb' -%}{%- assign ps_emoji = '💣' -%}
        {%- when 'Brown Sugar Scrub' -%}
          {%- assign ps_cat = 'scrub' -%}{%- assign ps_emoji = '🌸' -%}
        {%- when 'Bath Accessories', 'Happily Ever After' -%}
          {%- assign ps_cat = 'accessory' -%}{%- assign ps_emoji = '🛁' -%}
        {%- else -%}
          {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}
      {%- endcase -%}

      {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
      {%- assign is_available = product.available -%}

      <div class="ps-pc" data-cat="{{ ps_cat }}">
        <div class="ps-pc-img">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
              alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
              loading="lazy"
              width="400" height="400"
            >
          {%- else -%}
            <div class="ps-pc-img-fallback">{{ ps_emoji }}</div>
          {%- endif -%}

          {%- unless is_available -%}
            <span class="ps-pc-badge ps-sold">Sold Out</span>
          {%- endunless -%}

          <div class="ps-pc-overlay">
            {%- if is_available -%}
              <button class="ps-pc-quick"
                data-variant-id="{{ first_variant.id }}"
                data-product-title="{{ product.title | escape }}"
                onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">
                Quick Add! 🛒
              </button>
            {%- else -%}
              <button class="ps-pc-quick" disabled>Out of Stock</button>
            {%- endif -%}
          </div>
        </div>

        <div class="ps-pc-body">
          <p class="ps-pc-cat">{{ ps_emoji }} {{ ps_type | default: 'Body Bar' }}</p>
          <h3 class="ps-pc-name">
            <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">{{ product.title }}</a>
          </h3>
          <div class="ps-pc-foot">
            {%- if is_available -%}
              <span class="ps-pc-price">{{ first_variant.price | money }}</span>
              <button class="ps-atc"
                data-variant-id="{{ first_variant.id }}"
                data-product-title="{{ product.title | escape }}"
                onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">
                Add to Cart
              </button>
            {%- else -%}
              <span class="ps-pc-price ps-sold-out">{{ product.price | money }}</span>
              <button class="ps-atc" disabled>Sold Out</button>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div><!-- /ps-pgrid -->
    <button class="ps-pgrid-arrow ps-pgrid-next" id="psNext" aria-label="Next products">&#8594;</button>
  </div><!-- /ps-pgrid-wrap -->

  <div class="ps-load-more-wrap">
    <a href="{{ shop.url }}/collections/all" class="ps-btn-primary">See All Products 👉</a>
  </div>
</section>

<script>
// ── Parallax ──
const psHeroBgEl   = document.getElementById('psHeroBg');
const psHeroArtEl  = document.getElementById('psHeroArt');

function psRatio(el) {
  const r = el.getBoundingClientRect();
  return (window.innerHeight - r.top) / (window.innerHeight + r.height);
}
function psSetNavTop() {
  const rainbow  = document.querySelector('.ps-rainbow-bar');
  const announce = document.querySelector('.ps-announce');
  const h = (rainbow  ? rainbow.offsetHeight  : 8)
          + (announce ? announce.offsetHeight : 36);
  document.documentElement.style.setProperty('--nav-top', h + 'px');
}
function psOnScroll() {
  const sy = window.scrollY;
  if (psHeroBgEl)   psHeroBgEl.style.transform  = `translateY(${sy * 0.45}px)`;
  if (psHeroArtEl)  psHeroArtEl.style.transform  = `translateY(${sy * 0.25}px) scaleX(-1)`;
  document.getElementById('psNav').classList.toggle('scrolled', sy > 50);
}
window.addEventListener('scroll', psOnScroll, { passive: true });
window.addEventListener('resize', psSetNavTop, { passive: true });
psSetNavTop();
psOnScroll();

// ── Reveal on scroll ──
const psRevObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); psRevObs.unobserve(e.target); }
  });
}, { threshold: 0.08 });
document.querySelectorAll('.ps-reveal').forEach(el => psRevObs.observe(el));

// ── Category filter tabs ──
document.getElementById('psCatTabs').addEventListener('click', e => {
  const tab = e.target.closest('.ps-cat-tab');
  if (!tab) return;
  document.querySelectorAll('.ps-cat-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active');
  const cat = tab.dataset.cat;
  const isMobile = window.innerWidth < 680;
  let shown = 0;
  document.querySelectorAll('#psProductGrid .ps-pc').forEach(card => {
    const match = cat === 'all' || card.dataset.cat === cat;
    // On mobile "All" tab: keep the 6-card cap; specific categories show all matches
    const overMobileLimit = isMobile && cat === 'all' && shown >= 6;
    const visible = match && !overMobileLimit;
    card.style.display = visible ? 'flex' : 'none';
    if (visible) shown++;
  });
  // Reset slider position and refresh arrow states
  var grid = document.getElementById('psProductGrid');
  if (grid) {
    grid.scrollLeft = 0;
    grid.dispatchEvent(new Event('scroll'));
  }
});

// ── Smooth anchor scrolling ──
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const el = document.querySelector(a.getAttribute('href'));
    if (el) { e.preventDefault(); el.scrollIntoView({ behavior: 'smooth' }); }
  });
});
// ── Product slider (large screens only) ──
(function() {
  var grid = document.getElementById('psProductGrid');
  var prev = document.getElementById('psPrev');
  var next = document.getElementById('psNext');
  if (!grid || !prev || !next) return;

  function scrollBy(dir) {
    var card = grid.querySelector('.ps-pc');
    if (!card) return;
    var step = (card.offsetWidth + parseInt(getComputedStyle(grid).gap || 24)) * 2;
    grid.scrollBy({ left: dir * step, behavior: 'smooth' });
  }

  function updateArrows() {
    var atStart = grid.scrollLeft <= 4;
    var atEnd = grid.scrollLeft >= grid.scrollWidth - grid.offsetWidth - 4;
    prev.style.opacity = atStart ? '0.3' : '1';
    prev.style.pointerEvents = atStart ? 'none' : 'auto';
    next.style.opacity = atEnd ? '0.3' : '1';
    next.style.pointerEvents = atEnd ? 'none' : 'auto';
  }

  prev.addEventListener('click', function() { scrollBy(-1); });
  next.addEventListener('click', function() { scrollBy(1); });
  grid.addEventListener('scroll', updateArrows, { passive: true });
  updateArrows();
})();

</script>

