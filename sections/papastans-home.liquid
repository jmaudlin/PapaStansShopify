
<!-- HERO: Split Kinetic — one continuous pin (bucket tips → panel opens/splits closed →
     real "Pick Your Favorites" section revealed, with its own cat-tab filters and
     arrow-paged carousel), then testimonial + into the rest of the homepage below. -->
{%- assign featured = collections['featured-products'] -%}
{%- assign runway_source = featured.products | default: collections.all.products -%}
<div class="ps-herowrap" id="psHeroWrap">
  <div class="ps-heropin">
    <div class="ps-hero-bgdark" id="psHeroBgDark"></div>
    <div class="ps-hero-photo" id="psHeroPhoto">
      <div class="ps-hero-bucket" id="psHeroBucket">🪣</div>
    </div>
    <div id="psBubbleField"></div>
    <div class="ps-hero-zoomlabel" id="psHeroZoomLabel">
      <span class="label">{{ section.settings.hero_eyebrow | default: "Papa Stan's of Iowa · Est. 2019" }}</span>
      <h1>{{ section.settings.hero_heading | default: 'Soaps. Lotions.' }}<br><span class="glow">{{ section.settings.hero_heading_glow | default: 'Candles.' }}</span></h1>
      <p>{{ section.settings.hero_subheading | default: 'Handcrafted, veteran-owned, made in small batches.' }}</p>
      <div class="cta-row">
        <a href="{{ section.settings.hero_shop_link | default: '/collections/all' }}" class="ps-hkbtn ps-btn-glow">Shop Now</a>
        {%- if runway_source.first -%}
          <a href="{{ runway_source.first.url }}" class="ps-hkbtn ps-hkbtn-ghost">View a Product</a>
        {%- endif -%}
      </div>
    </div>
    <div class="ps-hero-runway" id="psHeroRunway">
      <div class="ps-runway-body">
        <section class="ps-products ps-products--in-hero" id="ps-products">
          <div class="ps-products-top">
            <div>
              <div class="ps-section-tag">🛒 Shop Now</div>
              <h2 class="ps-section-h2">Pick Your <em>Favorites!</em></h2>
            </div>
            <a href="{{ shop.url }}/collections/all" class="ps-view-all">See All {{ collections.all.products_count }} Products →</a>
            <a href="{{ shop.url }}/collections/all" class="ps-mobile-view-all ps-btn-primary">
              See All {{ collections.all.products_count }} Products 🛒
            </a>
          </div>

          <!-- Category filter tabs — "All" filters in-page; others navigate to collection -->
          <div class="ps-cat-tabs" id="psCatTabs">
            <button class="ps-cat-tab active" data-cat="all">🌟 All</button>
            <a href="/collections/soaps"             class="ps-cat-tab" data-cat="soap">🧼 Soaps</a>
            <a href="/collections/body-care"         class="ps-cat-tab" data-cat="bodycare">🧴 Body Care</a>
            <a href="/collections/candles-and-scents" class="ps-cat-tab" data-cat="candle">🕯️ Candles</a>
            <a href="/collections/bath-bombs"        class="ps-cat-tab" data-cat="bomb">💣 Bath Bombs</a>
            <a href="/collections/scrubs"            class="ps-cat-tab" data-cat="scrub">🌸 Scrubs</a>
            <a href="/collections/accessories"       class="ps-cat-tab" data-cat="accessory">🛁 Accessories</a>
          </div>

          <div class="ps-pgrid-wrap">
            <button class="ps-pgrid-arrow ps-pgrid-prev" id="psPrev" aria-label="Previous products">&#8592;</button>
            <div class="ps-pgrid" id="psProductGrid">
            {%- assign featured = collections['featured-products'] -%}
            {%- assign source = featured.products | default: collections.all.products -%}
            {%- for product in source limit: 24 -%}
              {%- assign ps_type = product.type | strip -%}
              {%- case ps_type -%}
                {%- when 'Body Bars' -%}
                  {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}
                {%- when 'Body Lotion', 'Ultra-Rich Body Butter', 'Hair And Body Wash', 'Perfume Body Spray', 'Deodorant', 'Lip butter', 'Foaming Hand Soap', 'Metaphysical' -%}
                  {%- assign ps_cat = 'bodycare' -%}{%- assign ps_emoji = '🧴' -%}
                {%- when 'Candles - 8 oz', 'Seasonal Candles', 'Wax Melts', 'Potpourri' -%}
                  {%- assign ps_cat = 'candle' -%}{%- assign ps_emoji = '🕯️' -%}
                {%- when 'Bath Bombs' -%}
                  {%- assign ps_cat = 'bomb' -%}{%- assign ps_emoji = '💣' -%}
                {%- when 'Brown Sugar Scrub' -%}
                  {%- assign ps_cat = 'scrub' -%}{%- assign ps_emoji = '🌸' -%}
                {%- when 'Bath Accessories', 'Happily Ever After' -%}
                  {%- assign ps_cat = 'accessory' -%}{%- assign ps_emoji = '🛁' -%}
                {%- else -%}
                  {%- assign ps_cat = 'soap' -%}{%- assign ps_emoji = '🧼' -%}
              {%- endcase -%}

              {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
              {%- assign is_available = product.available -%}

              <div class="ps-pc" data-cat="{{ ps_cat }}">
                <div class="ps-pc-img">
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
                      srcset="{{ product.featured_image | image_url: width: 200, height: 200, crop: 'center' }} 200w,
                              {{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }} 400w,
                              {{ product.featured_image | image_url: width: 600, height: 600, crop: 'center' }} 600w"
                      sizes="(max-width: 480px) 44vw, (max-width: 768px) 30vw, 220px"
                      alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
                      loading="lazy"
                      width="400" height="400"
                    >
                  {%- else -%}
                    <div class="ps-pc-img-fallback">{{ ps_emoji }}</div>
                  {%- endif -%}

                  {%- unless is_available -%}
                    <span class="ps-pc-badge ps-sold">Sold Out</span>
                  {%- endunless -%}

                  <div class="ps-pc-overlay">
                    {%- if is_available -%}
                      <button class="ps-pc-quick"
                        data-variant-id="{{ first_variant.id }}"
                        data-product-title="{{ product.title | escape }}"
                        onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">
                        Quick Add! 🛒
                      </button>
                    {%- else -%}
                      <button class="ps-pc-quick" disabled>Out of Stock</button>
                    {%- endif -%}
                  </div>
                </div>

                <div class="ps-pc-body">
                  <p class="ps-pc-cat">{{ ps_emoji }} {{ ps_type | default: 'Body Bar' }}</p>
                  <h3 class="ps-pc-name">
                    <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">{{ product.title }}</a>
                  </h3>
                  <div class="ps-pc-foot">
                    {%- if is_available -%}
                      <span class="ps-pc-price">{{ first_variant.price | money }}</span>
                      <button class="ps-atc"
                        data-variant-id="{{ first_variant.id }}"
                        data-product-title="{{ product.title | escape }}"
                        onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">
                        Add to Cart
                      </button>
                    {%- else -%}
                      <span class="ps-pc-price ps-sold-out">{{ product.price | money }}</span>
                      <button class="ps-atc" disabled>Sold Out</button>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div><!-- /ps-pgrid -->
            <button class="ps-pgrid-arrow ps-pgrid-next" id="psNext" aria-label="Next products">&#8594;</button>
          </div><!-- /ps-pgrid-wrap -->
        </section>
      </div>
    </div>
    <div class="ps-hero-panel" id="psHeroPanel">
      <div class="ps-hero-panel-content" id="psHeroPanelContent">
        <h1>{{ section.settings.panel_heading | default: 'Handmade,<br>Head to Toe.' }}</h1>
        <p>{{ section.settings.panel_subheading | default: "Soaps, lotions & candles from Oskaloosa, Iowa since 2019" }}</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap">
          <a href="{{ section.settings.hero_shop_link | default: '/collections/all' }}" class="ps-hkbtn ps-hkbtn-light">🛒 Shop Now</a>
          {%- if runway_source.first -%}
            <a href="{{ runway_source.first.url }}" class="ps-hkbtn ps-hkbtn-ghost">A Product →</a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Phase D reveal: latest blog posts, kinetic cards: latest posts, kinetic cards -->
    <div class="ps-hero-blog-layer" id="psHeroBlog">
      <section class="ps-hblog">
        {%- comment -%} Default: combined feed from every store blog, newest first. Picking a blog in the editor narrows it to that one. {%- endcomment -%}
        {%- if section.settings.blog_source != blank and blogs[section.settings.blog_source].articles_count > 0 -%}
          {%- assign harticles = blogs[section.settings.blog_source].articles -%}
          {%- assign hblog_url = blogs[section.settings.blog_source].url -%}
        {%- else -%}
          {%- assign harticles = blogs.news.articles | concat: blogs.articles.articles | sort: 'published_at' | reverse -%}
          {%- assign hblog_url = '/blogs/articles' -%}
        {%- endif -%}
        <div class="ps-hblog-head">
          <div class="ps-section-tag" style="background:var(--white);">{{ section.settings.blog_eyebrow | default: '📖 From the Blog' }}</div>
          <h2 class="ps-section-h2 ps-light">{{ section.settings.blog_heading | default: "From Papa Stan's Notes" }}</h2>
        </div>
        {%- if harticles.size > 0 -%}
          <div class="ps-hblog-grid">
            {%- for article in harticles limit: section.settings.blog_count -%}
              <article class="ps-blog-card">
                <a href="{{ article.url }}" class="ps-blog-card-img-link">
                  {%- if article.image -%}
                    <img src="{{ article.image | image_url: width: 600, height: 400, crop: 'center' }}"
                         alt="{{ article.image.alt | escape | default: article.title | escape }}"
                         width="600" height="400" loading="lazy" class="ps-blog-card-img">
                  {%- else -%}
                    <div class="ps-blog-card-img-fallback">🧼</div>
                  {%- endif -%}
                </a>
                <div class="ps-blog-card-body">
                  <div class="ps-blog-card-meta">
                    {%- if article.tags.size > 0 -%}<span class="ps-blog-tag">{{ article.tags.first }}</span>{%- endif -%}
                    <span class="ps-blog-date">{{ article.published_at | date: "%b %d, %Y" }}</span>
                  </div>
                  <h3 class="ps-blog-card-title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                  <p class="ps-blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 110 }}</p>
                  <a href="{{ article.url }}" class="ps-blog-read-more">Read More →</a>
                </div>
              </article>
            {%- endfor -%}
          </div>
        {%- else -%}
          <p class="ps-hblog-empty">Stories from the soap shed are on their way — check back soon! 🌿</p>
        {%- endif -%}
        <div class="ps-hblog-cta">
          <a href="{{ section.settings.blog_cta_link | default: hblog_url }}" class="ps-btn-primary">Read the Blog 📖</a>
        </div>
      </section>
    </div>

    <!-- Post-blog reveal: real Judge.me testimonials carousel -->
    <div class="ps-hero-testimonials-layer ps-testimonials-dark" id="psHeroTestimonials">
      {% render 'ps-testimonials' %}
    </div>

    <!-- Phase F reveal: newsletter signup -->
    <div class="ps-hero-newsletter-layer" id="psHeroNewsletter">
      <section class="ps-newsletter">
        <div class="ps-section-tag" style="margin:0 auto 1rem;background:var(--white);">{{ section.settings.newsletter_eyebrow | default: '📬 Stay Connected' }}</div>
        <h2 class="ps-section-h2 ps-light" style="margin-bottom:.8rem">{{ section.settings.newsletter_heading | default: 'Get the Good Stuff First!' }}</h2>
        <p class="ps-nl-sub">{{ section.settings.newsletter_subtext | default: 'New scents, seasonal specials, local pop-up events, and exclusive deals!' }}</p>
        {%- form 'customer', id: 'ps-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="ps-nl-form">
            <input type="email" name="contact[email]" class="ps-nl-input" placeholder="your@email.com" required>
            <button type="submit" class="ps-nl-btn">Subscribe! 🌿</button>
          </div>
        {%- endform -%}
      </section>
    </div>

    <!-- First-visit scroll cues: chevron + idle bucket nudge; JS emits a bubble stream from the bucket until it tips -->
    <div class="ps-scroll-cue" id="psScrollCue" aria-hidden="true">
      <span class="ps-scroll-cue-text">{{ section.settings.scroll_cue_text | default: 'scroll to pour' }}</span>
      <svg class="ps-scroll-cue-chev" width="26" height="14" viewBox="0 0 26 14" fill="none"><path d="M2 2l11 10L24 2" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <div class="ps-hero-wipe-d" id="psWipeD"></div>
    <div class="ps-hero-wipe-blog" id="psWipeBlog"></div>
    <div class="ps-hero-wipe-f" id="psWipeF"></div>

    <!-- Persistent ticker: once revealed (phase B), stays on screen through every
         later phase/wipe. Only hides again if you scroll back to the very start.
         Content comes from the same "Announcement Bar" menu as the top bar
         (Content > Navigation > handle: announcement-bar). -->
    {%- assign ann_links = linklists['announcement-bar'].links -%}
    <div class="ps-kmarquee" id="psMarqueeLayer">
      <div class="ps-kmarquee-inner" id="psKmTrack">
        {%- if ann_links.size > 0 -%}
          {%- for link in ann_links -%}
            <span{% if forloop.index0 == 1 or forloop.index0 == 3 or forloop.index0 == 5 %} class="alt"{% endif %}>{{ link.title }}</span>
          {%- endfor -%}
        {%- else -%}
          <span>🧼 SOAPS</span><span class="alt">🧴 LOTIONS</span><span>🕯️ CANDLES</span><span class="alt">🌸 SCRUBS</span><span>💣 BATH BOMBS</span><span class="alt">🎖️ VETERAN OWNED</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- for block in section.blocks -%}
  {%- case block.type -%}
    {%- when '@app' -%}
      <div class="ps-hero-app-block" {{ block.shopify_attributes }}>
        {% render block %}
      </div>
  {%- endcase -%}
{%- endfor -%}






<script src="{{ 'ps-home-kinetic.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Papa Stan's Home",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow text",
      "default": "Papa Stan's of Iowa \u00b7 Est. 2019"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading (line 1)",
      "default": "Soaps. Lotions."
    },
    {
      "type": "text",
      "id": "hero_heading_glow",
      "label": "Heading (glow line)",
      "default": "Candles."
    },
    {
      "type": "text",
      "id": "hero_subheading",
      "label": "Subheading",
      "default": "Handcrafted, veteran-owned, made in small batches."
    },
    {
      "type": "url",
      "id": "hero_shop_link",
      "label": "\"Shop Now\" link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Hero \u2014 reveal panel"
    },
    {
      "type": "text",
      "id": "panel_heading",
      "label": "Panel heading (use <br> for line break)",
      "default": "Handmade,<br>Head to Toe."
    },
    {
      "type": "text",
      "id": "panel_subheading",
      "label": "Panel subheading",
      "default": "Soaps, lotions & candles from Oskaloosa, Iowa since 2019"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_eyebrow",
      "label": "Eyebrow tag",
      "default": "\ud83d\udcec Stay Connected"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Get the Good Stuff First!"
    },
    {
      "type": "textarea",
      "id": "newsletter_subtext",
      "label": "Subtext",
      "default": "New scents, seasonal specials, local pop-up events, and exclusive deals!"
    },
    {
      "type": "header",
      "content": "Blog chapter"
    },
    {
      "type": "blog",
      "id": "blog_source",
      "label": "Blog to feature (optional)",
      "info": "Leave unset to combine posts from all blogs, newest first."
    },
    {
      "type": "text",
      "id": "blog_eyebrow",
      "label": "Eyebrow",
      "default": "\ud83d\udcd6 From the Blog"
    },
    {
      "type": "text",
      "id": "blog_heading",
      "label": "Heading",
      "default": "From Papa Stan's Notes"
    },
    {
      "type": "range",
      "id": "blog_count",
      "label": "Posts to show",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "url",
      "id": "blog_cta_link",
      "label": "\"Read the Blog\" link",
      "info": "Defaults to the featured blog."
    },
    {
      "type": "text",
      "id": "scroll_cue_text",
      "label": "Scroll cue caption",
      "default": "scroll to pour"
    }
  ],
  "presets": [
    {
      "name": "Papa Stan's Home"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "templates": [
    "index"
  ]
}
{% endschema %}
