{% render 'ps-header' %}

<!-- HERO -->
<section class="ps-hero">
  <div class="ps-hero-bg" id="psHeroBg"></div>
  <div class="ps-hero-pattern"></div>
  <div class="ps-bubble ps-bubble-1"></div>
  <div class="ps-bubble ps-bubble-2"></div>
  <div class="ps-bubble ps-bubble-3"></div>
  <div class="ps-bubble ps-bubble-4"></div>
  <div class="ps-bubble ps-bubble-5"></div>
  <div class="ps-bubble ps-bubble-6"></div>
  <div class="ps-bubble ps-bubble-7"></div>
  <div class="ps-hero-art" id="psHeroArt">🪣</div>
  <div class="ps-hero-content">
    <div class="ps-hero-eyebrow">🌿 Handcrafted · Small Batch · All Natural</div>
    <h1 class="ps-hero-h1"><span>Soaps, Lotions</span><br>&amp; Candles!</h1>
    <p class="ps-hero-sub">Made with love right here in<br>Oskaloosa, Iowa since 2019</p>
    <div class="ps-hero-btns">
      <a href="#ps-products" class="ps-btn-primary">Shop Now 🛒</a>
      <a href="{{ shop.url }}/pages/our-story" class="ps-btn-secondary">Our Story 🏡</a>
    </div>
  </div>

  <div class="ps-hero-phone">
    <span>📞</span>
    <a href="tel:6416701573">641.670.1573</a>
  </div>
</section>

<!-- MARQUEE -->
<div class="ps-marquee">
  <div class="ps-marquee-inner">
    {%- assign marquee_items = "🧼 Soaps,🧴 Lotions,🕯️ Candles,🧖 Face Scrubs,🌿 All Natural,🎖️ Veteran Owned,📍 Oskaloosa Iowa,⭐ 190+ Products,🎁 Free Samples" | split: "," -%}
    {%- for item in marquee_items -%}<span class="ps-m-item">{{ item }}<span class="ps-m-sep">✦</span></span>{%- endfor -%}
    {%- for item in marquee_items -%}<span class="ps-m-item">{{ item }}<span class="ps-m-sep">✦</span></span>{%- endfor -%}
  </div>
</div>


<!-- PRODUCTS — rendered server-side via Liquid -->
<section class="ps-products" id="ps-products">
  <div class="ps-products-top">
    <div>
      <div class="ps-section-tag ps-reveal">🛒 Shop Now</div>
      <h2 class="ps-section-h2 ps-reveal ps-rd1">Pick Your <em>Favorites!</em></h2>
    </div>
    <a href="{{ shop.url }}/collections/all" class="ps-view-all ps-reveal">See All {{ collections.all.products_count }} Products →</a>
    <a href="{{ shop.url }}/collections/all" class="ps-mobile-view-all ps-btn-primary">
      See All {{ collections.all.products_count }} Products 🛒
    </a>
  </div>

  <!-- Category filter tabs -->
  <div class="ps-cat-tabs ps-reveal" id="psCatTabs">
    <button class="ps-cat-tab active" data-cat="all">🌟 All</button>
    <button class="ps-cat-tab" data-cat="soap">🧼 Soaps</button>
    <button class="ps-cat-tab" data-cat="lotion">🧴 Lotions</button>
    <button class="ps-cat-tab" data-cat="candle">🕯️ Candles</button>
    <button class="ps-cat-tab" data-cat="scrub">🌸 Scrubs</button>
  </div>

  <div class="ps-pgrid" id="psProductGrid">
    {%- assign product_limit = 24 -%}
    {%- for product in collections.all.products limit: product_limit -%}
      {%- assign product_type_lower = product.type | downcase -%}
      {%- assign product_tags_lower = product.tags | join: ' ' | downcase -%}
      {%- assign product_title_lower = product.title | downcase -%}
      {%- assign combined = product_type_lower | append: ' ' | append: product_tags_lower | append: ' ' | append: product_title_lower -%}

      {%- if combined contains 'candle' -%}
        {%- assign ps_cat = 'candle' -%}
        {%- assign ps_emoji = '🕯️' -%}
      {%- elsif combined contains 'lotion' or combined contains 'butter' or combined contains 'cream' -%}
        {%- assign ps_cat = 'lotion' -%}
        {%- assign ps_emoji = '🧴' -%}
      {%- elsif combined contains 'scrub' -%}
        {%- assign ps_cat = 'scrub' -%}
        {%- assign ps_emoji = '🌸' -%}
      {%- else -%}
        {%- assign ps_cat = 'soap' -%}
        {%- assign ps_emoji = '🧼' -%}
      {%- endif -%}

      {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
      {%- assign is_available = product.available -%}

      <div class="ps-pc ps-reveal" data-cat="{{ ps_cat }}">
        <div class="ps-pc-img">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
              alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
              loading="lazy"
              width="400" height="400"
            >
          {%- else -%}
            <div class="ps-pc-img-fallback">{{ ps_emoji }}</div>
          {%- endif -%}

          {%- unless is_available -%}
            <span class="ps-pc-badge ps-sold">Sold Out</span>
          {%- endunless -%}

          <div class="ps-pc-overlay">
            {%- if is_available -%}
              <button class="ps-pc-quick"
                data-variant-id="{{ first_variant.id }}"
                data-product-title="{{ product.title | escape }}"
                onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">
                Quick Add! 🛒
              </button>
            {%- else -%}
              <button class="ps-pc-quick" disabled>Out of Stock</button>
            {%- endif -%}
          </div>
        </div>

        <div class="ps-pc-body">
          <p class="ps-pc-cat">{{ ps_emoji }} {{ ps_cat | capitalize }}</p>
          <h3 class="ps-pc-name">
            <a href="{{ product.url }}" style="text-decoration:none;color:inherit;">{{ product.title }}</a>
          </h3>
          <div class="ps-pc-foot">
            {%- if is_available -%}
              <span class="ps-pc-price">{{ first_variant.price | money }}</span>
              <button class="ps-atc"
                data-variant-id="{{ first_variant.id }}"
                data-product-title="{{ product.title | escape }}"
                onclick="psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">
                Add to Cart
              </button>
            {%- else -%}
              <span class="ps-pc-price ps-sold-out">{{ product.price | money }}</span>
              <button class="ps-atc" disabled>Sold Out</button>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <div class="ps-load-more-wrap">
    <a href="{{ shop.url }}/collections/all" class="ps-btn-primary">See All Products 👉</a>
  </div>
</section>

<!-- SCENTS PARALLAX -->
<section class="ps-scents" id="ps-scents">
  <div class="ps-scents-bg" id="psScentsBg"></div>
  <div class="ps-scents-pattern"></div>
  <div class="ps-scents-inner">
    <div class="ps-scents-text">
      <div class="ps-section-tag ps-reveal" style="background:var(--sun);border-color:rgba(255,255,255,.4);">🌺 Scent Library</div>
      <h2 class="ps-section-h2 ps-light ps-reveal ps-rd1">A Scent for <em>Everyone!</em></h2>
      <p class="ps-reveal ps-rd2">With {{ collections.all.products_count }}+ products and dozens of amazing scents, we've got something for everybody! From sweet and fruity to fresh and woodsy — all handcrafted in Oskaloosa, Iowa.</p>
      <a href="{{ shop.url }}/collections/all" class="ps-btn-secondary ps-reveal ps-rd3">Browse All Scents 🌸</a>
    </div>
    <div class="ps-scents-grid">
      <div class="ps-scent-chip ps-reveal"><div class="ps-scent-name">🍊 Citrus &amp; Seagrass</div><div class="ps-scent-type">Candle · Soap</div></div>
      <div class="ps-scent-chip ps-reveal ps-rd1"><div class="ps-scent-name">🍬 Vanilla Caramel</div><div class="ps-scent-type">Soap · Lotion</div></div>
      <div class="ps-scent-chip ps-reveal ps-rd2"><div class="ps-scent-name">🍎 Apple Cinnamon</div><div class="ps-scent-type">Soap</div></div>
      <div class="ps-scent-chip ps-reveal ps-rd1"><div class="ps-scent-name">🥥 Bamboo Coconut</div><div class="ps-scent-type">Soap · Lotion</div></div>
      <div class="ps-scent-chip ps-reveal ps-rd2"><div class="ps-scent-name">🌸 Aloe White Lilac</div><div class="ps-scent-type">Lotion</div></div>
      <div class="ps-scent-chip ps-reveal ps-rd3"><div class="ps-scent-name">🍌 Banana Orange Smoothie</div><div class="ps-scent-type">Soap</div></div>
      <div class="ps-scent-chip ps-reveal ps-rd1"><div class="ps-scent-name">🍩 Sweet Sugar Donut</div><div class="ps-scent-type">Soap</div></div>
      <div class="ps-scent-chip ps-reveal ps-rd2"><div class="ps-scent-name">🍓 Raspberry Delight</div><div class="ps-scent-type">Soap · Sample</div></div>
      <div class="ps-scent-more ps-reveal ps-rd3">…and {{ collections.all.products_count | minus: 9 }}+ more amazing scents in the shop! ✨</div>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="ps-testi">
  <div class="ps-testi-header">
    <div class="ps-section-tag ps-reveal" style="margin:0 auto 1rem;">⭐ Happy Customers</div>
    <h2 class="ps-section-h2 ps-reveal ps-rd1">People <em>Love</em> Papa Stan's!</h2>
  </div>
  <div class="ps-testi-grid">
    <div class="ps-tc ps-reveal ps-pop">
      <div class="ps-tc-quote">"</div>
      <div class="ps-tc-stars">★★★★★</div>
      <p class="ps-tc-text">The Bamboo Coconut soap is absolutely incredible! I've never felt so clean and my skin feels so soft. I order a new batch every month!</p>
      <p class="ps-tc-author">— Sarah M., Oskaloosa</p>
    </div>
    <div class="ps-tc ps-reveal ps-pop ps-rd1">
      <div class="ps-tc-quote">"</div>
      <div class="ps-tc-stars">★★★★★</div>
      <p class="ps-tc-text">Bought the Citrus &amp; Seagrass candle for my mom's birthday and now she's obsessed! It fills the whole house with the most wonderful scent.</p>
      <p class="ps-tc-author">— James R., Iowa City</p>
    </div>
    <div class="ps-tc ps-reveal ps-pop ps-rd2">
      <div class="ps-tc-quote">"</div>
      <div class="ps-tc-stars">★★★★★</div>
      <p class="ps-tc-text">Love supporting a local veteran-owned business! The Aloe Lilac lotion is genuinely the best I've ever used. My whole family is hooked now!</p>
      <p class="ps-tc-author">— Emily T., Des Moines</p>
    </div>
  </div>
</section>


<!-- FIND US -->
<section class="ps-local" id="ps-find-us">
  <div class="ps-local-inner">

    <!-- Embedded Google Map -->
    <div class="ps-map-wrap ps-reveal ps-from-left">
      <iframe
        class="ps-map-iframe"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3066.5!2d-92.6438!3d41.2959!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87ee4e3e3e3e3e3f%3A0x1!2sOskaloosa%2C+IA+52577!5e0!3m2!1sen!2sus!4v1"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>

    <div>
      <div class="ps-section-tag ps-reveal" style="background:var(--lav-light);color:var(--lav-dark);border-color:var(--lav-dark);">📍 Where to Find Us</div>
      <h2 class="ps-section-h2 ps-light ps-reveal ps-rd1">Proudly <em>Local.</em><br>Shipped <em>Everywhere!</em></h2>

      <div class="ps-local-detail ps-reveal ps-rd2">
        <div class="ps-l-icon">🏠</div>
        <div class="ps-l-text">
          <h4>{{ shop.address.address1 | default: 'Oskaloosa, Iowa' }}</h4>
          <p>{{ shop.address.city | default: 'Oskaloosa' }}, {{ shop.address.province_code | default: 'IA' }} {{ shop.address.zip | default: '52577' }}<br>{{ shop.address.country | default: 'United States' }}</p>
        </div>
      </div>

      <div class="ps-local-detail ps-reveal ps-rd2">
        <div class="ps-l-icon">📞</div>
        <div class="ps-l-text">
          <h4><a href="tel:{{ shop.phone | default: '6416701573' }}" style="color:var(--butter);text-decoration:none;">{{ shop.phone | default: '641.670.1573' }}</a></h4>
          <p><a href="mailto:{{ shop.email }}" style="color:rgba(255,255,255,.65);text-decoration:none;">{{ shop.email }}</a></p>
        </div>
      </div>

      <div class="ps-local-detail ps-reveal ps-rd3">
        <div class="ps-l-icon">🚚</div>
        <div class="ps-l-text">
          <h4>Free Shipping on $55+</h4>
          <p>Orders over $55 ship free nationwide. Plus 4 free samples with every order!</p>
        </div>
      </div>

      <div class="ps-local-detail ps-reveal ps-rd4">
        <div class="ps-l-icon">⭐</div>
        <div class="ps-l-text">
          <h4>Veteran-Owned &amp; Operated</h4>
          <p>Established 2019. We bring the same dedication from service to every batch we make.</p>
        </div>
      </div>

      <div class="ps-local-btns ps-reveal">
        <a href="https://maps.google.com/?q=Oskaloosa,+IA+52577" target="_blank" class="ps-btn-secondary" style="margin-top:1.5rem;display:inline-block;margin-right:.8rem;">Get Directions 🗺️</a>
        <a href="{{ shop.url }}/collections/all" class="ps-btn-primary" style="margin-top:1.5rem;display:inline-block;">Shop Now 🛒</a>
      </div>
    </div>

  </div>
</section>

<!-- NEWSLETTER -->
<section class="ps-newsletter">
  <div class="ps-section-tag ps-reveal" style="margin:0 auto 1rem;background:var(--white);">📬 Stay Connected</div>
  <h2 class="ps-section-h2 ps-light ps-reveal ps-rd1" style="margin-bottom:.8rem">Get the <em>Good Stuff</em> First!</h2>
  <p class="ps-nl-sub ps-reveal ps-rd2">New scents, seasonal specials, local pop-up events, and exclusive deals!</p>
  {%- form 'customer', id: 'ps-newsletter-form' -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="ps-nl-form ps-reveal ps-rd3">
      <input type="email" name="contact[email]" class="ps-nl-input" placeholder="your@email.com" required>
      <button type="submit" class="ps-nl-btn">Subscribe! 🌿</button>
    </div>
  {%- endform -%}
</section>

<!-- FOOTER -->
{% render 'ps-footer' %}

{% schema %}
{
  "name": "Papa Stan's Home",
  "settings": [],
  "presets": [{ "name": "Papa Stan's Home" }]
}
{% endschema %}
