
<!-- HERO: Split Kinetic — one continuous pin (bucket tips → panel opens/splits closed →
     runway of real featured products scrubs horizontally), then testimonial + into the
     rest of the homepage below. Mascot canvas (further down) is currently dormant — its
     old #psMascotCanvas mount point was part of the previous static hero. -->
{%- assign featured = collections['featured-products'] -%}
{%- assign runway_source = featured.products | default: collections.all.products -%}
<div class="ps-herowrap" id="psHeroWrap">
  <div class="ps-heropin">
    <div class="ps-hero-bgdark" id="psHeroBgDark"></div>
    <div class="ps-hero-photo" id="psHeroPhoto">
      <div class="ps-hero-bucket" id="psHeroBucket">🪣</div>
    </div>
    <div id="psBubbleField"></div>
    <div class="ps-hero-zoomlabel" id="psHeroZoomLabel">
      <span class="label">{{ section.settings.hero_eyebrow | default: 'Oskaloosa, Iowa · Est. 2019' }}</span>
      <h1>{{ section.settings.hero_heading | default: 'Soaps. Lotions.' }}<br><span class="glow">{{ section.settings.hero_heading_glow | default: 'Candles.' }}</span></h1>
      <p>{{ section.settings.hero_subheading | default: 'Handcrafted, veteran-owned, made in small batches.' }}</p>
      <div class="cta-row">
        <a href="{{ section.settings.hero_shop_link | default: '/collections/all' }}" class="ps-hkbtn ps-btn-glow">Shop Now</a>
        {%- if runway_source.first -%}
          <a href="{{ runway_source.first.url }}" class="ps-hkbtn ps-hkbtn-ghost">View a Product</a>
        {%- endif -%}
      </div>
    </div>
    <div class="ps-hero-runway" id="psHeroRunway">
      <div class="ps-kmarquee">
        <div class="ps-kmarquee-inner" id="psKmTrack">
          <span>🧼 SOAPS</span><span class="alt">🧴 LOTIONS</span><span>🕯️ CANDLES</span><span class="alt">🌸 SCRUBS</span><span>💣 BATH BOMBS</span><span class="alt">🎖️ VETERAN OWNED</span>
          <span>🧼 SOAPS</span><span class="alt">🧴 LOTIONS</span><span>🕯️ CANDLES</span><span class="alt">🌸 SCRUBS</span><span>💣 BATH BOMBS</span><span class="alt">🎖️ VETERAN OWNED</span>
        </div>
      </div>
      <div class="ps-runway-body">
        <div class="ps-runway-head"><div class="eyebrow">🛒 The Runway</div><h2>Pick Your Favorites!</h2></div>
        <div class="ps-runway-track" id="psRtrack">
          {%- for product in runway_source limit: 12 -%}
            {%- assign ps_type = product.type | strip -%}
            {%- case ps_type -%}
              {%- when 'Body Bars' -%}{%- assign ps_cat = 'Soaps' -%}{%- assign ps_emoji = '🧼' -%}
              {%- when 'Body Lotion', 'Ultra-Rich Body Butter', 'Hair And Body Wash', 'Perfume Body Spray', 'Deodorant', 'Lip butter', 'Foaming Hand Soap', 'Metaphysical' -%}{%- assign ps_cat = 'Body Care' -%}{%- assign ps_emoji = '🧴' -%}
              {%- when 'Candles - 8 oz', 'Seasonal Candles', 'Wax Melts', 'Potpourri' -%}{%- assign ps_cat = 'Candles' -%}{%- assign ps_emoji = '🕯️' -%}
              {%- when 'Bath Bombs' -%}{%- assign ps_cat = 'Bath Bombs' -%}{%- assign ps_emoji = '💣' -%}
              {%- when 'Brown Sugar Scrub' -%}{%- assign ps_cat = 'Scrubs' -%}{%- assign ps_emoji = '🌸' -%}
              {%- when 'Bath Accessories', 'Happily Ever After' -%}{%- assign ps_cat = 'Accessories' -%}{%- assign ps_emoji = '🛁' -%}
              {%- else -%}{%- assign ps_cat = 'Soaps' -%}{%- assign ps_emoji = '🧼' -%}
            {%- endcase -%}
            {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
            <a href="{{ product.url }}" class="ps-rcard">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}" alt="{{ product.featured_image.alt | escape | default: product.title | escape }}" loading="lazy" width="400" height="400">
              {%- endif -%}
              <div class="b">
                <div class="cat">{{ ps_emoji }} {{ ps_cat }}</div>
                <div class="n">{{ product.title }}</div>
                <div class="row">
                  <span class="p">{{ first_variant.price | money }}</span>
                  {%- if product.available -%}
                    <button type="button" onclick="event.preventDefault();psAddToCart({{ first_variant.id }}, '{{ product.title | escape }}')">+</button>
                  {%- else -%}
                    <button type="button" disabled>✕</button>
                  {%- endif -%}
                </div>
              </div>
            </a>
          {%- endfor -%}
        </div>
        <div class="ps-runway-progress"><div class="ps-runway-progress-fill" id="psRunwayProgressFill"></div></div>
      </div>
    </div>
    <div class="ps-hero-panel" id="psHeroPanel">
      <div class="ps-hero-panel-content" id="psHeroPanelContent">
        <h1>{{ section.settings.panel_heading | default: 'Handmade,<br>Head to Toe.' }}</h1>
        <p>{{ section.settings.panel_subheading | default: "Soaps, lotions & candles from Oskaloosa, Iowa since 2019" }}</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap">
          <a href="{{ section.settings.hero_shop_link | default: '/collections/all' }}" class="ps-hkbtn ps-hkbtn-light">🛒 Shop Now</a>
          {%- if runway_source.first -%}
            <a href="{{ runway_source.first.url }}" class="ps-hkbtn ps-hkbtn-ghost">A Product →</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

<section class="ps-tband">
  <div class="ps-tband-inner">
    <p>&ldquo;{{ section.settings.testimonial_quote | default: "My skin has never felt better and the scent lasts all day. Absolutely love everything from Papa Stan's!" }}&rdquo;</p>
    <div class="author">— {{ section.settings.testimonial_author | default: 'Sarah M.' }}</div>
  </div>
</section>

{%- for block in section.blocks -%}
  {%- case block.type -%}
    {%- when '@app' -%}
      <div class="ps-hero-app-block" {{ block.shopify_attributes }}>
        {% render block %}
      </div>
  {%- endcase -%}
{%- endfor -%}

<script>
(function(){
  var herowrap = document.getElementById('psHeroWrap');
  var heroBgDark = document.getElementById('psHeroBgDark');
  var heroPhoto = document.getElementById('psHeroPhoto');
  var heroBucket = document.getElementById('psHeroBucket');
  var heroPanel = document.getElementById('psHeroPanel');
  var heroPanelContent = document.getElementById('psHeroPanelContent');
  var heroZoomLabel = document.getElementById('psHeroZoomLabel');
  var heroRunway = document.getElementById('psHeroRunway');
  var bubbleField = document.getElementById('psBubbleField');
  if (!herowrap || !bubbleField) return;

  // Three phases of ONE continuous pin: A = bucket tips, panel opens (lavender covers
  // screen); B = panel splits back closed, revealing the runway layer already sitting
  // full-frame beneath it; C = horizontal product scrub of real featured-products.
  var PA_END = 0.42, PB_END = 0.56;

  var BUBBLE_COUNT = 40;
  var bubbleBase = Array.from({ length: BUBBLE_COUNT }, function(_, i) {
    var ambient = i < 6;
    return {
      ambient: ambient,
      size: ambient ? 8 + Math.random() * 14 : 12 + Math.random() * 46,
      dx: ambient ? (Math.random() - 0.5) * 60 : -(0.15 + Math.random() * 0.85),
      dy: (Math.random() - 0.5) * 2,
      amp: ambient ? 30 + Math.random() * 40 : 120 + Math.random() * 260,
      appearAt: ambient ? 0 : 0.1 + Math.random() * 0.55,
      speed: 0.7 + Math.random() * 0.9
    };
  });
  var bubbles = bubbleBase.map(function() {
    var el = document.createElement('div');
    el.className = 'ps-hb-bubble';
    bubbleField.appendChild(el);
    return el;
  });
  bubbleBase.forEach(function(b, i) {
    bubbles[i].style.width = b.size + 'px';
    bubbles[i].style.height = b.size + 'px';
    bubbles[i].style.opacity = '0';
  });
  var lerp = function(a, b, t) { return a + (b - a) * t; };
  var easeInOutCubic = function(t) { return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2; };

  var progressFill = document.getElementById('psRunwayProgressFill');
  var kmtrack = document.getElementById('psKmTrack');
  var rtrack = document.getElementById('psRtrack');

  function onHeroScroll() {
    var rect = herowrap.getBoundingClientRect();
    var total = rect.height - window.innerHeight;
    var p = Math.min(1, Math.max(0, -rect.top / total));
    var pA = Math.min(1, p / PA_END);
    var ep = easeInOutCubic(pA);
    var pB = Math.min(1, Math.max(0, (p - PA_END) / (PB_END - PA_END)));
    var epB = easeInOutCubic(pB);
    var pC = Math.min(1, Math.max(0, (p - PB_END) / (1 - PB_END)));
    var vw = window.innerWidth, vh = window.innerHeight;

    var bucketW = 140, bucketH = 140;
    var bucketX = vw - bucketW - vw * 0.06;
    var bucketY = vh - bucketH - vh * 0.05;
    heroPhoto.style.left = bucketX + 'px';
    heroPhoto.style.top = bucketY + 'px';
    heroPhoto.style.width = bucketW + 'px';
    heroPhoto.style.height = bucketH + 'px';

    var tip = Math.min(1, Math.max(0, (ep - 0.12) / 0.35));
    var angle = lerp(0, -104, tip);
    heroBucket.style.transform = 'rotate(' + angle + 'deg)';

    heroBgDark.style.opacity = String(1 - Math.min(1, Math.max(0, (ep - 0.6) / 0.35)));

    var spoutX = bucketX + bucketW * lerp(0.55, 0.05, tip);
    var spoutY = bucketY + bucketH * lerp(0.15, 0.45, tip);

    bubbles.forEach(function(el, i) {
      var base = bubbleBase[i];
      var lp = base.ambient ? ep : Math.min(1, Math.max(0, (ep - base.appearAt) / (1 - base.appearAt)));
      var rise = lp * base.amp * base.speed;
      var spread = base.ambient ? base.dx : base.dx * (220 + tip * 900) * lp;
      var x = spoutX + spread;
      var y = spoutY - rise + base.dy * 30 * lp;
      var scale = lerp(base.ambient ? 0.8 : 0.5, base.ambient ? 1.2 : 1.9, lp);
      el.style.left = x + 'px';
      el.style.top = y + 'px';
      el.style.transform = 'scale(' + scale + ')';
      var fadeOut = Math.max(0, lp - 0.78) * 3.5;
      var baseOpacity = base.ambient ? 0.5 + lp * 0.4 : Math.min(1, lp * 1.8);
      el.style.opacity = (!base.ambient && lp <= 0) ? '0' : String(Math.max(0, baseOpacity * (1 - fadeOut)));
    });

    var openT = Math.max(0, ep - epB);
    var topX = lerp(0, 100, openT), bottomX = lerp(0, 78, openT);
    heroPanel.style.clipPath = 'polygon(0 0, ' + topX + '% 0, ' + bottomX + '% 100%, 0 100%)';

    var contentP = Math.min(1, Math.max(0, (ep - 0.45) / 0.55)) * (1 - epB);
    heroPanelContent.style.opacity = contentP;
    heroPanelContent.style.transform = 'translateX(' + lerp(-40, 0, contentP) + 'px)';
    heroPanelContent.style.pointerEvents = contentP > 0.5 ? 'auto' : 'none';

    var labelOpacity = (1 - Math.min(1, ep / 0.3)) * (1 - epB);
    heroZoomLabel.style.opacity = labelOpacity;
    heroZoomLabel.style.pointerEvents = labelOpacity > 0.5 ? 'auto' : 'none';

    heroPhoto.style.opacity = String(1 - epB);
    bubbleField.style.opacity = String(1 - epB);

    heroRunway.style.opacity = String(epB);
    heroRunway.style.pointerEvents = epB > 0.5 ? 'auto' : 'none';

    if (rtrack) {
      var max = Math.max(0, rtrack.scrollWidth - vw + 240);
      rtrack.style.transform = 'translateX(' + (-pC * max) + 'px)';
    }
    if (progressFill) progressFill.style.width = (pC * 100) + '%';
    if (kmtrack) {
      var scrollTop = document.documentElement.scrollTop || document.body.scrollTop || window.scrollY;
      kmtrack.style.transform = 'translateX(' + (-(scrollTop * 0.25) % 600) + 'px)';
    }
  }

  // NOTE: this theme scrolls on <body>, not <window> — 'scroll' events on window alone
  // never fire here. Listen on both so this keeps working if that ever changes.
  document.body.addEventListener('scroll', onHeroScroll, { passive: true });
  window.addEventListener('scroll', onHeroScroll, { passive: true });
  window.addEventListener('resize', onHeroScroll);
  onHeroScroll();
})();
</script>

<!-- MARQUEE -->
<script>
(function(){
const cv=document.getElementById('psMascotCanvas');
if(!cv)return;
const ctx=cv.getContext('2d');
let W,H,dpr;

function resize(){
  dpr=window.devicePixelRatio||1;
  W=cv.offsetWidth; H=cv.offsetHeight;
  cv.width=W*dpr; cv.height=H*dpr;
  ctx.scale(dpr,dpr);
}
resize();
window.addEventListener('resize',()=>{ resize(); if(phase>=4) skipTo(); });

const lerp=(a,b,t)=>a+(b-a)*Math.max(0,Math.min(1,t));
const easeOut=(t)=>1-(1-t)**3;
const rnd=(a,b)=>a+(b-a)*Math.random();
const PURPLE={r:188,g:105,b:235};

let phase=0,pT=0,bobT=0,faceFill=0,mascotY=0;
let hicS=0,hicT=0,hicMouth='smile',hicBlush=1,hicEye='normal';
let burps=[],all=[],last=0,rafId;
let scrollV=0,lastScrollY=0,scrollIdle=0,scrollTriggered=false,scrollSpinAngle=0,scrollSpinV=0;

const MCX=()=>W*.76;
const MCY=()=>H*.52;

const SLOTS=[
  {key:'body',dx:0,   dy:0,  r:50,depth:.5},
  {key:'armL',dx:-56, dy:-5, r:9, depth:.48},
  {key:'armR',dx:57,  dy:-5, r:9, depth:.52},
  {key:'legL',dx:-19, dy:57, r:9, depth:.49},
  {key:'legR',dx:20,  dy:57, r:9, depth:.51},
];

class B{
  constructor(x,y,r,slot,depth){
    this.x=x;this.y=y;this.r=r;
    this.vx=rnd(-.85,.85);this.vy=rnd(-.85,.85);
    this.slot=slot;this.depth=depth||rnd(.1,.9);
    this.fill=0;this.attached=false;this.attachT=0;
    this.wobble=0;
    this.op=slot?rnd(.6,.85):rnd(.2,.5);
    this.drift={ax:rnd(-.003,.003),ay:rnd(-.003,.003)};
  }
  get tx(){return this.slot?MCX()+this.slot.dx:null}
  get ty(){return this.slot?MCY()+this.slot.dy+mascotY:null}
}

function mkBubbles(){
  all=[];
  SLOTS.forEach(s=>{
    all.push(new B(rnd(W*.42,W*.96),rnd(H*.08,H*.92),s.r,s,s.depth));
  });
  [38,28,22,18,32,16,24,14,20,30,12,26,16,22,18,10,34].forEach(r=>{
    all.push(new B(rnd(r,W-r),rnd(r,H-r),r,null,rnd(.05,.95)));
  });
}

function collide(){
  for(let i=0;i<all.length;i++) for(let j=i+1;j<all.length;j++){
    const a=all[i],b=all[j];
    const dx=b.x-a.x,dy=b.y-a.y,d=Math.sqrt(dx*dx+dy*dy),mn=a.r+b.r+2;
    if(d<mn&&d>.01){
      const nx=dx/d,ny=dy/d,ov=(mn-d)*.5;
      const aPin=a.attachT>.1, bPin=b.attachT>.1;
      if(!aPin){a.x-=nx*ov*(bPin?.15:1);a.y-=ny*ov*(bPin?.15:1);}
      if(!bPin){b.x+=nx*ov*(aPin?.15:1);b.y+=ny*ov*(aPin?.15:1);}
      const rv=(a.vx-b.vx)*nx+(a.vy-b.vy)*ny;
      if(rv>0){
        const imp=rv*.3;
        if(!aPin){a.vx-=imp*nx;a.vy-=imp*ny;}
        if(!bPin){b.vx+=imp*nx;b.vy+=imp*ny;}
        a.wobble+=(Math.random()-.5)*.18;b.wobble+=(Math.random()-.5)*.18;
      }
    }
  }
}

function wall(b){
  if(b.attached)return;
  if(b.x<b.r){b.x=b.r;b.vx=Math.abs(b.vx)*.6;}
  if(b.x>W-b.r){b.x=W-b.r;b.vx=-Math.abs(b.vx)*.6;}
  if(b.y<b.r){b.y=b.r;b.vy=Math.abs(b.vy)*.6;}
  if(b.y>H-b.r){b.y=H-b.r;b.vy=-Math.abs(b.vy)*.6;}
}

function freeDrift(b,spd){
  b.vx+=b.drift.ax*spd;b.vy+=b.drift.ay*spd;b.vx*=.997;b.vy*=.997;
  b.x+=b.vx*spd;b.y+=b.vy*spd;wall(b);
}

function update(dt){
  pT+=dt;
  if(phase===0){
    all.forEach(b=>freeDrift(b,1));
    collide();
    if(pT>4.5){phase=1;pT=0;}
  }
  else if(phase===1){
    const prog=Math.min(pT/7,1);
    all.forEach(b=>{
      if(b.slot){
        const dx=b.tx-b.x,dy=b.ty-b.y,d=Math.sqrt(dx*dx+dy*dy);
        const zone=b.r*3.2;
        const pull=.0003+prog*.005;
        b.vx+=dx*pull+b.drift.ax*.6;
        b.vy+=dy*pull+b.drift.ay*.6;
        if(d<zone&&!b.attached){
          b.vx*=.6;b.vy*=.6;
          b.attachT+=dt;
          if(b.attachT>.18){b.attached=true;}
        }
        if(b.attachT>.0){
          const snap=Math.min(b.attachT*1.2,.35);
          b.x=lerp(b.x,b.tx,snap);b.y=lerp(b.y,b.ty,snap);
        } else {
          b.vx*=.98;b.vy*=.98;b.x+=b.vx;b.y+=b.vy;wall(b);
        }
      } else {freeDrift(b,1);}
      b.wobble*=.88;
    });
    collide();
    const allIn=all.filter(b=>b.slot).every(b=>b.attached);
    if((allIn&&pT>3)||pT>11){
      all.filter(b=>b.slot&&!b.attached).forEach(b=>{b.attached=true;b.attachT=1;});
      phase=2;pT=0;
    }
  }
  else if(phase===2){
    const t=Math.min(pT/1.8,1);
    all.forEach(b=>{
      if(b.slot){b.fill=easeOut(t);b.x=lerp(b.x,b.tx,.2);b.y=lerp(b.y,b.ty,.2);}
      else freeDrift(b,1);
    });
    if(t>=1){phase=3;pT=0;}
  }
  else if(phase===3){
    faceFill=Math.min(pT/.9,1);
    mascotY=-Math.sin(Math.min(pT/.95,1)*Math.PI)*10;
    all.forEach(b=>{if(b.slot){b.x=lerp(b.x,b.tx,.25);b.y=lerp(b.y,b.ty,.25);b.fill=1;}});
    if(pT>.9){phase=4;pT=0;window.psMascotFormed=true;scheduleHic();}
  }
  else if(phase===4){
    bobT+=dt*1.05;
    mascotY=Math.sin(bobT)*7;
    scrollIdle+=dt;
    if(scrollIdle>1.8)scrollTriggered=false;
    scrollSpinV*=.88; scrollSpinAngle+=scrollSpinV;
    all.forEach(b=>{
      if(b.slot){
        b.x=lerp(b.x,b.tx+Math.sin(bobT*(b.depth+.3))*(b.r*.1),.2);
        b.y=lerp(b.y,b.ty,.2);
        b.wobble=b.slot.key==='body'
          ? Math.sin(bobT)*.025+scrollSpinAngle
          : Math.sin(bobT*(b.slot.key==='armL'?.9:1.1))*.04+scrollSpinAngle;
        b.fill=1;
      } else {
        const spd=lerp(1.6,.5,b.depth);
        freeDrift(b,spd);
        b.wobble*=.9;
      }
    });
    if(hicS>0)tickHic(dt);
    burps.forEach(b=>{b.y-=1.7+b.s*.5;b.r+=.28;b.a-=.014;});
    burps=burps.filter(b=>b.a>0);
    faceFill=1;
  }
}

function drawBub(b){
  const f=b.fill;
  const alpha=b.op*(b.slot&&phase>=2?(1-f*.6):1);
  if(alpha<.02)return;
  ctx.save();ctx.globalAlpha=alpha;
  ctx.translate(b.x,b.y);if(b.wobble)ctx.rotate(b.wobble);
  ctx.beginPath();ctx.arc(0,0,b.r,0,Math.PI*2);
  if(f>0&&b.slot){
    const ri=lerp(255,PURPLE.r,f),gi=lerp(255,PURPLE.g,f),bi=lerp(255,PURPLE.b,f);
    ctx.fillStyle=`rgba(${Math.round(ri)},${Math.round(gi)},${Math.round(bi)},${lerp(.07,.88,f)})`;
  } else {
    ctx.fillStyle=`rgba(255,255,255,${lerp(.04,.12,b.depth)})`;
  }
  ctx.fill();
  ctx.strokeStyle=`rgba(255,255,255,${f>0?lerp(.18,.36,f):lerp(.1,.24,b.depth)})`;
  ctx.lineWidth=1.8;ctx.stroke();
  if(f>.2&&b.slot){
    ctx.beginPath();ctx.ellipse(-b.r*.28,-b.r*.28,b.r*.3,b.r*.19,-.35,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,255,255,${f*.42})`;ctx.fill();
  }
  if(f<.1&&b.r>12){
    ctx.beginPath();ctx.ellipse(-b.r*.3,-b.r*.3,b.r*.26,b.r*.15,-.3,0,Math.PI*2);
    ctx.fillStyle=`rgba(255,255,255,${b.op*.32})`;ctx.fill();
  }
  ctx.restore();
}

function drawFace(cx,cy){
  if(faceFill<=0)return;
  ctx.save();ctx.globalAlpha=faceFill;
  const ey=cy-7;
  const ew=hicEye==='wide'?12:10,eh=hicEye==='wide'?14:11.5;
  [cx-16,cx+16].forEach(ex=>{
    ctx.beginPath();ctx.ellipse(ex,ey,ew,eh,0,0,Math.PI*2);ctx.fillStyle='white';ctx.fill();
    ctx.beginPath();ctx.arc(ex+1.5,ey+1,6,0,Math.PI*2);ctx.fillStyle='#1e0838';ctx.fill();
    ctx.beginPath();ctx.arc(ex+3,ey-.5,2.2,0,Math.PI*2);ctx.fillStyle='white';ctx.fill();
    ctx.beginPath();ctx.arc(ex-1,ey+3.5,1.2,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,.5)';ctx.fill();
  });
  const br=hicBlush>1?13:9.5;
  ctx.beginPath();ctx.ellipse(cx-22,cy+9,br,6.5,0,0,Math.PI*2);ctx.fillStyle='rgba(255,130,165,.5)';ctx.fill();
  ctx.beginPath();ctx.ellipse(cx+22,cy+9,br,6.5,0,0,Math.PI*2);ctx.fillStyle='rgba(255,130,165,.5)';ctx.fill();
  ctx.beginPath();
  if(hicMouth==='smile'){ctx.moveTo(cx-13,cy+14);ctx.quadraticCurveTo(cx,cy+25,cx+13,cy+14);}
  else if(hicMouth==='open'){ctx.moveTo(cx-13,cy+12);ctx.quadraticCurveTo(cx,cy+28,cx+13,cy+12);}
  else if(hicMouth==='wide'){ctx.moveTo(cx-15,cy+11);ctx.quadraticCurveTo(cx,cy+30,cx+15,cy+11);}
  else{ctx.moveTo(cx-11,cy+20);ctx.quadraticCurveTo(cx,cy+13,cx+11,cy+20);}
  ctx.strokeStyle='#1e0838';ctx.lineWidth=2.8;ctx.lineCap='round';ctx.stroke();
  ctx.beginPath();ctx.arc(cx-26,cy-14,3.5,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,.22)';ctx.fill();
  ctx.restore();
}

function tickHic(dt){
  hicT+=dt;
  if(hicS===1){mascotY=-15;if(hicT>.22){hicS=2;hicT=0;hicMouth='open';hicEye='wide';}}
  else if(hicS===2){
    mascotY=20+Math.sin(hicT*7)*5;
    if(hicT>.78){
      hicS=3;hicT=0;hicMouth='wide';
      const body=all.find(b=>b.slot?.key==='body');
      if(body){for(let i=0;i<4;i++)burps.push({x:body.x+rnd(-10,10),y:body.y-body.r-5,r:rnd(5,13),a:1,s:Math.random()});}
    }
  }
  else if(hicS===3){mascotY=lerp(20,0,hicT/.5);if(hicT>.5){hicS=4;hicT=0;hicMouth='embarrassed';hicBlush=2;}}
  else if(hicS===4){if(hicT>1.5){hicS=0;hicT=0;hicMouth='smile';hicBlush=1;hicEye='normal';scheduleHic();}}
}

function scheduleHic(){
  setTimeout(()=>{if(phase===4&&hicS===0){hicS=1;hicT=0;hicMouth='line';hicEye='wide';}},rnd(18000,30000));
}

function skipTo(){
  phase=4;pT=0;faceFill=1;bobT=0;mascotY=0;hicS=0;hicT=0;hicMouth='smile';hicBlush=1;hicEye='normal';burps=[];
  all.forEach(b=>{if(b.slot){b.fill=1;b.attached=true;b.x=b.tx;b.y=b.ty;b.vx=0;b.vy=0;}});
  scheduleHic();
}

const scrollEl=document.body;
scrollEl.addEventListener('scroll',()=>{
  const sy=scrollEl.scrollTop;
  scrollV=sy-lastScrollY; lastScrollY=sy; scrollIdle=0;
  if(phase===4&&hicS===0){
    scrollSpinV+=(scrollV>0?.18:-.18)*Math.min(Math.abs(scrollV)*.04,1.2);
    scrollTriggered=true;
  }
},{passive:true});

function render(){
  ctx.clearRect(0,0,W,H);
  const bg=all.filter(b=>!b.slot&&b.depth<.5).sort((a,b2)=>b2.depth-a.depth);
  const fg=all.filter(b=>!b.slot&&b.depth>=.5).sort((a,b2)=>a.depth-b2.depth);
  const slotBubs=all.filter(b=>b.slot).sort((a,b2)=>a.depth-b2.depth);
  bg.forEach(b=>drawBub(b));
  slotBubs.forEach(b=>drawBub(b));
  const body=all.find(b=>b.slot?.key==='body');
  if(body)drawFace(body.x,body.y);
  burps.forEach(b=>{
    ctx.save();ctx.globalAlpha=b.a;
    ctx.beginPath();ctx.arc(b.x,b.y,b.r,0,Math.PI*2);
    ctx.fillStyle='rgba(190,150,255,.1)';ctx.fill();
    ctx.strokeStyle='rgba(200,165,255,.65)';ctx.lineWidth=1.6;ctx.stroke();
    ctx.beginPath();ctx.ellipse(b.x-b.r*.28,b.y-b.r*.28,b.r*.3,b.r*.18,0,0,Math.PI*2);
    ctx.fillStyle='rgba(255,255,255,.38)';ctx.fill();
    ctx.restore();
  });
  fg.forEach(b=>drawBub(b));
}

function tick(now){
  const dt=Math.min((now-last)/1000,.05);last=now;
  update(dt);render();
  rafId=requestAnimationFrame(tick);
}

function init(){
  resize();
  mkBubbles();
  last=performance.now();
  requestAnimationFrame(tick);
}
if(document.readyState==='complete'){ init(); }
else{ window.addEventListener('load', init); }
})();
</script>

