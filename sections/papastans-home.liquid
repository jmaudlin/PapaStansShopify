  </div>
  <div class="ps-cart-foot" id="psCartFoot" style="display:none">
    <div class="ps-ship-bar-wrap">
      <div class="ps-ship-bar-msg" id="psShipMsg"></div>
      <div class="ps-ship-bar-bg"><div class="ps-ship-bar-fill" id="psShipFill"></div></div>
    </div>
    <div class="ps-cart-subtotal">
      <span>Subtotal</span>
      <span id="psCartTotal">$0.00</span>
    </div>
    <a href="/checkout" class="ps-cart-checkout" id="psCheckoutBtn">Checkout Now! →</a>
    <p class="ps-cart-note">Secure checkout powered by <strong>Shopify</strong> 🔒</p>
  </div>
</div>

<div id="psToast"></div>

<script>
// ═══════════════════════════════════════════════════════════
//  Papa Stan's — Shopify AJAX Cart API (same-origin, no CORS)
//  Docs: https://shopify.dev/docs/api/ajax/reference/cart
// ═══════════════════════════════════════════════════════════

const PS_FREE_SHIP_CENTS = 5500; // $55.00 in cents

// ── Add to cart ──
async function psAddToCart(variantId, title) {
  psShowToast('Adding to cart… 🛒');
  try {
    const r = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    });
    if (!r.ok) throw new Error('Add failed');
    await psRefreshCart();
    psShowToast('✅ ' + title + ' added!');
    psBumpPill();
    psOpenCart();
  } catch(e) {
    psShowToast('Something went wrong, please try again.');
    console.error(e);
  }
}

// ── Update quantity ──
async function psUpdateQty(lineIndex, qty) {
  try {
    const updates = {};
    updates[lineIndex] = qty;
    await fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ updates })
    });
    await psRefreshCart();
  } catch(e) { console.error(e); }
}

// ── Remove line ──
async function psRemoveLine(lineIndex) {
  await psUpdateQty(lineIndex, 0);
}

// ── Fetch and render cart ──
async function psRefreshCart() {
  try {
    const r = await fetch('/cart.js', { headers: { 'Accept': 'application/json' } });
    const cart = await r.json();
    psRenderCart(cart);
    psUpdateCount(cart.item_count);
  } catch(e) { console.error(e); }
}

function psRenderCart(cart) {
  const itemsEl = document.getElementById('psCartItems');
  const footEl  = document.getElementById('psCartFoot');

  if (!cart.items || cart.items.length === 0) {
    itemsEl.innerHTML = '<p class="ps-cart-empty">Your cart is empty!<br>Go find something wonderful 🌿</p>';
    footEl.style.display = 'none';
    return;
  }

  footEl.style.display = 'block';
  itemsEl.innerHTML = cart.items.map((item, i) => `
    <div class="ps-cart-item">
      <img class="ps-ci-img"
        src="${item.image ? item.image.replace('http:', 'https:') : ''}"
        alt="${item.title}"
        onerror="this.style.visibility='hidden'">
      <div>
        <div class="ps-ci-name">${item.product_title}</div>
        <div class="ps-ci-price">${psMoney(item.price)}</div>
        <div class="ps-ci-qty">
          <button onclick="psUpdateQty(${item.key ? "'" + item.key + "'" : i+1}, ${item.quantity - 1})">−</button>
          <span>${item.quantity}</span>
          <button onclick="psUpdateQty(${item.key ? "'" + item.key + "'" : i+1}, ${item.quantity + 1})">+</button>
        </div>
      </div>
      <button class="ps-ci-remove" onclick="psRemoveLine(${item.key ? "'" + item.key + "'" : i+1})">✕</button>
    </div>`).join('');

  // Subtotal
  document.getElementById('psCartTotal').textContent = psMoney(cart.total_price);

  // Free shipping bar
  const pct = Math.min((cart.total_price / PS_FREE_SHIP_CENTS) * 100, 100);
  document.getElementById('psShipFill').style.width = pct + '%';
  const remaining = psMoney(Math.max(PS_FREE_SHIP_CENTS - cart.total_price, 0));
  document.getElementById('psShipMsg').innerHTML = cart.total_price >= PS_FREE_SHIP_CENTS
    ? '<strong>🎉 You unlocked FREE shipping!</strong>'
    : `Add <strong>${remaining} more</strong> for free shipping 🚚`;
}

function psMoney(cents) {
  return '$' + (cents / 100).toFixed(2);
}

function psUpdateCount(count) {
  document.getElementById('psCartCount').textContent = count || 0;
}

function psBumpPill() {
  const p = document.querySelector('.ps-cart-pill');
  p.classList.remove('ps-bump'); void p.offsetWidth; p.classList.add('ps-bump');
}

function psOpenCart() {
  psRefreshCart();
  document.getElementById('psCartDrawer').classList.add('open');
  document.getElementById('psCartOverlay').classList.add('open');
}

function psCloseCart() {
  document.getElementById('psCartDrawer').classList.remove('open');
  document.getElementById('psCartOverlay').classList.remove('open');
}

// ── Parallax ──
const psHeroBgEl   = document.getElementById('psHeroBg');
const psScentsBgEl = document.getElementById('psScentsBg');
const psHeroArtEl  = document.getElementById('psHeroArt');

function psRatio(el) {
  const r = el.getBoundingClientRect();
  return (window.innerHeight - r.top) / (window.innerHeight + r.height);
}

function psOnScroll() {
  const sy = window.scrollY;
  if (psHeroBgEl)   psHeroBgEl.style.transform   = `translateY(${sy * 0.45}px)`;
  if (psHeroArtEl)  psHeroArtEl.style.transform   = `translateY(${sy * 0.25}px) scaleX(-1)`;
  if (psScentsBgEl) psScentsBgEl.style.transform  = `translateY(${(psRatio(psScentsBgEl.parentElement) - .5) * -80}px)`;
  document.getElementById('psNav').classList.toggle('scrolled', sy > 50);
}
window.addEventListener('scroll', psOnScroll, { passive: true });
psOnScroll();

// ── Reveal on scroll ──
const psRevObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); psRevObs.unobserve(e.target); }
  });
}, { threshold: 0.08 });
document.querySelectorAll('.ps-reveal').forEach(el => psRevObs.observe(el));

// ── Category filter (client-side, products already rendered) ──
document.getElementById('psCatTabs').addEventListener('click', e => {
  const tab = e.target.closest('.ps-cat-tab');
  if (!tab) return;
  document.querySelectorAll('.ps-cat-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active');
  const cat = tab.dataset.cat;
  document.querySelectorAll('.ps-pc').forEach(card => {
    card.style.display = (cat === 'all' || card.dataset.cat === cat) ? 'flex' : 'none';
  });
});

// ── Toast ──
let psToastTimer;
function psShowToast(msg) {
  const t = document.getElementById('psToast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(psToastTimer);
  psToastTimer = setTimeout(() => t.classList.remove('show'), 2800);
}

// ── Smooth anchors ──
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const el = document.querySelector(a.getAttribute('href'));
    if (el) { e.preventDefault(); el.scrollIntoView({ behavior: 'smooth' }); }
  });
});

// ── Load cart count on page load ──
psRefreshCart();
</script>

