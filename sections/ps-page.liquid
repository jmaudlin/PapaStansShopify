{% render 'ps-header', nav_solid: true %}

<div class="ps-page-wrap">

  {%- assign is_shipping  = false -%}
  {%- assign is_returns   = false -%}
  {%- assign is_privacy   = false -%}
  {%- assign is_tos       = false -%}
  {%- if page.handle == 'shipping' or page.handle == 'shipping-policy' -%}{%- assign is_shipping = true -%}{%- endif -%}
  {%- if page.handle == 'returns' or page.handle == 'returns-refunds' or page.handle == 'refund-policy' -%}{%- assign is_returns = true -%}{%- endif -%}
  {%- if page.handle == 'privacy-policy' or page.handle == 'privacy' -%}{%- assign is_privacy = true -%}{%- endif -%}
  {%- if page.handle == 'terms-of-service' or page.handle == 'terms' -%}{%- assign is_tos = true -%}{%- endif -%}
  {%- assign is_policy = false -%}
  {%- if is_shipping or is_returns or is_privacy or is_tos -%}{%- assign is_policy = true -%}{%- endif -%}

  {%- if page.handle == 'contact' -%}

    <div class="ps-contact-grid">

      <!-- LEFT: Contact Form -->
      <div class="ps-contact-form-col">
        <div class="ps-section-tag" style="margin-bottom:.8rem">✉️ Get in Touch</div>
        <h1 class="ps-section-h2" style="margin-bottom:.5rem">Contact <em>Us!</em></h1>
        <p style="font-family:'Caveat',cursive;font-size:1.15rem;color:var(--lav-ink);margin-bottom:2rem;">
          Questions about products, custom orders, wholesale, local pickup — we'd love to hear from you!
        </p>

        {%- form 'contact', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="ps-form-success">
              🎉 Thanks for reaching out! We'll get back to you within 1–2 business days.
            </div>
          {%- endif -%}

          <div class="ps-form-row">
            <div class="ps-form-group">
              <label class="ps-form-label" for="ContactForm-name">Your Name</label>
              <input type="text" id="ContactForm-name" name="contact[name]" class="ps-form-input" placeholder="Jane Smith" value="{{ form.name }}" autocomplete="name">
            </div>
            <div class="ps-form-group">
              <label class="ps-form-label" for="ContactForm-email">Email <span class="ps-required">*</span></label>
              <input type="email" id="ContactForm-email" name="contact[email]" class="ps-form-input" placeholder="jane@example.com" value="{{ form.email }}" autocomplete="email" required>
            </div>
          </div>

          <div class="ps-form-group">
            <label class="ps-form-label" for="ContactForm-phone">Phone (optional)</label>
            <input type="tel" id="ContactForm-phone" name="contact[phone]" class="ps-form-input" placeholder="641-555-0123" value="{{ form.phone }}" autocomplete="tel">
          </div>

          <div class="ps-form-group">
            <label class="ps-form-label" for="ContactForm-subject">Subject</label>
            <select id="ContactForm-subject" name="contact[subject]" class="ps-form-input">
              <option value="">— Select a topic —</option>
              <option value="Product Question">Product Question</option>
              <option value="Order Status">Order Status</option>
              <option value="Custom / Wholesale Order">Custom / Wholesale Order</option>
              <option value="Local Pickup">Local Pickup</option>
              <option value="General Inquiry">General Inquiry</option>
            </select>
          </div>

          <div class="ps-form-group">
            <label class="ps-form-label" for="ContactForm-body">Message <span class="ps-required">*</span></label>
            <textarea id="ContactForm-body" name="contact[body]" class="ps-form-input ps-form-textarea" placeholder="Tell us how we can help..." required>{{ form.body }}</textarea>
          </div>

          <button type="submit" class="ps-btn-primary" style="width:100%;text-align:center;">Send Message 💌</button>
        {%- endform -%}
      </div>

      <!-- RIGHT: Info sidebar -->
      <div class="ps-contact-info-col">

        <div class="ps-contact-info-card">
          <h3 class="ps-contact-info-title">📍 Our Location</h3>
          <p class="ps-contact-info-addr">
            {{ shop.address.address1 }}<br>
            {{ shop.address.city }}, {{ shop.address.province_code }} {{ shop.address.zip }}<br>
            {{ shop.address.country }}
          </p>
          <a href="https://maps.google.com/?q={{ shop.address.address1 | append: ', ' | append: shop.address.city | append: ', ' | append: shop.address.province_code | url_encode }}" target="_blank" class="ps-contact-map-link">Get Directions →</a>
          <div class="ps-contact-map">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d24530!2d-92.6438!3d41.2959!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87ee4e3ec5fca9a5%3A0xabcdef123456!2sOskaloosa%2C+IA+52577!5e0!3m2!1sen!2sus!4v1"
              allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

        <div class="ps-contact-info-card">
          <h3 class="ps-contact-info-title">📞 Reach Us Directly</h3>
          <div class="ps-contact-info-row"><span>Phone</span><a href="tel:{{ shop.phone }}">{{ shop.phone | default: '641.670.1573' }}</a></div>
          <div class="ps-contact-info-row"><span>Email</span><a href="mailto:{{ shop.email }}">{{ shop.email }}</a></div>
          <div class="ps-contact-info-row"><span>Response</span><span>1–2 business days</span></div>
        </div>

        <div class="ps-contact-info-card">
          <h3 class="ps-contact-info-title">🌿 Follow Along</h3>
          <div class="ps-contact-socials">
            <a href="https://facebook.com/PapaStansSoaps" target="_blank" class="ps-contact-social-btn">
              <strong>f</strong> PapaStansSoaps
            </a>
            <a href="https://instagram.com/PapaStansSoaps" target="_blank" class="ps-contact-social-btn">
              <strong>ig</strong> PapaStansSoaps
            </a>
          </div>
        </div>

      </div>
    </div>

  {%- elsif is_policy -%}

    {%- if is_shipping -%}
      {%- assign policy_obj = shop.shipping_policy -%}
      {%- assign policy_icon = '🚚' -%}
      {%- assign policy_tag  = 'Shipping Info' -%}
    {%- elsif is_returns -%}
      {%- assign policy_obj = shop.refund_policy -%}
      {%- assign policy_icon = '↩️' -%}
      {%- assign policy_tag  = 'Returns & Refunds' -%}
    {%- elsif is_privacy -%}
      {%- assign policy_obj = shop.privacy_policy -%}
      {%- assign policy_icon = '🔒' -%}
      {%- assign policy_tag  = 'Privacy Policy' -%}
    {%- elsif is_tos -%}
      {%- assign policy_obj = shop.terms_of_service -%}
      {%- assign policy_icon = '📋' -%}
      {%- assign policy_tag  = 'Terms of Service' -%}
    {%- endif -%}

    <div class="ps-policy-header">
      <div class="ps-section-tag" style="margin-bottom:.8rem">{{ policy_icon }} {{ policy_tag }}</div>
      <h1 class="ps-section-h2">{{ policy_obj.title }}</h1>
      <p class="ps-policy-updated">Last updated: {{ policy_obj.updated_at | date: "%B %d, %Y" }}</p>
    </div>

    <div class="ps-policy-grid">
      <div class="ps-policy-content rte">
        {{ policy_obj.body }}
      </div>
      <div class="ps-policy-sidebar">
        <div class="ps-policy-sidebar-card">
          <h4 class="ps-policy-sidebar-title">📋 All Policies</h4>
          <ul class="ps-policy-links">
            <li><a href="{{ shop.url }}/pages/shipping" {% if is_shipping %}class="ps-policy-link-active"{% endif %}>🚚 Shipping Info</a></li>
            <li><a href="{{ shop.url }}/pages/returns" {% if is_returns %}class="ps-policy-link-active"{% endif %}>↩️ Returns &amp; Refunds</a></li>
            <li><a href="{{ shop.url }}/pages/privacy-policy" {% if is_privacy %}class="ps-policy-link-active"{% endif %}>🔒 Privacy Policy</a></li>
            <li><a href="{{ shop.url }}/pages/terms-of-service" {% if is_tos %}class="ps-policy-link-active"{% endif %}>📋 Terms of Service</a></li>
          </ul>
        </div>
        <div class="ps-policy-sidebar-card">
          <h4 class="ps-policy-sidebar-title">💬 Questions?</h4>
          <p class="ps-policy-sidebar-body">Have a question about our policies? We're happy to help!</p>
          <a href="{{ shop.url }}/pages/contact" class="ps-btn-primary" style="display:block;text-align:center;margin-top:1rem;">Contact Us</a>
          <div class="ps-policy-contact-row"><a href="tel:{{ shop.phone }}">📞 {{ shop.phone | default: '641.670.1573' }}</a></div>
        </div>
        <a href="{{ shop.url }}/collections/all" class="ps-btn-secondary" style="display:block;text-align:center;">← Back to Shop</a>
      </div>
    </div>

  {%- elsif page.handle == 'find-us' -%}

    {%- assign map_addr = shop.address.address1 | append: ', ' | append: shop.address.city | append: ', ' | append: shop.address.province_code | append: ' ' | append: shop.address.zip | url_encode -%}

    <div class="ps-section-tag" style="margin-bottom:.8rem">📍 Find Us</div>
    <h1 class="ps-section-h2" style="margin-bottom:2rem">Where to <em>Find Us!</em></h1>

    <div class="ps-findus-grid">

      <!-- Map -->
      <div class="ps-findus-map-col">
        <div class="ps-contact-info-card ps-findus-map-card">
          <iframe
            src="https://maps.google.com/maps?q={{ map_addr }}&output=embed&z=16"
            class="ps-findus-map"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
          <a href="https://maps.google.com/?q={{ map_addr }}" target="_blank" class="ps-contact-map-link" style="display:inline-block;margin-top:.75rem">Get Directions →</a>
        </div>
      </div>

      <!-- Details -->
      <div class="ps-findus-info-col">

        <div class="ps-contact-info-card">
          <h3 class="ps-contact-info-title">🏠 Our Location</h3>
          <p class="ps-contact-info-addr">
            {{ shop.address.address1 }}<br>
            {{ shop.address.city }}, {{ shop.address.province_code }} {{ shop.address.zip }}<br>
            {{ shop.address.country }}
          </p>
        </div>

        <div class="ps-contact-info-card">
          <h3 class="ps-contact-info-title">📞 Reach Us Directly</h3>
          <div class="ps-contact-info-row"><span>Phone</span><a href="tel:{{ shop.phone }}">{{ shop.phone | default: '641.670.1573' }}</a></div>
          <div class="ps-contact-info-row"><span>Email</span><a href="mailto:{{ shop.email }}">{{ shop.email }}</a></div>
        </div>

        <div class="ps-contact-info-card">
          <h3 class="ps-contact-info-title">🚚 Shipping & Perks</h3>
          <div class="ps-contact-info-row"><span>Free Shipping</span><span>Orders $55+</span></div>
          <div class="ps-contact-info-row"><span>Free Samples</span><span>4 with every order</span></div>
          <div class="ps-contact-info-row"><span>Est.</span><span>2019 — Oskaloosa, Iowa</span></div>
          <div class="ps-contact-info-row"><span>Ownership</span><span>Veteran-Owned ⭐</span></div>
        </div>

        <a href="{{ shop.url }}/collections/all" class="ps-btn-primary" style="display:block;text-align:center;">Shop Now 🛒</a>

      </div>
    </div>

    <style>
      .ps-findus-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; align-items:start; }
      .ps-findus-map-card { padding:0; overflow:hidden; }
      .ps-findus-map-card a { padding:0 1.25rem 1rem; }
      .ps-findus-map { width:100%; height:340px; border:none; display:block; }
      @media (max-width:860px) { .ps-findus-grid { grid-template-columns:1fr; } .ps-findus-map { height:260px; } }
    </style>

  {%- else -%}

    <!-- Generic page template -->
    <h1 class="ps-section-h2" style="margin-bottom:2rem">{{ page.title }}</h1>
    <div class="ps-page-content">{{ page.content }}</div>
    {% content_for 'blocks' %}

  {%- endif -%}

</div>

{% render 'ps-footer' %}
{% schema %}{ "name": "Page", "settings": [], "blocks": [{ "type": "@app" }], "presets": [{ "name": "Page" }] }{% endschema %}
