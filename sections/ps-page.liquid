    <li><a href="{{ shop.url }}/blogs/news">Blog</a></li>
    <li><a href="{{ shop.url }}/#ps-about">Our Story</a></li>
    <li><a href="{{ shop.url }}/#ps-find-us">Find Us</a></li>
  </ul>
  <div class="ps-nav-actions">
