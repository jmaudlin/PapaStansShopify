{% render 'ps-account-nav' %}

<div class="ps-page-wrap ps-account-wrap">
  <div class="ps-account-card">
    <div class="ps-section-tag" style="margin:0 auto .8rem;width:fit-content">🌿 Activate Account</div>
    <h1 class="ps-account-title">Activate Your Account</h1>
    <p class="ps-account-sub">Create a password to activate your Papa Stan's account.</p>

    {%- form 'activate_customer_password' -%}
      {%- if form.errors -%}<div class="ps-form-error">{{ form.errors | default_errors }}</div>{%- endif -%}

      <div class="ps-form-group">
        <label class="ps-form-label" for="ActivatePassword">Password <span class="ps-required">*</span></label>
        <input type="password" id="ActivatePassword" name="customer[password]" class="ps-form-input"
          placeholder="Min. 6 characters" autocomplete="new-password" required
          {% if form.errors contains 'password' %}autofocus{% endif %}>
      </div>
      <div class="ps-form-group">
        <label class="ps-form-label" for="ActivatePasswordConfirm">Confirm Password <span class="ps-required">*</span></label>
        <input type="password" id="ActivatePasswordConfirm" name="customer[password_confirmation]" class="ps-form-input"
          placeholder="Re-enter your password" autocomplete="new-password" required>
      </div>
      <button type="submit" class="ps-btn-primary" style="width:100%;text-align:center;">Activate Account 🌿</button>
      <a href="{{ routes.account_login_url }}" style="display:block;text-align:center;margin-top:.8rem;font-size:.82rem;color:var(--lav);text-decoration:none;">Decline &amp; cancel</a>
    {%- endform -%}
  </div>
</div>

<script>
window.addEventListener('scroll', () => document.getElementById('psNav').classList.toggle('scrolled', window.scrollY > 10), { passive: true });
</script>

{% schema %}{"name":"Activate Account","settings":[]}{% endschema %}
