{% render 'ps-account-nav' %}

<div class="ps-page-wrap ps-account-wrap">
  <div class="ps-account-card">
    <div class="ps-section-tag" style="margin:0 auto .8rem;width:fit-content">🌿 Join the Family</div>
    <h1 class="ps-account-title">Create an Account</h1>
    <p class="ps-account-sub">Sign up to track orders, save addresses, and get early access to new scents!</p>

    {%- form 'create_customer', novalidate: 'novalidate' -%}
      {%- if form.errors -%}<div class="ps-form-error">{{ form.errors | default_errors }}</div>{%- endif -%}

      <div class="ps-form-row">
        <div class="ps-form-group">
          <label class="ps-form-label" for="FirstName">First Name</label>
          <input type="text" id="FirstName" name="customer[first_name]" class="ps-form-input"
            placeholder="Jane" value="{{ form.first_name }}" autocomplete="given-name"
            {% if form.errors contains 'first_name' %}autofocus{% endif %}>
        </div>
        <div class="ps-form-group">
          <label class="ps-form-label" for="LastName">Last Name</label>
          <input type="text" id="LastName" name="customer[last_name]" class="ps-form-input"
            placeholder="Smith" value="{{ form.last_name }}" autocomplete="family-name">
        </div>
      </div>

      <div class="ps-form-group">
        <label class="ps-form-label" for="RegisterEmail">Email Address <span class="ps-required">*</span></label>
        <input type="email" id="RegisterEmail" name="customer[email]" class="ps-form-input"
          placeholder="you@example.com" value="{{ form.email }}" autocomplete="email" required
          {% if form.errors contains 'email' %}autofocus{% endif %}>
      </div>

      <div class="ps-form-group">
        <label class="ps-form-label" for="RegisterPassword">Password <span class="ps-required">*</span></label>
        <input type="password" id="RegisterPassword" name="customer[password]" class="ps-form-input"
          placeholder="Min. 6 characters" autocomplete="new-password" required
          {% if form.errors contains 'password' %}autofocus{% endif %}>
      </div>

      <button type="submit" class="ps-btn-primary" style="width:100%;text-align:center;margin-top:.5rem;">Create Account 🌿</button>
    {%- endform -%}

    <div class="ps-account-divider"><span>Already have an account?</span></div>
    <a href="{{ routes.account_login_url }}" class="ps-btn-secondary" style="display:block;text-align:center;">Sign In 🔐</a>
  </div>
</div>

<script>
window.addEventListener('scroll', () => document.getElementById('psNav').classList.toggle('scrolled', window.scrollY > 10), { passive: true });
</script>

{% schema %}{"name":"Register","settings":[]}{% endschema %}
