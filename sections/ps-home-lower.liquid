<!-- NEWSLETTER -->
<section class="ps-newsletter">
  <div class="ps-section-tag ps-reveal" style="margin:0 auto 1rem;background:var(--white);">{{ section.settings.eyebrow }}</div>
  <h2 class="ps-section-h2 ps-light ps-reveal ps-rd1" style="margin-bottom:.8rem">{{ section.settings.heading }}</h2>
  <p class="ps-nl-sub ps-reveal ps-rd2">{{ section.settings.subtext }}</p>
  {%- form 'customer', id: 'ps-newsletter-form' -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="ps-nl-form ps-reveal ps-rd3">
      <input type="email" name="contact[email]" class="ps-nl-input" placeholder="your@email.com" required>
      <button type="submit" class="ps-nl-btn">Subscribe! 🌿</button>
    </div>
  {%- endform -%}
</section>

<!-- FOOTER -->

<script>
// ── Reveal on scroll (lower page) ──
const psRevObsLower = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); psRevObsLower.unobserve(e.target); }
  });
}, { threshold: 0.08 });
document.querySelectorAll('.ps-newsletter .ps-reveal').forEach(el => psRevObsLower.observe(el));
</script>

{%- schema -%}
{
  "name": "Home \u2014 Lower",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter section"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow tag",
      "default": "\ud83d\udcec Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get the Good Stuff First!"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "New scents, seasonal specials, local pop-up events, and exclusive deals!"
    }
  ],
  "presets": [
    {
      "name": "Home \u2014 Lower",
      "category": "Home"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "templates": [
    "index"
  ]
}
{%- endschema -%}
