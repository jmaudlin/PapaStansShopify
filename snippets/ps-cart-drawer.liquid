<div class="ps-cart-overlay" id="psCartOverlay" onclick="psCloseCart()"></div>
<div class="ps-cart-drawer" id="psCartDrawer">
  <div class="ps-cart-head">
    <h3>🛒 Your Cart</h3>
    <button class="ps-cart-close" onclick="psCloseCart()">✕</button>
  </div>
  <div class="ps-cart-items" id="psCartItems">
    <p class="ps-cart-empty">Your cart is empty!<br>Go find something wonderful 🌿</p>
  </div>
  <div class="ps-cart-foot" id="psCartFoot" style="display:none">
    <div class="ps-ship-bar-wrap">
      <div class="ps-ship-bar-msg" id="psShipMsg"></div>
      <div class="ps-ship-bar-bg"><div class="ps-ship-bar-fill" id="psShipFill"></div></div>
    </div>
    <div class="ps-cart-subtotal">
      <span>Subtotal</span>
      <span id="psCartTotal">$0.00</span>
    </div>
    <a href="/checkout" class="ps-cart-checkout">Checkout Now! →</a>
    <p class="ps-cart-note">Secure checkout powered by <strong>Shopify</strong> 🔒</p>
  </div>
</div>
<div id="psToast"></div>
