{%- comment -%}
  ps-testimonials.liquid — Customer reviews carousel powered by Judge.me.

  Reviews are managed entirely through the Judge.me app:
    Admin → Apps → Judge.me Reviews → Reviews (pending/published)

  Stan's workflow:
    1. Customer submits a review (post-purchase email or Write a Review button)
    2. Review appears in Judge.me → Reviews → Pending
    3. Stan approves it → it immediately shows on the product page AND here
    4. No manual copying. One approval = everywhere.

  The jdgm-carousel-widget renders Judge.me's testimonials carousel.
  Carousel settings (# of cards, autoplay, etc.) are configured in:
    Judge.me Admin → Widgets → Testimonials Carousel
{%- endcomment -%}

<section class="ps-testimonials" id="ps-testimonials">
  <div class="ps-testimonials-inner">

    <div class="ps-testimonials-header">
      <div class="ps-section-tag ps-reveal">⭐ Customer Love</div>
      <h2 class="ps-section-h2 ps-reveal ps-rd1">What Our <em>Customers Say!</em></h2>
      <p class="ps-testimonials-sub ps-reveal ps-rd2">Real words from real people who've brought a little Iowa into their homes.</p>
    </div>

    {%- assign jm = shop.metafields.judgeme -%}
    <div class="ps-jdgm-wrap ps-reveal ps-rd2">
      {%- if jm.featured_carousel != blank -%}
        <div class="jdgm-carousel-wrapper">
          <div class="jdgm-carousel-title-and-link">
            <span class="jdgm-all-reviews-rating-wrapper">
              <span style="display:block" data-score="{{ jm.all_reviews_rating }}" class="jdgm-all-reviews-rating" aria-label="{{ jm.all_reviews_rating }} stars" tabindex="0" role="img"></span>
              <span style="display:block" class="jdgm-carousel-number-of-reviews" data-number-of-reviews="{{ jm.all_reviews_count }}">from {{ jm.all_reviews_count }} reviews</span>
            </span>
          </div>
          {{ jm.featured_carousel }}
        </div>
      {%- else -%}
        {%- comment -%} No featured reviews selected yet in Judge.me admin — the
            carousel metafield is empty. Pick featured reviews in
            Judge.me → Reviews to populate this. {%- endcomment -%}
      {%- endif -%}
    </div>

  </div>
</section>

<style>
.ps-testimonials { background: var(--lav-xlight); padding: 6rem 2rem 5rem; }
.ps-testimonials-inner { max-width: 1200px; margin: 0 auto; }
.ps-testimonials-header { text-align: center; margin-bottom: 3rem; }
.ps-testimonials-sub { font-family: 'Caveat', cursive; font-size: 1.2rem; color: var(--lav-ink); max-width: 480px; margin: .75rem auto 0; line-height: 1.5; }
.ps-jdgm-wrap { width: 100%; }

/* Judge.me carousel overrides — targets the REAL rendered classes
   (.jdgm-carousel-item etc. from the featured_carousel metafield markup).
   Section sits on the dark testimonials backdrop on the homepage. */
.ps-testimonials .jdgm-widget { font-family: 'Nunito', 'Nunito-fallback', sans-serif !important; }

/* Header: rating + count, centered and readable on dark */
.ps-testimonials .jdgm-carousel-title-and-link { text-align: center; margin-bottom: 2rem; }
.ps-testimonials .jdgm-all-reviews-rating-wrapper { display: inline-flex; flex-direction: column; align-items: center; gap: .3rem; }
.ps-testimonials .jdgm-carousel-number-of-reviews { color: rgba(255,255,255,.85) !important; font-weight: 700; font-size: .9rem; display: inline-flex; align-items: center; gap: .35rem; }
.ps-testimonials .jdgm-carousel-number-of-reviews svg { width: 15px; height: 15px; }

/* Cards: white, corner-notched like the rest of the homepage cards */
/* Neutralize Judge.me's slider (inline-block track + translate3d) into a
   static centered flex grid — with a handful of reviews there's nothing to
   slide, and their JS positioning fought every layout we gave it. */
.ps-testimonials .jdgm-carousel__item-container { display: block !important; height: auto !important; overflow: visible !important; width: 100% !important; max-width: none !important; }
.ps-testimonials .jdgm-carousel__item-wrapper { display: flex !important; flex-wrap: wrap; justify-content: center; gap: 2.5rem; transform: none !important; font-size: 16px !important; width: 100% !important; }
.ps-testimonials .jdgm-carousel__prev, .ps-testimonials .jdgm-carousel__next { display: none !important; }
.ps-testimonials .jdgm-carousel-item { background: #fff !important; clip-path: polygon(0 0,100% 0,100% 92%,92% 100%,0 100%); border: 2px solid var(--border) !important; border-radius: 0 !important; padding: 2rem 1.8rem 1.6rem !important; margin: 0 !important; display: flex; flex-direction: column; flex: 0 1 320px; width: auto !important; max-width: 360px; position: static !important; transform: none !important; transition: transform .25s ease; }
.ps-testimonials .jdgm-carousel-item:hover { transform: translateY(-4px); }
/* Judge.me fixes items at 200px and line-clamps review text — undo both so
   full reviews show and cards size to content (flex keeps rows equal-height) */
.ps-testimonials .jdgm-carousel-item { height: auto !important; min-height: 200px; }
.ps-testimonials .jdgm-carousel-item .jdgm-line-clamp,
.ps-testimonials .jdgm-carousel-item__review-title,
.ps-testimonials .jdgm-carousel-item__review-body { display: block !important; -webkit-line-clamp: unset !important; -webkit-box-orient: unset !important; overflow: visible !important; max-height: none !important; height: auto !important; white-space: normal !important; text-overflow: unset !important; }

/* Stars */
.ps-testimonials .jdgm-carousel-item .jdgm-star.jdgm--on { color: var(--lav) !important; }
.ps-testimonials .jdgm-carousel-title-and-link .jdgm-star.jdgm--on { color: var(--lav-300, #C8A8E0) !important; }
.ps-testimonials .jdgm-star.jdgm--off { color: rgba(124,77,158,.25) !important; }
.ps-testimonials .jdgm-carousel-item__review-rating { margin-bottom: .7rem; }

/* Review title + body */
.ps-testimonials .jdgm-carousel-item__review-title { font-family: 'Caveat', 'Caveat-fallback', cursive !important; font-size: 1.35rem !important; font-weight: 700 !important; color: var(--lav-ink) !important; margin-bottom: .35rem; }
.ps-testimonials .jdgm-carousel-item__review-body { color: var(--lav-ink) !important; font-size: .95rem !important; line-height: 1.65 !important; font-weight: 600; }

/* Reviewer + timestamp */
.ps-testimonials .jdgm-carousel-item__reviewer-name-wrapper { margin-top: auto; padding-top: 1rem; }
.ps-testimonials .jdgm-carousel-item__reviewer-name { font-weight: 800 !important; color: var(--lav) !important; font-size: .82rem !important; text-transform: uppercase; letter-spacing: .06em; white-space: normal !important; overflow: visible !important; text-overflow: unset !important; line-height: 1.4; }
.ps-testimonials .jdgm-carousel-item__timestamp { color: #8a7f92 !important; font-size: .75rem !important; }

/* Product chip link on shop/product reviews */
.ps-testimonials .jdgm-carousel-item__product { color: var(--lav-dark) !important; font-size: .78rem !important; font-weight: 700; text-decoration: none; margin-top: .5rem; }
.ps-testimonials .jdgm-carousel-item__product:hover { text-decoration: underline; }

/* Navigation arrows + dots (if carousel paginates) */
.ps-testimonials .jdgm-carousel__prev, .ps-testimonials .jdgm-carousel__next { background: var(--lav) !important; border-color: var(--lav) !important; color: #fff !important; }
.ps-testimonials .jdgm-carousel__prev:hover, .ps-testimonials .jdgm-carousel__next:hover { background: var(--lav-dark) !important; }
.ps-testimonials .jdgm-carousel__dot { background: rgba(255,255,255,.35) !important; }
.ps-testimonials .jdgm-carousel__dot--active { background: #fff !important; }

</style>
