{%- comment -%} Self-hosted fonts (latin, variable) — served from Shopify CDN {%- endcomment -%}
@font-face { font-family: 'Luckiest Guy'; font-style: normal; font-weight: 400; font-display: swap; src: url('{{ 'font-luckiestguy-latin.woff2' | asset_url }}') format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
@font-face { font-family: 'Caveat'; font-style: normal; font-weight: 400 700; font-display: swap; src: url('{{ 'font-caveat-latin.woff2' | asset_url }}') format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
@font-face { font-family: 'Nunito'; font-style: normal; font-weight: 400 800; font-display: swap; src: url('{{ 'font-nunito-latin.woff2' | asset_url }}') format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }

:root {
  --lav:       #7C4D9E;  /* deep lavender — primary              */
  --lav-mid:   #A470C8;  /* mid lavender — buttons, accents      */
  --lav-light: #E8D5F5;  /* pale lavender — card fills, borders  */
  --lav-xlight:#F5EDFB;  /* whisper lavender — page background   */
  --lav-dark:  #4A2870;  /* darkest lavender — hover, footer     */
  --lav-ink:   #1E0A2E;  /* near-black purple — all body text    */
  --pink:      #C8607A;  /* deep pink — secondary CTA            */
  --pink-light:#F5D0DA;  /* pale pink — fills                    */
  --white:     #ffffff;
  --offwhite:  #FDFAFF;  /* page background                      */
  --border:    #D0B0E8;  /* lavender border                      */

  /* ── Every legacy alias → lavender equivalents, NO brown, NO yellow ── */
  --cream:  #FDFAFF;
  --warm:   #F5EDFB;
  --tan:    #E8D5F5;
  --brown:  #7C4D9E;
  --bark:   #1E0A2E;
  --ink:    #1E0A2E;
  --border-alt: #D0B0E8;
  --sun:    #E8D5F5;
  --honey:  #A470C8;
  --barn:   #7C4D9E;
  --barn2:  #4A2870;
  --barrel: #7C4D9E;
  --barrel2:#4A2870;
  --sage:   #A470C8;
  --moss:   #7C4D9E;
  --sky:    #E8D5F5;
  --butter: #E8D5F5;
  --butter-dk: #A470C8;
  --spoon:  #C8A8E0;
  --lavender: #7C4D9E;
  --lav-mid-old: #A470C8;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; overflow-x: hidden; }
body { font-family: 'Nunito', sans-serif; background: var(--offwhite); color: var(--lav-ink); }

.visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
.skip-to-content-link:focus { position: fixed; top: 1rem; left: 1rem; z-index: 9999; padding: .75rem 1.5rem; background: var(--lav); color: #fff; border-radius: 6px; font-weight: 700; text-decoration: none; width: auto; height: auto; clip: auto; }

/* ── Rainbow bar ── */
.ps-rainbow-bar {
  height: 8px;
  background: linear-gradient(90deg,
    #C8A8E0 0%,   /* pale lavender    */
    #A470C8 20%,  /* mid lavender     */
    #7C4D9E 40%,  /* deep lavender    */
    #4A2870 60%,  /* dark lavender    */
    #C8607A 80%,  /* pink             */
    #E8D5F5 100%  /* whisper lavender */
  ) 0px,    var(--lavender) 40px,
    var(--butter)   40px,   var(--butter)   80px,
    var(--barrel)   80px,   var(--barrel)   120px,
    var(--spoon)    120px,  var(--spoon)    160px,
    var(--lav-light)160px,  var(--lav-light)200px,
    var(--tan)      200px,  var(--tan)      240px
  );
}

/* ── Announce ── */
.ps-announce { background: var(--lav-dark); color: #fff; text-align: center; padding: .55rem 1rem; font-size: .78rem; font-weight: 700; letter-spacing: .04em; }
.ps-announce a { color: var(--sun); text-decoration: none; }
.ps-announce strong { color: var(--sun); }

/* ── Nav ── */
.ps-nav { position: fixed; top: var(--nav-top, 44px); left: 0; right: 0; z-index: 200; display: flex; align-items: center; justify-content: space-between; padding: .6rem 3rem; transition: top .2s, padding .4s, background .4s, box-shadow .4s; }
.ps-nav.scrolled { background: rgba(253,250,255,.97); backdrop-filter: blur(12px); top: 0 !important; padding: .5rem 3rem; box-shadow: 0 2px 0 var(--border), 0 4px 12px rgba(74,40,112,.1); }
.ps-nav-logo { text-decoration: none; display: flex; align-items: center; }
.ps-nav-logo-img { height: 64px; width: auto; object-fit: contain; transition: height .4s; }
.ps-nav.scrolled .ps-nav-logo-img { height: 54px; }
.ps-nav-solid .ps-nav-logo-img { height: 54px; }


.ps-nav-links { display: flex; gap: 0; list-style: none; }
.ps-nav-links a {
  font-size: .75rem;
  font-weight: 800;
  letter-spacing: .06em;
  text-transform: uppercase;
  text-decoration: none;
  color: rgba(255,255,255,.9);
  transition: color .25s, background .25s;
  padding: .45rem .9rem;
  border-radius: 20px;
}
.ps-nav.scrolled .ps-nav-links a { color: var(--lav-ink); }
.ps-nav-links a:hover {
  color: var(--bark) !important;
  background: var(--lav-light);
}
.ps-nav-actions { display: flex; align-items: center; }
.ps-cart-btn { display: flex; align-items: center; gap: .5rem; background: var(--lav-light); border: none; color: var(--lav-ink); font-family: 'Nunito', sans-serif; font-size: .75rem; font-weight: 800; padding: .5rem 1.1rem; cursor: pointer; clip-path: polygon(10% 0,100% 0,90% 100%,0 100%); transition: background .2s, color .2s; }
.ps-cart-btn:hover { background: var(--lav); color: #fff; }
.ps-cart-pill { background: var(--lav-mid); color: #fff; font-size: .62rem; font-weight: 800; padding: .05rem .4rem; border-radius: 10px; min-width: 18px; text-align: center; }
.ps-cart-pill.ps-bump { animation: psBump .3s ease; }
@keyframes psBump { 0%,100%{transform:scale(1)} 50%{transform:scale(1.5)} }
/* ── Redesign token bridge (Split Kinetic) ── */
:root {
  --lav-300: #C8A8E0;
  --ease-pop: cubic-bezier(.34, 1.56, .64, 1);
  --font-display: 'Luckiest Guy', cursive;
  --font-script:  'Caveat', cursive;
  --font-body:    'Nunito', sans-serif;
}

/* ── Hero: pinned split-kinetic sequence (critical — LCP) ── */
.ps-herowrap { height: 1760vh; position: relative; }
.ps-heropin { position: sticky; top: 0; height: 100vh; overflow: hidden; background: var(--offwhite); }
.ps-hero-bgdark { position: absolute; inset: 0; z-index: 0; background: radial-gradient(ellipse 60% 55% at 50% 45%, rgba(164,112,200,.5) 0%, transparent 60%), linear-gradient(180deg,#1E0A2E 0%,#120620 55%,#0A0313 100%); }
.ps-hero-photo { position: absolute; z-index: 5; display: flex; align-items: flex-end; justify-content: center; }
.ps-hero-bucket { position: relative; font-size: 6.5rem; line-height: 1; filter: drop-shadow(4px 6px 10px rgba(0,0,0,.35)); transform-origin: 82% 96%; }
.ps-hb-bubble { position: absolute; z-index: 6; border-radius: 50%; pointer-events: none; will-change: transform, opacity; border: 2px solid rgba(255,255,255,.35); background: radial-gradient(circle at 35% 35%, rgba(220,190,250,.9), rgba(150,100,200,.5)); }
.ps-hero-zoomlabel { position: absolute; inset: 0; z-index: 3; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding-top: var(--nav-top, 44px); }
.ps-hero-zoomlabel .label { font-size: .78rem; font-weight: 800; letter-spacing: .22em; text-transform: uppercase; color: var(--lav-300); }
.ps-hero-zoomlabel h1 { font-size: clamp(1.8rem,4.6vw,3.8rem); font-weight: 400; font-family: var(--font-display); color: #fff; letter-spacing: -.01em; line-height: 1.25; margin: 1rem 0 3rem; text-transform: uppercase; }
.ps-hero-zoomlabel h1 .glow { color: var(--lav-300); text-shadow: 0 0 10px rgba(164,112,200,.7); }
.ps-hero-zoomlabel p { font-family: var(--font-script); font-size: clamp(1.1rem,2.2vw,1.5rem); color: rgba(255,255,255,.7); margin: 0 0 1.6rem; }
.ps-hero-zoomlabel .cta-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.ps-btn-glow { background: var(--lav-300); color: #120620; border: 1px solid var(--lav-300); box-shadow: 0 0 40px rgba(164,112,200,.6); }
.ps-hero-panel { position: absolute; inset: 0; z-index: 4; background: var(--lav); display: flex; align-items: center; padding: 0 5vw 0 4vw; }
.ps-hero-panel-content { opacity: 0; max-width: 640px; }
.ps-hero-panel-content h1 { font-family: var(--font-display); font-size: clamp(2.6rem,6vw,5rem); color: #fff; line-height: .96; letter-spacing: .02em; text-shadow: 5px 5px 0 var(--lav-dark); margin: 0 0 2.2rem; }
.ps-hero-panel-content p { font-family: var(--font-script); color: var(--lav-light); font-size: clamp(1.2rem,2.4vw,1.6rem); margin: 0 0 2rem; }
.ps-hkbtn { display: inline-block; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; font-size: .95rem; padding: 1.05rem 2.2rem; cursor: pointer; clip-path: polygon(6% 0,100% 0,94% 100%,0 100%); text-decoration: none; }
.ps-hkbtn-light { background: #fff; color: var(--lav-ink); }
.ps-hkbtn-ghost { background: transparent; color: #fff; border: 3px solid #fff; }
@media (max-width: 900px) { .ps-hero-panel-content h1 { font-size: 2.4rem; } }

/* ── Reduced motion: unpin the kinetic sequence into a static stacked page ── */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; scroll-behavior: auto !important; }
  .ps-herowrap { height: auto; }
  .ps-heropin { position: static; height: auto; overflow: visible; display: flex; flex-direction: column; }
  .ps-hero-bgdark, .ps-hero-photo, #psBubbleField, .ps-hero-panel, .ps-hero-wipe-d, .ps-hero-wipe-f, .ps-kmarquee { display: none; }
  .ps-hero-zoomlabel { position: static; min-height: 68vh; background: radial-gradient(ellipse 60% 55% at 50% 45%, rgba(164,112,200,.5) 0%, transparent 60%), linear-gradient(180deg,#1E0A2E 0%,#120620 55%,#0A0313 100%); }
  .ps-hero-runway, .ps-hero-testimonials-layer, .ps-hero-newsletter-layer { position: static; opacity: 1; overflow: visible; }
  .ps-hero-testimonials-layer .ps-testimonials, .ps-hero-newsletter-layer .ps-newsletter { height: auto; }
  .ps-hero-panel-content, .ps-reveal { opacity: 1 !important; transform: none !important; }
}
