:root {
  --lav:       #7C4D9E;  /* deep lavender — primary              */
  --lav-mid:   #A470C8;  /* mid lavender — buttons, accents      */
  --lav-light: #E8D5F5;  /* pale lavender — card fills, borders  */
  --lav-xlight:#F5EDFB;  /* whisper lavender — page background   */
  --lav-dark:  #4A2870;  /* darkest lavender — hover, footer     */
  --lav-ink:   #1E0A2E;  /* near-black purple — all body text    */
  --pink:      #C8607A;  /* deep pink — secondary CTA            */
  --pink-light:#F5D0DA;  /* pale pink — fills                    */
  --white:     #ffffff;
  --offwhite:  #FDFAFF;  /* page background                      */
  --border:    #D0B0E8;  /* lavender border                      */

  /* ── Every legacy alias → lavender equivalents, NO brown, NO yellow ── */
  --cream:  #FDFAFF;
  --warm:   #F5EDFB;
  --tan:    #E8D5F5;
  --brown:  #7C4D9E;
  --bark:   #1E0A2E;
  --ink:    #1E0A2E;
  --border-alt: #D0B0E8;
  --sun:    #E8D5F5;
  --honey:  #A470C8;
  --barn:   #7C4D9E;
  --barn2:  #4A2870;
  --barrel: #7C4D9E;
  --barrel2:#4A2870;
  --sage:   #A470C8;
  --moss:   #7C4D9E;
  --sky:    #E8D5F5;
  --butter: #E8D5F5;
  --butter-dk: #A470C8;
  --spoon:  #C8A8E0;
  --lavender: #7C4D9E;
  --lav-mid-old: #A470C8;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; overflow-x: hidden; }
body { font-family: 'Nunito', sans-serif; background: var(--offwhite); color: var(--lav-ink); }

.visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
.skip-to-content-link:focus { position: fixed; top: 1rem; left: 1rem; z-index: 9999; padding: .75rem 1.5rem; background: var(--lav); color: #fff; border-radius: 6px; font-weight: 700; text-decoration: none; width: auto; height: auto; clip: auto; }

/* ── Rainbow bar ── */
.ps-rainbow-bar {
  height: 8px;
  background: linear-gradient(90deg,
    #C8A8E0 0%,   /* pale lavender    */
    #A470C8 20%,  /* mid lavender     */
    #7C4D9E 40%,  /* deep lavender    */
    #4A2870 60%,  /* dark lavender    */
    #C8607A 80%,  /* pink             */
    #E8D5F5 100%  /* whisper lavender */
  ) 0px,    var(--lavender) 40px,
    var(--butter)   40px,   var(--butter)   80px,
    var(--barrel)   80px,   var(--barrel)   120px,
    var(--spoon)    120px,  var(--spoon)    160px,
    var(--lav-light)160px,  var(--lav-light)200px,
    var(--tan)      200px,  var(--tan)      240px
  );
}

/* ── Announce ── */
.ps-announce { background: var(--lav-dark); color: #fff; text-align: center; padding: .55rem 1rem; font-size: .78rem; font-weight: 700; letter-spacing: .04em; }
.ps-announce a { color: var(--sun); text-decoration: none; }
.ps-announce strong { color: var(--sun); }

/* ── Nav ── */
.ps-nav { position: fixed; top: var(--nav-top, 44px); left: 0; right: 0; z-index: 200; display: flex; align-items: center; justify-content: space-between; padding: .6rem 3rem; transition: top .2s, padding .4s, background .4s, box-shadow .4s; }
.ps-nav.scrolled { background: rgba(253,250,255,.97); backdrop-filter: blur(12px); top: 0 !important; padding: .5rem 3rem; box-shadow: 0 2px 0 var(--border), 0 4px 12px rgba(74,40,112,.1); }
.ps-nav-logo { text-decoration: none; display: flex; align-items: center; }
.ps-nav-logo-img { height: 64px; width: auto; object-fit: contain; transition: height .4s; }
.ps-nav.scrolled .ps-nav-logo-img { height: 54px; }
.ps-nav-solid .ps-nav-logo-img { height: 54px; }


.ps-nav-links { display: flex; gap: 0; list-style: none; }
.ps-nav-links a {
  font-size: .75rem;
  font-weight: 800;
  letter-spacing: .06em;
  text-transform: uppercase;
  text-decoration: none;
  color: rgba(255,255,255,.9);
  transition: color .25s, background .25s;
  padding: .45rem .9rem;
  border-radius: 20px;
}
.ps-nav.scrolled .ps-nav-links a { color: var(--lav-ink); }
.ps-nav-links a:hover {
  color: var(--bark) !important;
  background: var(--lav-light);
}
.ps-nav-actions { display: flex; align-items: center; }
.ps-cart-btn { display: flex; align-items: center; gap: .5rem; background: var(--lav-light); border: 3px solid var(--bark); color: var(--lav-ink); font-family: 'Nunito', sans-serif; font-size: .75rem; font-weight: 800; padding: .4rem 1rem; cursor: pointer; border-radius: 20px; transition: all .2s; box-shadow: 3px 3px 0 var(--bark); }
.ps-cart-btn:hover { transform: translate(-2px,-2px); box-shadow: 5px 5px 0 var(--bark); }
.ps-cart-pill { background: var(--lav-mid); color: #fff; font-size: .62rem; font-weight: 800; padding: .05rem .4rem; border-radius: 10px; min-width: 18px; text-align: center; }
.ps-cart-pill.ps-bump { animation: psBump .3s ease; }
@keyframes psBump { 0%,100%{transform:scale(1)} 50%{transform:scale(1.5)} }
/* ── Hero (critical — LCP) ── */
.ps-hero { position: relative; height: 100vh; min-height: 640px; display: flex; align-items: center; overflow: hidden; padding-top: var(--nav-top, 44px); }
.ps-hero-bg { position: absolute; inset: -15%; will-change: transform;
  background: radial-gradient(ellipse 70% 60% at 60% 40%, rgba(164,112,200,.35) 0%, transparent 55%),
              radial-gradient(ellipse 50% 70% at 20% 70%, rgba(122,158,110,.30) 0%, transparent 50%),
              linear-gradient(170deg, #4A2870 0%, #7C4D9E 35%, #5A3060 70%, #4A2870 100%); }
.ps-hero-pattern { position: absolute; inset: 0; opacity: .06; pointer-events: none;
  background-image: repeating-linear-gradient(0deg, transparent, transparent 30px, rgba(255,255,255,.8) 30px, rgba(255,255,255,.8) 32px),
                    repeating-linear-gradient(90deg, transparent, transparent 30px, rgba(255,255,255,.8) 30px, rgba(255,255,255,.8) 32px); }
.ps-bubble { position: absolute; border-radius: 50%; pointer-events: none; will-change: transform; }
.ps-bubble-1 { width:120px;height:120px; top:12%;right:10%; background:radial-gradient(circle at 35% 35%,rgba(164,112,200,.85),rgba(100,60,150,.5)); border:3px solid rgba(255,255,255,.3); animation:psBobble 6s ease-in-out infinite; }
.ps-bubble-2 { width:80px;height:80px;  top:15%;left:48%; background:radial-gradient(circle at 35% 35%,rgba(200,160,230,.8),rgba(140,90,190,.4));  border:3px solid rgba(255,255,255,.3); animation:psBobble 8s ease-in-out infinite 2s; }
.ps-bubble-3 { width:100px;height:100px;bottom:15%;right:8%;background:radial-gradient(circle at 35% 35%,rgba(188,140,190,.8),rgba(120,80,130,.4));  border:3px solid rgba(255,255,255,.3); animation:psBobble 7s ease-in-out infinite 1s; }
.ps-bubble-4 { width:60px;height:60px;  top:30%;right:32%;background:radial-gradient(circle at 35% 35%,rgba(180,130,220,.8),rgba(120,70,170,.4)); border:3px solid rgba(255,255,255,.3); animation:psBobble 9s ease-in-out infinite 3s; }
.ps-bubble-5 { width:45px;height:45px;  top:18%;right:52%; background:radial-gradient(circle at 38% 32%,rgba(210,170,240,.9),rgba(150,100,200,.5)); border:2px solid rgba(255,255,255,.25); animation:psBobble 7.5s ease-in-out infinite 0.5s; }
.ps-bubble-6 { width:90px;height:90px;  top:65%;right:44%; background:radial-gradient(circle at 35% 35%,rgba(170,120,210,.75),rgba(110,65,160,.4)); border:3px solid rgba(255,255,255,.2); animation:psBobble 10s ease-in-out infinite 4s; }
.ps-bubble-7 { width:35px;height:35px;  top:42%;right:58%; background:radial-gradient(circle at 40% 30%,rgba(220,190,250,.9),rgba(160,120,210,.5)); border:2px solid rgba(255,255,255,.3); animation:psBobble 6.5s ease-in-out infinite 1.5s; }
@keyframes psBobble { 0%,100%{transform:translateY(0) rotate(0deg)} 33%{transform:translateY(-18px) rotate(5deg)} 66%{transform:translateY(10px) rotate(-3deg)} }
.ps-hero-art { position:absolute;right:3%;bottom:0;z-index:2;font-size:12rem;line-height:1;opacity:.22;transform:scaleX(-1);pointer-events:none;will-change:transform; }
.ps-mascot-canvas { position:absolute;inset:0;width:100%;height:100%;z-index:3;pointer-events:none; }
.ps-hero-content { position:relative;z-index:5;padding:0 4rem 0 5rem;max-width:680px; }
.ps-hero-eyebrow { display:inline-flex;align-items:center;gap:.5rem;background:var(--sun);border:3px solid var(--bark);padding:.3rem .9rem;border-radius:20px;font-size:.72rem;font-weight:800;color:var(--lav-ink);letter-spacing:.06em;text-transform:uppercase;margin-bottom:1.2rem;box-shadow:3px 3px 0 var(--bark);opacity:0;animation:psPopIn .6s cubic-bezier(.34,1.56,.64,1) forwards .2s; }
.ps-hero-h1 { font-family:'Luckiest Guy',cursive;font-size:clamp(3rem,7vw,6.5rem);line-height:1;color:#fff;letter-spacing:.04em;text-shadow:4px 4px 0 var(--bark),6px 6px 0 rgba(0,0,0,.2);margin-bottom:.2em;opacity:0;animation:psPopIn .7s cubic-bezier(.34,1.56,.64,1) forwards .4s; }
.ps-hero-h1 span { color:var(--sun); }
.ps-hero-sub { font-family:'Caveat',cursive;font-size:clamp(1.3rem,3vw,2rem);color:var(--tan);line-height:1.4;margin-bottom:2rem;opacity:0;animation:psPopIn .6s cubic-bezier(.34,1.56,.64,1) forwards .6s; }
.ps-hero-btns { display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:psPopIn .6s cubic-bezier(.34,1.56,.64,1) forwards .8s; }
.ps-hero-offer { position:absolute;right:4%;top:30%;z-index:5;background:#fff;border:4px solid var(--lavender);padding:1.2rem 1.4rem;max-width:200px;text-align:center;transform:rotate(3deg);box-shadow:6px 6px 0 var(--bark);opacity:0;animation:psPopIn .7s cubic-bezier(.34,1.56,.64,1) forwards 1s; }
.ps-offer-icon { font-size:1.8rem; }
.ps-offer-title { font-family:'Luckiest Guy',cursive;font-size:1rem;color:var(--lav-dark);letter-spacing:.04em;margin:.3rem 0 .2rem; }
.ps-offer-body { font-size:.7rem;font-weight:700;color:var(--lav-mid);line-height:1.4; }
.ps-hero-phone { position:absolute;bottom:2.5rem;left:5rem;z-index:5;display:flex;align-items:center;gap:.6rem;opacity:0;animation:psFadeIn .8s ease forwards 1.2s; }
.ps-hero-phone a { font-family:'Caveat',cursive;font-size:1.15rem;color:var(--tan);text-decoration:none;font-weight:600; }
.ps-hero-phone a:hover { color:var(--sun); }
@keyframes psPopIn { from{opacity:0;transform:scale(.7) translateY(20px)} to{opacity:1;transform:scale(1) translateY(0)} }
@keyframes psFadeIn { from{opacity:0} to{opacity:1} }
