{%- comment -%}
  ps-footer.liquid — Site footer, cart drawer, and all shared cart JS.

  Shopify admin wiring (Content > Navigation):
  ┌─────────────────────────────────────────────────────────────────┐
  │ Menu: "Footer"   handle: footer                                 │
  │   Top-level items = column headings (e.g. "Shop", "About",      │
  │   "Help"). Set their URL to / since they are labels, not links. │
  │   Child items under each heading = the actual footer links.     │
  │                                                                 │
  │   Example structure:                                            │
  │     Shop (/)                                                    │
  │       ├ All Products  → /collections/all                        │
  │       └ Best Sellers  → /collections/all?sort_by=best-selling   │
  │     About (/)                                                   │
  │       ├ Our Story     → /pages/our-story                        │
  │       └ Find Us       → /#ps-find-us                            │
  │     Help (/)                                                    │
  │       ├ Contact Us    → /pages/contact                          │
  │       └ View Cart     → /cart                                   │
  │                                                                 │
  │   If the "Footer" menu doesn't exist, hardcoded defaults show.  │
  └─────────────────────────────────────────────────────────────────┘

  Also contains all shared cart JS functions used site-wide:
    psOpenCart / psCloseCart / psRefreshCart / psRenderCart
    psAddToCart / psUpdateQty / psRemoveLine / psShowToast / psMoney
{%- endcomment -%}

<footer class="ps-footer">
  <div class="ps-footer-top">
    <div>
      <a href="{{ shop.url }}" class="ps-f-logo">
        <img src="{{ 'logo-transparent.png' | asset_url }}" alt="{{ shop.name }}" class="ps-f-logo-img">
      </a>
      <p class="ps-f-sub">of Iowa · Est. 2019 · Veteran-Owned</p>
      <p class="ps-f-desc">"The cleanest body products that money can buy" — handcrafted with love in Oskaloosa, Iowa.</p>
      <div class="ps-f-contact">📞 <a href="tel:6416701573">641.670.1573</a></div>
      {%- assign soc_menu = linklists['social-media-accounts'] -%}
      {%- if soc_menu.links.size > 0 -%}
        <div class="ps-f-soc">
          {%- for link in soc_menu.links -%}
            {%- assign url_lower = link.url | downcase -%}
            {%- assign title_lower = link.title | downcase -%}
            <a href="{{ link.url }}" target="_blank" rel="noopener" aria-label="{{ link.title }}" class="ps-soc-a">
              {%- if url_lower contains 'facebook' or title_lower contains 'facebook' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              {%- elsif url_lower contains 'instagram' or title_lower contains 'instagram' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              {%- elsif url_lower contains 'tiktok' or title_lower contains 'tiktok' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34l-.03-8.36a8.27 8.27 0 0 0 4.84 1.55V5.05a4.85 4.85 0 0 1-1.04-.36z"/></svg>
              {%- elsif url_lower contains 'youtube' or title_lower contains 'youtube' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.47a2.78 2.78 0 0 0-1.95 1.97A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.45a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
              {%- elsif url_lower contains 'pinterest' or title_lower contains 'pinterest' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
              {%- elsif url_lower contains 'twitter' or url_lower contains 'x.com' or title_lower contains 'twitter' or title_lower == 'x' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.632 5.903-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- assign footer_nav = linklists['footer'] -%}
    {%- if footer_nav.links.size > 0 -%}
      {%- for col in footer_nav.links -%}
        <div class="ps-footer-col">
          <h5>{{ col.title }}</h5>
          <ul>
            {%- for link in col.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="ps-footer-col"><h5>Shop</h5><ul>
        <li><a href="{{ shop.url }}/collections/all">All Products</a></li>
        <li><a href="{{ shop.url }}/collections/all?sort_by=best-selling">Best Sellers</a></li>
        <li><a href="{{ shop.url }}/collections/all">Soaps</a></li>
        <li><a href="{{ shop.url }}/collections/all">Lotions</a></li>
        <li><a href="{{ shop.url }}/collections/all">Candles</a></li>
      </ul></div>
      <div class="ps-footer-col"><h5>About</h5><ul>
        <li><a href="{{ shop.url }}/pages/our-story">Our Story</a></li>
        <li><a href="{{ shop.url }}/pages/our-story">Veteran Owned</a></li>
        <li><a href="{{ shop.url }}/#ps-scents">Scent Library</a></li>
        <li><a href="{{ shop.url }}/#ps-find-us">Find Us</a></li>
      </ul></div>
      <div class="ps-footer-col"><h5>Help</h5><ul>
        <li><a href="{{ shop.url }}/pages/shipping">Shipping Info</a></li>
        <li><a href="{{ shop.url }}/pages/returns">Returns &amp; Refunds</a></li>
        <li><a href="{{ shop.url }}/pages/privacy-policy">Privacy Policy</a></li>
        <li><a href="{{ shop.url }}/pages/terms-of-service">Terms of Service</a></li>
        <li><a href="{{ shop.url }}/pages/contact">Contact Us</a></li>
        <li><a href="{{ shop.url }}/cart">View Cart</a></li>
      </ul></div>
    {%- endif -%}
  </div>
  <div class="ps-footer-btm">
    <p>© {{ 'now' | date: "%Y" }} Papa Stan's of Iowa. All rights reserved. Made with ❤️ in Oskaloosa.</p>
    <p>Powered by Shopify</p>
  </div>
</footer>

{% render 'ps-cart-drawer' %}

<script>
/* ─── Shared cart JS — do not duplicate in individual sections ─── */
const PS_FREE_SHIP_CENTS = 5500;

function psMoney(c) { return '$' + (c / 100).toFixed(2); }

async function psAddToCart(variantId, title) {
  psShowToast('Adding to cart… 🛒');
  try {
    const r = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    });
    if (!r.ok) throw new Error('Failed');
    await psRefreshCart();
    psShowToast('✅ ' + title + ' added!');
    const pill = document.querySelector('.ps-cart-pill');
    if (pill) { pill.classList.remove('ps-bump'); void pill.offsetWidth; pill.classList.add('ps-bump'); }
    psOpenCart();
  } catch(e) { psShowToast('Something went wrong, please try again.'); }
}

async function psUpdateQty(key, qty) {
  const u = {}; u[key] = qty;
  await fetch('/cart/update.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ updates: u }) });
  await psRefreshCart();
}
async function psRemoveLine(key) { await psUpdateQty(key, 0); }

async function psRefreshCart() {
  const r = await fetch('/cart.js', { headers: { 'Accept': 'application/json' } });
  const cart = await r.json();
  psRenderCart(cart);
  const countEl = document.getElementById('psCartCount');
  if (countEl) countEl.textContent = cart.item_count || 0;
}

function psRenderCart(cart) {
  const el = document.getElementById('psCartItems');
  const ft = document.getElementById('psCartFoot');
  if (!el) return;
  if (!cart.items || !cart.items.length) {
    el.innerHTML = '<p class="ps-cart-empty">Your cart is empty!<br>Go find something wonderful 🌿</p>';
    if (ft) ft.style.display = 'none';
    return;
  }
  if (ft) ft.style.display = 'block';
  el.innerHTML = cart.items.map(item => `
    <div class="ps-cart-item">
      <img class="ps-ci-img" src="${item.image ? item.image.replace('http:', 'https:') : ''}" alt="${item.title}" onerror="this.style.visibility='hidden'">
      <div>
        <div class="ps-ci-name">${item.product_title}</div>
        <div class="ps-ci-price">${psMoney(item.price)}</div>
        <div class="ps-ci-qty">
          <button onclick="psUpdateQty('${item.key}',${item.quantity - 1})">−</button>
          <span>${item.quantity}</span>
          <button onclick="psUpdateQty('${item.key}',${item.quantity + 1})">+</button>
        </div>
      </div>
      <button class="ps-ci-remove" onclick="psRemoveLine('${item.key}')">✕</button>
    </div>`).join('');
  document.getElementById('psCartTotal').textContent = psMoney(cart.total_price);
  const pct = Math.min((cart.total_price / PS_FREE_SHIP_CENTS) * 100, 100);
  document.getElementById('psShipFill').style.width = pct + '%';
  const rem = psMoney(Math.max(PS_FREE_SHIP_CENTS - cart.total_price, 0));
  document.getElementById('psShipMsg').innerHTML = cart.total_price >= PS_FREE_SHIP_CENTS
    ? '<strong>🎉 Free shipping unlocked!</strong>'
    : `Add <strong>${rem} more</strong> for free shipping 🚚`;
}

function psOpenCart() {
  psRefreshCart();
  document.getElementById('psCartDrawer').classList.add('open');
  document.getElementById('psCartOverlay').classList.add('open');
}
function psCloseCart() {
  document.getElementById('psCartDrawer').classList.remove('open');
  document.getElementById('psCartOverlay').classList.remove('open');
}

let psToastTimer;
function psShowToast(msg) {
  const t = document.getElementById('psToast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(psToastTimer);
  psToastTimer = setTimeout(() => t.classList.remove('show'), 2800);
}

window.addEventListener('scroll', () => {
  const nav = document.getElementById('psNav');
  if (nav) nav.classList.toggle('scrolled', window.scrollY > 10);
}, { passive: true });

psRefreshCart();
</script>
