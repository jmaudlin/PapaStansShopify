{% layout none %}
{%- comment -%}
  Gift card issued page — standalone (no theme layout). Self-contained Papa
  Stan's styling: brand palette via theme color settings, self-hosted fonts,
  QR code via Shopify's vendored qrcode.js, print-friendly.
{%- endcomment -%}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary | default: '#7C4D9E' }}">
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}
  {%- assign formatted_balance = gift_card.balance | money_without_trailing_zeros | strip_html -%}
  <title>{{ formatted_balance }} Gift Card — {{ shop.name }}</title>
  <meta name="description" content="Your {{ shop.name }} gift card.">
  <meta name="robots" content="noindex">
  {{ content_for_header }}
  <script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>
  <style>
    @font-face { font-family: 'Luckiest Guy'; font-style: normal; font-weight: 400; font-display: swap; src: url('{{ 'font-luckiestguy-latin.woff2' | asset_url }}') format('woff2'); }
    @font-face { font-family: 'Nunito'; font-style: normal; font-weight: 400 800; font-display: swap; src: url('{{ 'font-nunito-latin.woff2' | asset_url }}') format('woff2'); }
    @font-face { font-family: 'Caveat'; font-style: normal; font-weight: 400 700; font-display: swap; src: url('{{ 'font-caveat-latin.woff2' | asset_url }}') format('woff2'); }
    :root {
      --lav: {{ settings.color_primary | default: '#7C4D9E' }};
      --lav-dark: {{ settings.color_primary_dark | default: '#4A2870' }};
      --lav-light: {{ settings.color_primary_light | default: '#E8D5F5' }};
      --lav-xlight: {{ settings.color_bg_tint | default: '#F5EDFB' }};
      --ink: {{ settings.color_text | default: '#1E0A2E' }};
      --offwhite: {{ settings.color_background | default: '#FDFAFF' }};
      --border: {{ settings.color_border | default: '#D0B0E8' }};
    }
    * { box-sizing: border-box; margin: 0; }
    body { font-family: 'Nunito', sans-serif; background: var(--offwhite); color: var(--ink); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
    .gc-card { width: 100%; max-width: 460px; background: #fff; box-shadow: inset 0 0 0 2px var(--border), 8px 8px 0 var(--lav-light); clip-path: polygon(0 0, 100% 0, 100% 96%, 94% 100%, 0 100%); padding: 2.5rem 2rem 2.75rem; text-align: center; }
    .gc-eyebrow { font-size: .72rem; font-weight: 800; letter-spacing: .2em; text-transform: uppercase; color: var(--lav); margin-bottom: .4rem; }
    .gc-shop { font-family: 'Luckiest Guy', cursive; font-size: 1.7rem; letter-spacing: .03em; color: var(--ink); margin-bottom: 1.4rem; }
    .gc-balance { font-family: 'Luckiest Guy', cursive; font-size: 3.2rem; color: var(--lav); line-height: 1; margin-bottom: .4rem; }
    .gc-sub { font-family: 'Caveat', cursive; font-size: 1.2rem; color: var(--lav-dark); margin-bottom: 1.6rem; }
    .gc-badge { display: inline-block; background: var(--lav-xlight); color: var(--lav-dark); font-size: .72rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; padding: .35rem 1rem; clip-path: polygon(8% 0,100% 0,92% 100%,0 100%); margin-bottom: 1rem; }
    .gc-code { font-size: 1.35rem; font-weight: 800; letter-spacing: .14em; background: var(--lav-xlight); border: 2px dashed var(--lav); padding: .9rem 1rem; margin: 0 auto 1.2rem; user-select: all; }
    .gc-qr { display: flex; justify-content: center; margin-bottom: 1.4rem; min-height: 72px; }
    .gc-how { font-size: .85rem; font-weight: 600; color: var(--lav-dark); line-height: 1.6; margin-bottom: 1.6rem; }
    .gc-btns { display: flex; flex-direction: column; gap: .7rem; align-items: center; }
    .gc-btn { display: inline-block; width: 100%; max-width: 280px; padding: .85rem 1.5rem; font-family: 'Nunito', sans-serif; font-size: .82rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; text-decoration: none; text-align: center; cursor: pointer; border: none; clip-path: polygon(4% 0,100% 0,96% 100%,0 100%); }
    .gc-btn-primary { background: var(--lav); color: #fff; }
    .gc-btn-primary:hover { background: var(--lav-dark); }
    .gc-btn-secondary { background: var(--lav-xlight); color: var(--ink); box-shadow: inset 0 0 0 2px var(--lav); }
    .gc-copied { font-size: .8rem; font-weight: 700; color: var(--lav); min-height: 1.2em; }
    .gc-expiry { font-size: .78rem; font-weight: 600; color: var(--lav-dark); margin-bottom: 1rem; }
    .gc-wallet { display: inline-block; margin-bottom: 1.2rem; }
    @media print { .no-print { display: none !important; } body { background: #fff; } .gc-card { box-shadow: none; clip-path: none; border: 2px solid #ccc; } }
  </style>
</head>
<body>
  <div class="gc-card">
    <div class="gc-eyebrow">🎁 Gift Card</div>
    <div class="gc-shop">{{ shop.name }}</div>
    <div class="gc-balance">{{ gift_card.balance | money }}</div>
    <p class="gc-sub">The cleanest gift that money can buy!</p>

    {%- if gift_card.enabled == false or gift_card.expired -%}
      <div class="gc-badge">Expired</div>
    {%- endif -%}
    {%- if gift_card.expires_on -%}
      <p class="gc-expiry">Expires {{ gift_card.expires_on | date: '%B %e, %Y' }}</p>
    {%- endif -%}

    <p id="gcCode" class="gc-code">{{ gift_card.code | format_code }}</p>
    <div class="gc-qr no-print"><div id="gcQr" data-identifier="{{ gift_card.qr_identifier }}"></div></div>
    <p class="gc-how">Use this code at checkout, or show the QR code in person at our Oskaloosa shop or local events.</p>

    {%- if gift_card.pass_url -%}
      <a href="{{ gift_card.pass_url }}" class="gc-wallet no-print">
        <img src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}" width="120" height="40" alt="Add to Apple Wallet" loading="lazy">
      </a>
    {%- endif -%}

    <div class="gc-btns no-print">
      <span class="gc-copied" id="gcCopied" role="status"></span>
      <button type="button" class="gc-btn gc-btn-primary" id="gcCopyBtn">Copy Code</button>
      <a href="{{ shop.url }}" class="gc-btn gc-btn-secondary">Shop Papa Stan's 🌿</a>
      <button type="button" class="gc-btn gc-btn-secondary" onclick="window.print()">Print 🖨️</button>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var qrEl = document.getElementById('gcQr');
      if (qrEl && window.QRCode) {
        new QRCode(qrEl, { text: qrEl.dataset.identifier, width: 72, height: 72 });
      }
      var btn = document.getElementById('gcCopyBtn');
      btn.addEventListener('click', function () {
        var code = document.getElementById('gcCode').textContent.trim();
        navigator.clipboard.writeText(code).then(function () {
          document.getElementById('gcCopied').textContent = '✅ Code copied!';
          setTimeout(function () { document.getElementById('gcCopied').textContent = ''; }, 2500);
        });
      });
    });
  </script>
</body>
</html>
